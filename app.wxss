page {
  background: #0f0c29;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #e2e8f0;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx 28rpx 40rpx;
}

/* 通用卡片 */
.card {
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f1f5f9;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

/* 游戏风格按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 16rpx 32rpx;
  transition: all 0.2s;
}

.btn::after {
  border: none;
}

.btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 标签 */
.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 通用HP条 */
.hp-bar-bg {
  background: rgba(0,0,0,0.3);
  border-radius: 10rpx;
  height: 20rpx;
  overflow: hidden;
}

.hp-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease-out;
  background: linear-gradient(90deg, #10b981, #34d399);
}

.hp-bar-fill.low {
  background: linear-gradient(90deg, #ef4444, #f87171);
}

.hp-bar-fill.medium {
  background: linear-gradient(90deg, #f59e0b, #fbbf24);
}

/* XP条 */
.xp-bar-bg {
  background: rgba(0,0,0,0.3);
  border-radius: 10rpx;
  height: 16rpx;
  overflow: hidden;
}

.xp-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease-out;
  background: linear-gradient(90deg, #a78bfa, #c084fc);
}

/* 稀有度颜色 */
.rarity-common { color: #94a3b8; }
.rarity-rare { color: #3b82f6; }
.rarity-epic { color: #a855f7; }
.rarity-legendary { color: #f59e0b; }

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}
