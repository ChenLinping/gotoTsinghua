page {
  background: #2d1b00;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #e8dcc8;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx 28rpx 40rpx;
}

/* 通用卡片 (MC风格) */
.card {
  background: #4a3728;
  border-radius: 6rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid #5a4738;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.3);
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffd700;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.4);
}

/* 游戏风格按钮 (MC方块按钮) */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: 4rpx solid #7ab356;
  padding: 16rpx 32rpx;
  transition: all 0.15s;
  background: linear-gradient(180deg, #5b8c3e 0%, #3d6b28 100%);
  color: #fff;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.4);
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.3);
}

.btn::after {
  border: none;
}

.btn:active {
  transform: translateY(3rpx);
  box-shadow: 0 1rpx 0 rgba(0,0,0,0.3);
}

/* 标签 */
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-weight: 600;
  border: 2rpx solid rgba(255,255,255,0.15);
}

/* 通用HP条 (MC像素风) */
.hp-bar-bg {
  background: rgba(0,0,0,0.3);
  border-radius: 4rpx;
  height: 20rpx;
  overflow: hidden;
  border: 3rpx solid rgba(0,0,0,0.3);
}

.hp-bar-fill {
  height: 100%;
  border-radius: 2rpx;
  transition: width 0.5s ease-out;
  background: linear-gradient(180deg, #4ade80 0%, #22c55e 100%);
  box-shadow: inset 0 -2rpx 0 rgba(0,0,0,0.2);
}

.hp-bar-fill.low {
  background: linear-gradient(180deg, #ff6b6b 0%, #cc3333 100%);
}

.hp-bar-fill.medium {
  background: linear-gradient(180deg, #fbbf24 0%, #f59e0b 100%);
}

/* XP条 */
.xp-bar-bg {
  background: rgba(0,0,0,0.3);
  border-radius: 4rpx;
  height: 16rpx;
  overflow: hidden;
  border: 3rpx solid rgba(0,0,0,0.3);
}

.xp-bar-fill {
  height: 100%;
  border-radius: 2rpx;
  transition: width 0.5s ease-out;
  background: linear-gradient(180deg, #ffd700 0%, #b8860b 100%);
  box-shadow: inset 0 -2rpx 0 rgba(0,0,0,0.2);
}

/* 稀有度颜色 */
.rarity-common { color: #94a3b8; }
.rarity-rare { color: #3b82f6; }
.rarity-epic { color: #a855f7; }
.rarity-legendary { color: #f59e0b; }

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}
