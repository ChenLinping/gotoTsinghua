.subject-tabs {
  white-space: nowrap;
  margin-bottom: 24rpx;
}
.subject-tab {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  border-radius: 18rpx;
  font-weight: 600;
  font-size: 28rpx;
  margin-right: 12rpx;
  background: #fff;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
}
.subject-tab.active {
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.subject-header {
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.subject-header-name { font-size: 38rpx; font-weight: 800; display: block; margin-bottom: 8rpx; }
.subject-header-phase { font-size: 26rpx; opacity: 0.9; display: block; }
.subject-header-right { text-align: right; }
.mastered-label { font-size: 22rpx; opacity: 0.8; display: block; }
.mastered-num { font-size: 36rpx; font-weight: 800; display: block; }

.topic-item {
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  border: 1rpx solid #f1f5f9;
}
.topic-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx;
  border-radius: 16rpx;
}
.topic-title { font-size: 28rpx; font-weight: 600; color: #334155; }
.topic-arrow {
  font-size: 32rpx; color: #94a3b8;
  transition: transform 0.2s;
}
.topic-body { padding: 20rpx 28rpx; }
.point-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 10rpx 0;
}
.point-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%; flex-shrink: 0;
  margin-top: 14rpx;
}
.point-text { font-size: 26rpx; color: #334155; line-height: 1.7; flex: 1; }

.question-item {
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  border: 2rpx solid #f1f5f9;
}
.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
}
.q-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.q-num {
  width: 56rpx; height: 56rpx;
  border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
  flex-shrink: 0;
}
.q-info { flex: 1; overflow: hidden; }
.q-preview {
  font-size: 26rpx; color: #334155; font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}
.q-tags { display: flex; gap: 8rpx; margin-top: 6rpx; }
.diff-tag { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 6rpx; font-weight: 500; }
.q-arrow {
  font-size: 36rpx; color: #94a3b8;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.q-body { padding: 0 28rpx 28rpx; }
.q-content {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  color: #1e293b;
  line-height: 1.8;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}
.hint-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 14rpx;
  border: 2rpx solid #fde68a;
  background: #fffbeb;
  font-size: 26rpx;
  color: #92400e;
  margin-bottom: 16rpx;
}
.hint-content {
  background: #fef3c7;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #92400e;
  margin-bottom: 16rpx;
  line-height: 1.6;
}
.answer-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.answer-content {
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 26rpx;
  color: #1e293b;
  line-height: 1.8;
  white-space: pre-wrap;
  border-left: 6rpx solid;
  margin-bottom: 16rpx;
}
.master-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.title-icon { font-size: 32rpx; margin-right: 12rpx; }
