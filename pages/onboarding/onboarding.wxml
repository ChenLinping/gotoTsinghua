<view class="page-bg">

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;" wx:if="{{step >= 1 && step <= 3}}">
    <view class="nav-bar">
      <view wx:if="{{step >= 1 && step <= 2}}" class="nav-back" bindtap="goBack">
        <text class="nav-back-text">{{'< '}} 返回</text>
      </view>
      <text class="nav-title">{{step === 1 ? '报名修仙' : step === 2 ? '灵根鉴定' : '仙缘已至'}}</text>
      <view class="nav-spacer" wx:if="{{step >= 1 && step <= 2}}"></view>
    </view>
  </view>

  <!-- 步骤指示器 -->
  <view class="step-indicator" wx:if="{{step >= 1 && step <= 3}}">
    <view class="step-dot {{step >= 1 ? 'step-active' : ''}}"></view>
    <view class="step-line {{step >= 2 ? 'line-active' : ''}}"></view>
    <view class="step-dot {{step >= 2 ? 'step-active' : ''}}"></view>
    <view class="step-line {{step >= 3 ? 'line-active' : ''}}"></view>
    <view class="step-dot {{step >= 3 ? 'step-active' : ''}}"></view>
  </view>

  <!-- ========== Step 0: 品牌首页 ========== -->
  <view class="step-content splash-view" wx:if="{{step === 0}}">

    <!-- 灵气粒子 -->
    <view class="splash-particles">
      <view wx:for="{{particles}}" wx:key="*this" class="sp-dot {{item}}" style="background:#a78bfa;"></view>
    </view>

    <view class="splash-glow"></view>

    <view class="splash-brand">
      <text class="brand-icon">{{'🏆'}}</text>
      <text class="brand-title">清北修仙传</text>
      <text class="brand-sub">修仙之路，从此刻开始</text>
    </view>

    <view class="splash-features">
      <view class="sf-item">
        <text class="sf-icon">{{'⚡'}}</text>
        <text class="sf-text">五大境界 · 二十重突破</text>
      </view>
      <view class="sf-item">
        <text class="sf-icon">{{'📚'}}</text>
        <text class="sf-text">六科修炼 · 答题即修行</text>
      </view>
      <view class="sf-item">
        <text class="sf-icon">{{'🔥'}}</text>
        <text class="sf-text">每日打卡 · 道心坚定</text>
      </view>
    </view>

    <view class="splash-btn" bindtap="enterGame">
      <text class="btn-text">踏入仙途</text>
    </view>
  </view>

  <!-- ========== Step 1: 输入名字 ========== -->
  <view class="step-content" wx:if="{{step === 1}}" style="padding-top: {{statusBarHeight + 44 + 20}}px;">

    <view class="name-hero">
      <view class="name-circle">
        <text class="name-emoji">{{'🧙'}}</text>
      </view>
    </view>

    <view class="name-prompt">
      <text class="prompt-title">报上名来，修仙者！</text>
      <text class="prompt-desc">此名将伴随你的修仙之路（最多8字）</text>
    </view>

    <view class="name-input-wrap">
      <view class="name-input-border {{nameError ? 'input-error' : ''}}">
        <input
          class="name-input"
          placeholder="输入你的名字..."
          placeholder-class="name-placeholder"
          maxlength="8"
          value="{{name}}"
          bindinput="onNameInput"
          bindconfirm="confirmName"
          focus="{{step === 1}}"
        />
      </view>
      <text wx:if="{{nameError}}" class="error-text">{{nameError}}</text>
    </view>

    <view class="action-btn" bindtap="confirmName">
      <text class="btn-text">确认名字</text>
    </view>
  </view>

  <!-- ========== Step 2: 成绩输入 ========== -->
  <view class="step-content score-view" wx:if="{{step === 2}}" style="padding-top: {{statusBarHeight + 44 + 10}}px;">

    <view class="score-header">
      <text class="score-header-icon">{{'🔮'}}</text>
      <text class="score-header-title">灵根鉴定</text>
      <text class="score-header-desc">输入最近一次考试各科成绩</text>
    </view>

    <view class="score-list">
      <view class="score-item" wx:for="{{subjects}}" wx:key="key"
        style="border-left: 6rpx solid {{item.color}};">
        <view class="score-left">
          <text class="score-icon">{{item.icon}}</text>
          <view class="score-info">
            <text class="score-name">{{item.name}}</text>
            <text class="score-max">满分 {{item.max}}</text>
          </view>
        </view>
        <view class="score-input-wrap">
          <input
            class="score-input"
            type="number"
            placeholder="0"
            placeholder-class="score-placeholder"
            value="{{item.score}}"
            data-idx="{{index}}"
            bindinput="onScoreInput"
          />
          <text class="score-unit">分</text>
        </view>
      </view>
    </view>

    <!-- 总分 -->
    <view class="score-summary" wx:if="{{totalScore > 0}}">
      <view class="summary-row">
        <text class="summary-label">总分</text>
        <text class="summary-value {{scoreWarning ? 'warn' : ''}}">{{totalScore}} / {{maxTotal}}</text>
      </view>
      <text wx:if="{{scoreWarning}}" class="warn-text">{{scoreWarning}}</text>
    </view>

    <view class="action-btn {{scoreWarning ? 'btn-disabled' : ''}}" bindtap="confirmScores">
      <text class="btn-text">完成鉴定</text>
    </view>
  </view>

  <!-- ========== Step 3: 仪式感欢迎 ========== -->
  <view class="step-content welcome-view" wx:if="{{step === 3}}" style="padding-top: {{statusBarHeight + 44 + 10}}px;">

    <view class="welcome-portal">
      <view class="portal-ring"></view>
      <view class="portal-ring2"></view>
      <text class="portal-icon">{{'✨'}}</text>
    </view>

    <text class="welcome-big-title">{{welcomeTitle}}</text>

    <view class="welcome-msg-box">
      <text class="welcome-msg-text">{{welcomeMsg}}</text>
    </view>

    <view class="welcome-score-row">
      <view class="wsr-item">
        <text class="wsr-val">{{totalScore}}</text>
        <text class="wsr-label">总分</text>
      </view>
      <view class="wsr-item">
        <text class="wsr-val">练气初期</text>
        <text class="wsr-label">初始境界</text>
      </view>
      <view class="wsr-item">
        <text class="wsr-val">化神大圆满</text>
        <text class="wsr-label">终极目标</text>
      </view>
    </view>

    <view class="action-btn cinematic-btn" bindtap="startCinematic">
      <text class="btn-text">让我们开始修仙之路吧</text>
    </view>
  </view>

  <!-- ========== Step 4: 开场动画 ========== -->
  <view class="cinematic-overlay" wx:if="{{step === 4}}">
    <view class="cin-bg" bindtap="skipCinematic"></view>

    <!-- 灵气粒子 -->
    <view class="cin-particles">
      <view wx:for="{{particles}}" wx:key="*this" class="cin-dot {{item}}" style="background:#a78bfa;"></view>
    </view>

    <!-- 依次浮现文字 -->
    <view class="cin-texts">
      <text class="cin-line {{cinematicIdx >= 0 ? 'cin-show' : ''}}">{{cinematicTexts[0]}}</text>
      <text class="cin-line {{cinematicIdx >= 1 ? 'cin-show' : ''}}">{{cinematicTexts[1]}}</text>
      <text class="cin-line {{cinematicIdx >= 2 ? 'cin-show' : ''}}">{{cinematicTexts[2]}}</text>
    </view>

    <!-- 跳过 -->
    <view class="cin-skip" bindtap="skipCinematic">
      <text class="cin-skip-text">点击跳过</text>
    </view>
  </view>

</view>
