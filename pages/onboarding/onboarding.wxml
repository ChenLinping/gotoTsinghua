<view class="page-bg" style="padding-top: {{statusBarHeight + 44}}px;">

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar">
      <view wx:if="{{step > 0 && step < 3}}" class="nav-back" bindtap="goBack">
        <text>← 返回</text>
      </view>
      <text class="nav-title">{{step === 0 ? '开始修行' : step === 1 ? '创建角色' : step === 2 ? '灵根鉴定' : '准备就绪'}}</text>
      <view class="nav-spacer" wx:if="{{step > 0 && step < 3}}"></view>
    </view>
  </view>

  <!-- 步骤指示器 -->
  <view class="step-indicator" wx:if="{{step > 0 && step < 3}}">
    <view class="step-dot {{step >= 1 ? 'step-active' : ''}}"></view>
    <view class="step-line {{step >= 2 ? 'line-active' : ''}}"></view>
    <view class="step-dot {{step >= 2 ? 'step-active' : ''}}"></view>
    <view class="step-line {{step >= 3 ? 'line-active' : ''}}"></view>
    <view class="step-dot {{step >= 3 ? 'step-active' : ''}}"></view>
  </view>

  <!-- ========== Step 0: 欢迎页 ========== -->
  <view class="step-content" wx:if="{{step === 0}}">
    <view class="welcome-hero">
      <view class="welcome-trophy">
        <text class="trophy-emoji">🏆</text>
      </view>
      <view class="welcome-glow"></view>
    </view>

    <view class="welcome-text">
      <text class="welcome-title">走向清华</text>
      <text class="welcome-subtitle">修仙之路</text>
    </view>

    <view class="welcome-desc">
      <text class="desc-text">将高考备考变成一段修仙修行的旅程</text>
    </view>

    <view class="feature-list">
      <view class="feature-item">
        <text class="feature-icon">&#127793;</text>
        <view class="feature-info">
          <text class="feature-name">修仙境界</text>
          <text class="feature-desc">从练气期到化神境大圆满</text>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">&#129504;</text>
        <view class="feature-info">
          <text class="feature-name">每日修行</text>
          <text class="feature-desc">答题积累修为，突破境界</text>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">&#128218;</text>
        <view class="feature-info">
          <text class="feature-name">六科修炼</text>
          <text class="feature-desc">数英物化生语全面提升</text>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">&#127942;</text>
        <view class="feature-info">
          <text class="feature-name">圆梦清华</text>
          <text class="feature-desc">高考前一天达成化神大圆满</text>
        </view>
      </view>
    </view>

    <view class="welcome-btn" bindtap="startAdventure">
      <text class="btn-text">开始修行</text>
      <text class="btn-arrow">→</text>
    </view>
  </view>

  <!-- ========== Step 1: 名字输入 ========== -->
  <view class="step-content" wx:if="{{step === 1}}">
    <view class="name-hero">
      <text class="name-hero-emoji">🧙</text>
    </view>

    <view class="name-prompt">
      <text class="prompt-title">你叫什么名字，修仙者？</text>
      <text class="prompt-desc">这个名字将伴随你的修行之路</text>
    </view>

    <view class="name-input-wrap">
      <view class="name-input-border {{nameError ? 'input-error' : ''}}">
        <text class="input-icon">✏️</text>
        <input
          class="name-input"
          placeholder="输入你的名字..."
          placeholder-class="name-placeholder"
          maxlength="8"
          value="{{name}}"
          bindinput="onNameInput"
          bindconfirm="confirmName"
          focus="{{step === 1}}"
        />
      </view>
      <text wx:if="{{nameError}}" class="error-text">{{nameError}}</text>
    </view>

    <view class="name-btn" bindtap="confirmName">
      <text class="btn-text">确认名字</text>
    </view>
  </view>

  <!-- ========== Step 2: 成绩输入 ========== -->
  <view class="step-content" wx:if="{{step === 2}}">
    <view class="score-header">
      <text class="score-header-emoji">🔮</text>
      <text class="score-header-title">灵根鉴定</text>
      <text class="score-header-desc">输入你最近一次考试各科成绩，系统将评估你的初始灵根</text>
    </view>

    <view class="score-list">
      <view
        class="score-item"
        wx:for="{{subjects}}"
        wx:key="key"
        style="border-left: 6rpx solid {{item.color}};"
      >
        <view class="score-left">
          <text class="score-icon">{{item.icon}}</text>
          <view class="score-info">
            <text class="score-name">{{item.name}}</text>
            <text class="score-desc">{{item.desc}}</text>
          </view>
        </view>
        <view class="score-input-wrap">
          <input
            class="score-input"
            type="number"
            placeholder="{{item.placeholder}}"
            placeholder-class="score-placeholder"
            value="{{item.score}}"
            data-idx="{{index}}"
            bindinput="onScoreInput"
          />
          <text class="score-unit">分</text>
        </view>
      </view>
    </view>

    <!-- 总分和等级预览 -->
    <view wx:if="{{totalScore > 0}}" class="score-summary">
      <view class="summary-row">
        <text class="summary-label">总分</text>
        <text class="summary-value">{{totalScore}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">初始境界</text>
        <text class="summary-level">练气初期</text>
      </view>
      <text class="summary-analysis">{{scoreAnalysis}}</text>
    </view>

    <view class="score-btn" bindtap="confirmScores">
      <text class="btn-text">完成鉴定</text>
    </view>
  </view>

  <!-- ========== Step 3: 完成 ========== -->
  <view class="step-content" wx:if="{{step === 3}}">
    <view class="complete-hero">
      <view class="complete-portal">
        <text class="portal-emoji">🌀</text>
      </view>
      <view class="complete-glow"></view>
    </view>

    <view class="complete-text">
      <text class="complete-title">鉴定完成！</text>
      <text class="complete-name">修仙者 {{name}}</text>
    </view>

    <view class="complete-stats">
      <view class="cs-item">
        <text class="cs-label">初始境界</text>
        <text class="cs-value">练气初期</text>
      </view>
      <view class="cs-item">
        <text class="cs-label">总分</text>
        <text class="cs-value">{{totalScore}}</text>
      </view>
      <view class="cs-item">
        <text class="cs-label">目标</text>
        <text class="cs-value">化神大圆满</text>
      </view>
    </view>

    <view class="complete-msg">
      <text>修仙之路已经开启，清华之巅在等待着你！</text>
    </view>

    <view class="complete-btn" bindtap="enterWorld">
      <text class="btn-text">踏入修行之路</text>
      <text class="btn-arrow">&#127793;</text>
    </view>
  </view>

</view>
