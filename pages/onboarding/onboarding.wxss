/* ========== 页面背景 ========== */
.page-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #1e1b4b 0%, #312e81 35%, #3730a3 60%, #1e1b4b 100%);
  position: relative;
  overflow: hidden;
}

/* ========== 自定义导航 ========== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(30, 27, 75, 0.85);
  backdrop-filter: blur(10px);
}

.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 28rpx;
}

.nav-back {
  padding: 8rpx 16rpx;
  margin: -8rpx -16rpx -8rpx 0;
}

.nav-back text {
  font-size: 28rpx;
  color: #a5b4fc;
  font-weight: 600;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #e0e7ff;
}

.nav-spacer {
  width: 80rpx;
}

/* ========== 步骤指示器 ========== */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 16rpx;
}

.step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(99, 102, 241, 0.3);
  border: 3rpx solid rgba(99, 102, 241, 0.4);
}

.step-dot.step-active {
  background: #818cf8;
  border-color: #a5b4fc;
  box-shadow: 0 0 12rpx rgba(129, 140, 248, 0.5);
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: rgba(99, 102, 241, 0.2);
  margin: 0 12rpx;
}

.step-line.line-active {
  background: #818cf8;
}

/* ========== 步骤内容区 ========== */
.step-content {
  padding: 16rpx 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ========== Step 0: 欢迎 ========== */
.welcome-hero {
  position: relative;
  margin: 40rpx 0 20rpx;
}

.welcome-trophy {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(99, 102, 241, 0.2);
  border-radius: 50%;
  border: 4rpx solid rgba(139, 92, 246, 0.4);
  position: relative;
  z-index: 1;
}

.trophy-emoji {
  font-size: 80rpx;
}

.welcome-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.welcome-text {
  text-align: center;
  margin-bottom: 16rpx;
}

.welcome-title {
  display: block;
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 20rpx rgba(139, 92, 246, 0.5);
}

.welcome-subtitle {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #c4b5fd;
  letter-spacing: 12rpx;
  margin-top: 8rpx;
}

.welcome-desc {
  margin-bottom: 36rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #a5b4fc;
}

.feature-list {
  width: 100%;
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: rgba(30, 27, 75, 0.5);
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.2);
}

.feature-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-info {
  display: flex;
  flex-direction: column;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #e0e7ff;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 开始冒险按钮 */
.welcome-btn {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #6366f1);
  border-radius: 20rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(99, 102, 241, 0.4);
  margin-top: 10rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

.btn-arrow {
  font-size: 32rpx;
  margin-left: 12rpx;
  color: rgba(255,255,255,0.7);
}

/* ========== Step 1: 名字输入 ========== */
.name-hero {
  margin: 50rpx 0 24rpx;
}

.name-hero-emoji {
  font-size: 100rpx;
  display: block;
  width: 150rpx;
  height: 150rpx;
  line-height: 150rpx;
  text-align: center;
  background: rgba(99, 102, 241, 0.15);
  border-radius: 50%;
  border: 3rpx solid rgba(139, 92, 246, 0.3);
}

.name-prompt {
  text-align: center;
  margin-bottom: 40rpx;
}

.prompt-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
}

.prompt-desc {
  font-size: 24rpx;
  color: #a5b4fc;
}

.name-input-wrap {
  width: 100%;
  margin-bottom: 36rpx;
}

.name-input-border {
  display: flex;
  align-items: center;
  background: rgba(30, 27, 75, 0.6);
  border: 3rpx solid rgba(99, 102, 241, 0.4);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
}

.name-input-border.input-error {
  border-color: rgba(239, 68, 68, 0.6);
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.name-input {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  height: 50rpx;
}

.name-placeholder {
  color: #64748b;
  font-weight: 400;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #f87171;
  margin-top: 12rpx;
  padding-left: 8rpx;
}

.name-btn {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #6366f1);
  border-radius: 20rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(99, 102, 241, 0.4);
}

/* ========== Step 2: 成绩输入 ========== */
.score-header {
  text-align: center;
  margin-bottom: 28rpx;
}

.score-header-emoji {
  font-size: 56rpx;
  display: block;
  margin-bottom: 10rpx;
}

.score-header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
}

.score-header-desc {
  display: block;
  font-size: 24rpx;
  color: #a5b4fc;
  line-height: 1.5;
}

.score-list {
  width: 100%;
  margin-bottom: 24rpx;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(30, 27, 75, 0.5);
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 14rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.15);
}

.score-left {
  display: flex;
  align-items: center;
}

.score-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
}

.score-info {
  display: flex;
  flex-direction: column;
}

.score-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #e0e7ff;
}

.score-desc {
  font-size: 20rpx;
  color: #94a3b8;
}

.score-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(15, 12, 50, 0.5);
  border-radius: 12rpx;
  padding: 10rpx 16rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.2);
}

.score-input {
  width: 100rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #fbbf24;
  text-align: center;
  height: 44rpx;
}

.score-placeholder {
  color: #475569;
  font-size: 24rpx;
  font-weight: 400;
}

.score-unit {
  font-size: 22rpx;
  color: #64748b;
  margin-left: 4rpx;
}

/* 分数汇总 */
.score-summary {
  width: 100%;
  background: rgba(99, 102, 241, 0.15);
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.3);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #a5b4fc;
  font-weight: 600;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #fbbf24;
}

.summary-level {
  font-size: 36rpx;
  font-weight: 800;
  color: #c084fc;
}

.summary-analysis {
  display: block;
  font-size: 24rpx;
  color: #c4b5fd;
  text-align: center;
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(99, 102, 241, 0.2);
}

.score-btn {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #6366f1);
  border-radius: 20rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(99, 102, 241, 0.4);
}

/* ========== Step 3: 完成 ========== */
.complete-hero {
  position: relative;
  margin: 50rpx 0 24rpx;
}

.complete-portal {
  width: 150rpx;
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(99, 102, 241, 0.2);
  border-radius: 50%;
  border: 4rpx solid rgba(139, 92, 246, 0.5);
  position: relative;
  z-index: 1;
}

.portal-emoji {
  font-size: 72rpx;
}

.complete-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.35) 0%, transparent 70%);
  border-radius: 50%;
}

.complete-text {
  text-align: center;
  margin-bottom: 32rpx;
}

.complete-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
}

.complete-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #c4b5fd;
}

.complete-stats {
  width: 100%;
  display: flex;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.cs-item {
  flex: 1;
  margin: 0 8rpx;
  background: rgba(30, 27, 75, 0.5);
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  border: 2rpx solid rgba(99, 102, 241, 0.2);
}

.cs-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.cs-value {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #fbbf24;
}

.complete-msg {
  text-align: center;
  margin-bottom: 36rpx;
  padding: 20rpx;
  background: rgba(99, 102, 241, 0.1);
  border-radius: 14rpx;
}

.complete-msg text {
  font-size: 26rpx;
  color: #c4b5fd;
  line-height: 1.6;
}

.complete-btn {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #6366f1);
  border-radius: 20rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(99, 102, 241, 0.5);
}

.complete-btn .btn-text {
  font-size: 34rpx;
  letter-spacing: 6rpx;
}

.complete-btn .btn-arrow {
  font-size: 34rpx;
  margin-left: 12rpx;
}
