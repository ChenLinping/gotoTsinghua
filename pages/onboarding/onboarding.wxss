/* ========================================== */
/* 清北修仙传 - 入场流程 */
/* ========================================== */

.page-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0a2e 0%, #1a1145 40%, #2d1b69 70%, #0f0a2e 100%);
  position: relative;
  overflow: hidden;
}

/* ========== 自定义导航 ========== */
.custom-nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(15, 10, 46, 0.9);
}
.nav-bar {
  display: flex; align-items: center;
  height: 44px; padding: 0 14px;
}
.nav-back { padding: 4px 8px 4px 0; }
.nav-back-text { font-size: 14px; color: #a5b4fc; font-weight: 600; }
.nav-title { flex: 1; text-align: center; font-size: 15px; font-weight: 700; color: #e0e7ff; }
.nav-spacer { width: 40px; }

/* ========== 步骤指示器 ========== */
.step-indicator {
  display: flex; align-items: center; justify-content: center;
  padding: 12px 0 8px;
  position: relative; z-index: 1;
}
.step-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: rgba(99, 102, 241, 0.3);
  border: 2px solid rgba(99, 102, 241, 0.4);
  transition: all 0.3s;
}
.step-dot.step-active {
  background: #818cf8; border-color: #a5b4fc;
  box-shadow: 0 0 8px rgba(129, 140, 248, 0.5);
}
.step-line {
  width: 40px; height: 2px;
  background: rgba(99, 102, 241, 0.2);
  margin: 0 6px;
}
.step-line.line-active { background: #818cf8; }

/* ========== 通用按钮 ========== */
.action-btn {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #6366f1);
  border-radius: 14px; padding: 14px 0;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4);
  margin-top: 16px;
}
.action-btn:active { transform: scale(0.97); }
.btn-text { font-size: 16px; font-weight: 800; color: #fff; letter-spacing: 2px; }
.btn-disabled { opacity: 0.4; }

/* ========== 步骤内容区 ========== */
.step-content {
  padding: 16px 20px 40px;
  display: flex; flex-direction: column; align-items: center;
  min-height: 100vh; box-sizing: border-box;
}

/* ========== Step 0: 品牌首页 ========== */
.splash-view {
  justify-content: center; padding: 40px 24px;
  position: relative;
}

.splash-particles { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; }
.sp-dot {
  position: absolute; width: 4px; height: 4px;
  border-radius: 50%; opacity: 0;
  animation: spDrift 5s ease-in-out infinite;
}
.sp-dot.p1 { left: 10%; top: 20%; animation-delay: 0s; }
.sp-dot.p2 { left: 25%; top: 60%; animation-delay: 0.8s; }
.sp-dot.p3 { left: 50%; top: 15%; animation-delay: 1.6s; }
.sp-dot.p4 { left: 75%; top: 45%; animation-delay: 2.4s; }
.sp-dot.p5 { left: 85%; top: 70%; animation-delay: 3.2s; }
.sp-dot.p6 { left: 40%; top: 80%; animation-delay: 4s; }
@keyframes spDrift {
  0% { transform: translateY(0) scale(0); opacity: 0; }
  20% { transform: translateY(-15px) scale(1.5); opacity: 0.8; }
  60% { transform: translateY(-50px) scale(0.8); opacity: 0.4; }
  100% { transform: translateY(-90px) scale(0); opacity: 0; }
}

.splash-glow {
  position: absolute; top: 25%; left: 50%; transform: translateX(-50%);
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.25) 0%, transparent 70%);
  border-radius: 50%; pointer-events: none;
}

.splash-brand {
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 40px; position: relative; z-index: 1;
}
.brand-icon {
  font-size: 64px; margin-bottom: 16px;
  animation: brandPulse 3s ease-in-out infinite;
}
@keyframes brandPulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px rgba(251,191,36,0.3)); }
  50% { transform: scale(1.08); filter: drop-shadow(0 0 25px rgba(251,191,36,0.6)); }
}
.brand-title {
  font-size: 32px; font-weight: 900; color: #fff;
  letter-spacing: 6px;
  text-shadow: 0 2px 20px rgba(139, 92, 246, 0.6);
}
.brand-sub {
  font-size: 14px; font-weight: 600; color: #c4b5fd;
  letter-spacing: 4px; margin-top: 8px;
}

.splash-features {
  width: 100%; margin-bottom: 32px;
  position: relative; z-index: 1;
}
.sf-item {
  display: flex; align-items: center;
  padding: 10px 16px; margin-bottom: 8px;
  background: rgba(139, 92, 246, 0.1);
  border-radius: 10px;
  border: 1px solid rgba(139, 92, 246, 0.15);
}
.sf-icon { font-size: 18px; margin-right: 12px; }
.sf-text { font-size: 13px; color: #c4b5fd; font-weight: 600; }

.splash-btn {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #6366f1);
  border-radius: 14px; padding: 16px 0;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 24px rgba(99, 102, 241, 0.5);
  position: relative; z-index: 1;
}
.splash-btn:active { transform: scale(0.97); }

/* ========== Step 1: 名字输入 ========== */
.name-hero { margin: 20px 0 16px; }
.name-circle {
  width: 80px; height: 80px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(99, 102, 241, 0.15);
  border-radius: 50%;
  border: 2px solid rgba(139, 92, 246, 0.3);
}
.name-emoji { font-size: 40px; }

.name-prompt { text-align: center; margin-bottom: 24px; }
.prompt-title { display: block; font-size: 20px; font-weight: 800; color: #fff; margin-bottom: 6px; }
.prompt-desc { font-size: 12px; color: #a5b4fc; }

.name-input-wrap { width: 100%; margin-bottom: 20px; }
.name-input-border {
  display: flex; align-items: center;
  background: rgba(15, 10, 46, 0.6);
  border: 2px solid rgba(99, 102, 241, 0.4);
  border-radius: 12px; padding: 12px 16px;
}
.name-input-border.input-error { border-color: rgba(239, 68, 68, 0.6); }
.name-input { flex: 1; font-size: 16px; font-weight: 700; color: #fff; height: 28px; }
.name-placeholder { color: #64748b; font-weight: 400; }
.error-text { display: block; font-size: 12px; color: #f87171; margin-top: 6px; padding-left: 4px; }

/* ========== Step 2: 成绩输入 ========== */
.score-view { padding-top: 0; }

.score-header { text-align: center; margin-bottom: 12px; }
.score-header-icon { font-size: 28px; display: block; margin-bottom: 4px; }
.score-header-title { display: block; font-size: 18px; font-weight: 800; color: #fff; margin-bottom: 4px; }
.score-header-desc { display: block; font-size: 11px; color: #a5b4fc; }

.score-list { width: 100%; margin-bottom: 12px; }
.score-item {
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(15, 10, 46, 0.5);
  border-radius: 10px; padding: 10px 12px;
  margin-bottom: 8px;
  border: 1px solid rgba(99, 102, 241, 0.12);
}
.score-left { display: flex; align-items: center; }
.score-icon { font-size: 20px; margin-right: 10px; }
.score-info { display: flex; flex-direction: column; }
.score-name { font-size: 14px; font-weight: 700; color: #e0e7ff; }
.score-max { font-size: 10px; color: #64748b; }

.score-input-wrap {
  display: flex; align-items: center;
  background: rgba(15, 10, 46, 0.6);
  border-radius: 8px; padding: 6px 10px;
  border: 1px solid rgba(99, 102, 241, 0.2);
}
.score-input {
  width: 50px; font-size: 15px; font-weight: 700;
  color: #fbbf24; text-align: center; height: 24px;
}
.score-placeholder { color: #475569; font-size: 12px; }
.score-unit { font-size: 11px; color: #64748b; margin-left: 2px; }

.score-summary {
  width: 100%;
  background: rgba(99, 102, 241, 0.12);
  border-radius: 10px; padding: 10px 14px;
  margin-bottom: 8px;
  border: 1px solid rgba(139, 92, 246, 0.25);
}
.summary-row { display: flex; align-items: center; justify-content: space-between; }
.summary-label { font-size: 13px; color: #a5b4fc; font-weight: 600; }
.summary-value { font-size: 18px; font-weight: 800; color: #fbbf24; }
.summary-value.warn { color: #f87171; }
.warn-text { display: block; font-size: 11px; color: #f87171; margin-top: 6px; text-align: center; }

/* ========== Step 3: 仪式感欢迎 ========== */
.welcome-view { justify-content: center; }

.welcome-portal {
  position: relative; width: 100px; height: 100px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px;
}
.portal-ring {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  border: 2px solid rgba(167, 139, 250, 0.4);
  animation: portalSpin 4s linear infinite;
}
.portal-ring2 {
  position: absolute; top: 10px; left: 10px; right: 10px; bottom: 10px;
  border-radius: 50%;
  border: 2px solid rgba(139, 92, 246, 0.3);
  animation: portalSpin 3s linear infinite reverse;
}
@keyframes portalSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.portal-icon {
  font-size: 40px; position: relative; z-index: 1;
  animation: portalPulse 2s ease-in-out infinite;
}
@keyframes portalPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.welcome-big-title {
  font-size: 26px; font-weight: 900; color: #fbbf24;
  letter-spacing: 4px; margin-bottom: 16px;
  text-shadow: 0 0 15px rgba(251, 191, 36, 0.4);
  animation: titleGlow 2s ease-in-out infinite;
}
@keyframes titleGlow {
  0%, 100% { text-shadow: 0 0 8px rgba(251,191,36,0.3); }
  50% { text-shadow: 0 0 20px rgba(251,191,36,0.7), 0 0 40px rgba(251,191,36,0.3); }
}

.welcome-msg-box {
  width: 100%;
  background: rgba(139, 92, 246, 0.1);
  border-radius: 12px; padding: 16px;
  margin-bottom: 20px;
  border: 1px solid rgba(139, 92, 246, 0.2);
}
.welcome-msg-text {
  font-size: 15px; color: #c4b5fd; line-height: 1.7;
  text-align: center;
}

.welcome-score-row {
  width: 100%;
  display: flex; justify-content: space-between;
  margin-bottom: 20px;
}
.wsr-item {
  flex: 1; margin: 0 4px;
  background: rgba(15, 10, 46, 0.5);
  border-radius: 10px; padding: 12px 6px;
  text-align: center;
  border: 1px solid rgba(99, 102, 241, 0.15);
}
.wsr-val { display: block; font-size: 14px; font-weight: 800; color: #fbbf24; margin-bottom: 4px; }
.wsr-label { display: block; font-size: 10px; color: #94a3b8; }

.cinematic-btn { margin-top: 8px; }

/* ========== Step 4: 开场动画 ========== */
.cinematic-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.cin-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: #0a0520;
  animation: cinBgIn 1s ease-out;
}
@keyframes cinBgIn {
  from { opacity: 0; } to { opacity: 1; }
}

/* Cinematic particles */
.cin-particles { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; }
.cin-dot {
  position: absolute; width: 3px; height: 3px;
  border-radius: 50%; opacity: 0;
  animation: cinFloat 6s ease-in-out infinite;
}
.cin-dot.p1 { left: 15%; top: 30%; animation-delay: 0s; }
.cin-dot.p2 { left: 30%; top: 50%; animation-delay: 1s; }
.cin-dot.p3 { left: 50%; top: 25%; animation-delay: 2s; }
.cin-dot.p4 { left: 70%; top: 55%; animation-delay: 3s; }
.cin-dot.p5 { left: 80%; top: 35%; animation-delay: 4s; }
.cin-dot.p6 { left: 45%; top: 65%; animation-delay: 5s; }
@keyframes cinFloat {
  0% { transform: translateY(0) scale(0); opacity: 0; }
  20% { transform: translateY(-20px) scale(1.5); opacity: 0.7; }
  50% { transform: translateY(-60px) scale(1); opacity: 0.4; }
  100% { transform: translateY(-120px) scale(0); opacity: 0; }
}

/* Cinematic text lines */
.cin-texts {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center;
  gap: 24px;
}
.cin-line {
  font-size: 20px; font-weight: 700; color: #c4b5fd;
  letter-spacing: 3px;
  opacity: 0; transform: translateY(20px);
  transition: all 1s ease-out;
}
.cin-line.cin-show {
  opacity: 1; transform: translateY(0);
}

/* Skip button */
.cin-skip {
  position: absolute; bottom: 40px;
  z-index: 2; padding: 8px 20px;
}
.cin-skip-text { font-size: 12px; color: rgba(255,255,255,0.3); }
