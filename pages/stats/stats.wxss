.overview-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-num { font-size: 52rpx; font-weight: 800; display: block; }
.stat-label { font-size: 22rpx; color: #64748b; display: block; margin-top: 8rpx; }

.progress-row { margin-bottom: 24rpx; }
.progress-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.progress-name { font-size: 28rpx; font-weight: 600; color: #334155; }
.progress-info { font-size: 24rpx; color: #64748b; }
.progress-bar {
  height: 16rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.empty-tip {
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
  padding: 32rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.weekly-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  padding: 20rpx 0;
  min-height: 240rpx;
}
.chart-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.chart-bars { margin-bottom: 8rpx; }
.chart-bar-bg {
  width: 48rpx;
  background: #f1f5f9;
  border-radius: 8rpx 8rpx 0 0;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  min-height: 40rpx;
}
.chart-bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #4f46e5, #7c3aed);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s;
}
.chart-count { font-size: 20rpx; color: #4f46e5; font-weight: 600; margin-bottom: 4rpx; }
.chart-label { font-size: 22rpx; color: #64748b; }

.weekly-summary {
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
  padding: 16rpx 0;
  border-top: 1rpx solid #f1f5f9;
}

.weak-card {
  background: #fef2f2 !important;
  border: 2rpx solid #fecaca;
}
.weak-content { }
.weak-item { margin-bottom: 20rpx; }
.weak-item:last-child { margin-bottom: 0; }
.weak-sub {
  font-size: 28rpx;
  font-weight: 600;
  color: #991b1b;
  display: block;
  margin-bottom: 8rpx;
}
.weak-text {
  font-size: 26rpx;
  color: #7f1d1d;
  line-height: 1.7;
  display: block;
}

.reset-btn {
  text-align: center;
  color: #ef4444;
  font-size: 26rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.title-icon { font-size: 32rpx; margin-right: 12rpx; }
