.rank-card {
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 24rpx;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 28rpx;
  position: relative;
  overflow: hidden;
}
.rank-emoji { font-size: 88rpx; }
.rank-info { flex: 1; }
.rank-name { font-size: 44rpx; font-weight: 800; display: block; margin-bottom: 8rpx; }
.rank-desc { font-size: 26rpx; opacity: 0.9; display: block; margin-bottom: 8rpx; }
.rank-xp { font-size: 24rpx; opacity: 0.75; display: block; }

.levelup-banner {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 800;
  color: #4f46e5;
  animation: fadeIn 0.3s;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.progress-title { font-size: 28rpx; font-weight: 600; color: #334155; }
.progress-pct { font-size: 28rpx; font-weight: 700; color: #4f46e5; }
.xp-bar {
  height: 20rpx;
  background: #f1f5f9;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.xp-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}
.progress-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.xp-remaining { font-size: 24rpx; color: #64748b; }
.xp-rule { font-size: 22rpx; color: #94a3b8; }

.max-rank-msg {
  text-align: center;
  padding: 40rpx;
}
.max-emoji { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.max-text { font-size: 32rpx; font-weight: 700; color: #7c3aed; }

.streak-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.streak-flame { font-size: 56rpx; }
.streak-info { flex: 1; }
.streak-num { font-size: 40rpx; font-weight: 800; color: #f59e0b; display: block; }
.streak-label { font-size: 24rpx; color: #64748b; display: block; }
.streak-bonus { text-align: right; }
.bonus-label { font-size: 22rpx; color: #94a3b8; display: block; }
.bonus-value { font-size: 26rpx; font-weight: 600; color: #10b981; display: block; }

.rank-timeline { }
.rank-step {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  position: relative;
}
.rank-step-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: #f1f5f9;
  border: 2rpx solid #e2e8f0;
  flex-shrink: 0;
}
.rank-step-info { flex: 1; }
.rank-step-name { font-size: 28rpx; color: #334155; display: block; }
.rank-step-xp { font-size: 22rpx; color: #94a3b8; display: block; }
.current-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: #4f46e5;
  color: #fff;
  font-weight: 600;
}
.rank-step.locked .rank-step-icon { opacity: 0.5; }
.rank-step.locked .rank-step-name { color: #94a3b8; }

.achievement-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.achievement-item {
  text-align: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}
.achievement-item.earned {
  background: #fef3c7;
}
.achievement-item.locked {
  opacity: 0.5;
}
.achievement-icon { font-size: 40rpx; display: block; margin-bottom: 8rpx; }
.achievement-name { font-size: 22rpx; font-weight: 600; color: #334155; display: block; margin-bottom: 4rpx; }
.achievement-desc { font-size: 20rpx; color: #64748b; display: block; }

.subject-row { margin-bottom: 20rpx; }
.subject-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}
.subject-bar {
  height: 14rpx;
  background: #f1f5f9;
  border-radius: 7rpx;
  overflow: hidden;
}
.subject-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.5s ease;
}

.xp-guide { background: #fffbeb !important; }
.xp-rules { }
.xp-rule-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.xp-rule-item:last-child { border-bottom: none; }
.xp-rule-item.highlight { }
.xp-rule-label { font-size: 26rpx; color: #475569; }
.xp-rule-value { font-size: 26rpx; font-weight: 700; color: #f59e0b; }

.title-icon { font-size: 32rpx; margin-right: 12rpx; }
.card-title { font-size: 30rpx; font-weight: 700; color: #1e293b; margin-bottom: 20rpx; display: flex; align-items: center; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
