<view class="page-bg">

  <!-- 顶部统计 -->
  <view class="stat-bar">
    <text class="stat-title">宝库</text>
    <view class="stat-items">
      <view class="stat-item">
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-label">总题数</text>
      </view>
      <view class="stat-item">
        <text class="stat-num stat-ok">{{stats.correct}}</text>
        <text class="stat-label">答对</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.rate}}%</text>
        <text class="stat-label">正确率</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'tab-active' : ''}}" data-idx="0" bindtap="switchTab">
      <text>按日期</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'tab-active' : ''}}" data-idx="1" bindtap="switchTab">
      <text>按科目</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{empty}}">
    <text class="empty-icon">?</text>
    <text class="empty-text">还没有答题记录</text>
    <text class="empty-hint">去地图上炼宝答题吧！</text>
  </view>

  <!-- 题目列表 -->
  <scroll-view scroll-y class="history-list" wx:if="{{!empty}}">
    <view wx:for="{{groups}}" wx:key="title" class="group">
      <view class="group-header">
        <text class="group-title">{{item.title}}</text>
        <text class="group-sub">{{item.subtitle}}</text>
      </view>

      <view wx:for="{{item.items}}" wx:for-item="q" wx:key="q" class="q-card {{q.correct ? 'q-ok' : 'q-no'}}">
        <view class="q-top">
          <text class="q-badge {{q.correct ? 'badge-ok' : 'badge-no'}}">{{q.correct ? '对' : '错'}}</text>
          <text class="q-subject">{{q.subject === 'math' ? '数学' : q.subject === 'chinese' ? '语文' : q.subject === 'english' ? '英语' : q.subject === 'physics' ? '物理' : q.subject === 'chemistry' ? '化学' : q.subject === 'biology' ? '生物' : '综合'}}</text>
        </view>
        <text class="q-text">{{q.q}}</text>
        <view class="q-options">
          <view wx:for="{{q.options}}" wx:for-item="opt" wx:for-index="oi" wx:key="oi"
            class="q-opt {{oi === q.answer ? 'opt-right' : ''}}">
            <text class="q-opt-label">{{oi === 0 ? 'A' : oi === 1 ? 'B' : oi === 2 ? 'C' : 'D'}}</text>
            <text class="q-opt-text">{{opt}}</text>
          </view>
        </view>
        <view class="q-explain" wx:if="{{q.explain}}">
          <text class="q-explain-text">{{q.explain}}</text>
        </view>
      </view>
    </view>

    <view style="height: 60px;"></view>
  </scroll-view>

</view>
