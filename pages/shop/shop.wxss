/* ========== 宝库 - 答题历史 ========== */
page {
  overflow-x: hidden;
}

.page-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #1a1145 40%, #0f0c29 100%);
  display: flex; flex-direction: column;
  overflow-x: hidden;
  width: 100%;
  box-sizing: border-box;
}

/* 统计栏 */
.stat-bar {
  padding: 16px 20px 12px;
  background: rgba(255,255,255,0.04);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.stat-title {
  display: block; font-size: 20px; font-weight: 900;
  color: #c4b5fd; margin-bottom: 10px;
}
.stat-items { display: flex; gap: 16px; flex-wrap: wrap; overflow: hidden; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 22px; font-weight: 800; color: #e2e8f0; }
.stat-ok { color: #4ade80; }
.stat-no { color: #f87171; }
.stat-label { font-size: 10px; color: #64748b; margin-top: 2px; }

/* Tab */
.tab-bar {
  display: flex; padding: 8px 16px;
  background: rgba(0,0,0,0.2);
  border-bottom: 1px solid rgba(255,255,255,0.05);
  gap: 8px;
}
.tab-item {
  flex: 1; text-align: center; padding: 8px 0;
  border-radius: 8px; font-size: 13px; font-weight: 600;
  color: #64748b; background: rgba(255,255,255,0.04);
  transition: all 0.2s;
}
.tab-active {
  background: rgba(139,92,246,0.2);
  color: #c4b5fd;
  border: 1px solid rgba(139,92,246,0.3);
}

/* 筛选栏: 全部 / 错题 */
.filter-bar {
  display: flex; padding: 6px 16px;
  background: rgba(0,0,0,0.15);
  gap: 12px;
}
.filter-item {
  padding: 5px 16px; border-radius: 14px;
  font-size: 12px; font-weight: 600;
  color: #64748b; background: rgba(255,255,255,0.04);
  transition: all 0.2s;
}
.filter-active {
  background: rgba(239,68,68,0.15);
  color: #fca5a5;
  border: 1px solid rgba(239,68,68,0.25);
}

/* 空状态 */
.empty-state {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 60px 20px;
}
.empty-icon { font-size: 48px; color: #334155; margin-bottom: 12px; font-weight: 900; }
.empty-text { font-size: 16px; color: #475569; font-weight: 600; margin-bottom: 6px; }
.empty-hint { font-size: 12px; color: #334155; }

/* 列表 */
.history-list { flex: 1; padding: 12px 14px; height: 0; }

/* 分组 */
.group { margin-bottom: 16px; }
.group-header {
  display: flex; align-items: baseline; justify-content: space-between;
  padding: 6px 4px 8px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  margin-bottom: 8px;
}
.group-title { font-size: 14px; font-weight: 700; color: #a78bfa; }
.group-sub { font-size: 11px; color: #64748b; }

/* 题目卡片 */
.q-card {
  background: rgba(255,255,255,0.04);
  border-radius: 10px; padding: 12px 14px;
  margin-bottom: 8px;
  border-left: 3px solid #475569;
}
.q-ok { border-left-color: #22c55e; }
.q-no { border-left-color: #ef4444; }

.q-top { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.q-badge {
  font-size: 10px; font-weight: 700; color: #fff;
  padding: 2px 8px; border-radius: 4px;
}
.badge-ok { background: #22c55e; }
.badge-no { background: #ef4444; }
.q-subject { font-size: 10px; color: #94a3b8; font-weight: 500; }

.q-text { font-size: 13px; color: #e2e8f0; line-height: 1.6; display: block; margin-bottom: 8px; }

/* 选项 */
.q-options { display: flex; flex-direction: column; gap: 4px; margin-bottom: 6px; }
.q-opt {
  display: flex; align-items: center; gap: 6px;
  padding: 4px 8px; border-radius: 6px;
  background: rgba(255,255,255,0.02);
}
.opt-right { background: rgba(34,197,94,0.1); }
.q-opt-label {
  width: 18px; height: 18px; display: flex;
  align-items: center; justify-content: center;
  background: rgba(139,92,246,0.15); border-radius: 4px;
  font-size: 10px; font-weight: bold; color: #a78bfa; flex-shrink: 0;
}
.opt-right .q-opt-label { background: rgba(34,197,94,0.2); color: #4ade80; }
.q-opt-text { font-size: 12px; color: #94a3b8; line-height: 1.4; }
.opt-right .q-opt-text { color: #bbf7d0; }

/* 解析 */
.q-explain {
  background: rgba(255,255,255,0.03); border-radius: 6px;
  padding: 6px 8px; border: 1px solid rgba(255,255,255,0.04);
}
.q-explain-text { font-size: 11px; color: #64748b; line-height: 1.5; }
