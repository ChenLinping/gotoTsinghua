/* ========== 页面背景 ========== */
.page-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #1c1917 0%, #292524 40%, #1c1917 100%);
  display: flex;
  flex-direction: column;
}

/* ========== 金币栏 ========== */
.coin-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.15) 0%, rgba(217, 119, 6, 0.1) 100%);
  border-bottom: 2rpx solid rgba(245, 158, 11, 0.2);
}

.coin-info {
  display: flex;
  align-items: center;
  margin-right: 10rpx;
}

.coin-icon {
  font-size: 36rpx;
  margin-right: 6rpx;
}

.coin-label {
  font-size: 24rpx;
  color: #d97706;
  font-weight: 600;
}

.coin-amount {
  font-size: 40rpx;
  font-weight: 800;
  color: #fbbf24;
  text-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
  margin-right: 20rpx;
}

.shop-title-wrap {
  flex: 1;
  text-align: right;
}

.shop-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fcd34d;
  letter-spacing: 2rpx;
}

/* ========== Tab 栏 ========== */
.tab-bar {
  display: flex;
  padding: 16rpx 28rpx;
  background: rgba(28, 25, 23, 0.8);
  border-bottom: 2rpx solid rgba(120, 113, 108, 0.2);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 14rpx;
  margin: 0 6rpx;
  background: rgba(68, 64, 60, 0.4);
  transition: all 0.3s ease;
}

.tab-item.tab-active {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.25) 0%, rgba(217, 119, 6, 0.2) 100%);
  border: 2rpx solid rgba(245, 158, 11, 0.4);
}

.tab-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.tab-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #a8a29e;
}

.tab-active .tab-text {
  color: #fbbf24;
}

/* ========== 商品列表 ========== */
.item-list {
  flex: 1;
  padding: 20rpx 24rpx;
  height: 0;
}

.item-card {
  background: rgba(41, 37, 36, 0.7);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid rgba(120, 113, 108, 0.15);
  backdrop-filter: blur(10px);
}

.item-card.item-locked {
  opacity: 0.5;
}

.item-card.item-equipped {
  background: rgba(99, 102, 241, 0.1);
  border-color: rgba(99, 102, 241, 0.3);
}

.item-main {
  display: flex;
  align-items: center;
}

/* 左侧：图标 */
.item-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 90rpx;
}

.item-emoji {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.locked-emoji {
  font-size: 44rpx;
  opacity: 0.5;
}

.item-rarity {
  font-size: 18rpx;
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* 中间：信息 */
.item-center {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #e7e5e4;
  display: block;
  margin-bottom: 4rpx;
}

.locked-name {
  color: #78716c;
}

.item-stat {
  font-size: 24rpx;
  font-weight: 600;
  color: #fbbf24;
  display: block;
  margin-bottom: 4rpx;
}

.item-desc {
  font-size: 22rpx;
  color: #a8a29e;
  display: block;
}

.locked-desc {
  color: #57534e;
}

.lock-info {
  margin-bottom: 4rpx;
}

.lock-text {
  font-size: 22rpx;
  color: #78716c;
  font-weight: 500;
}

/* 右侧：操作 */
.item-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  min-width: 110rpx;
}

.lock-badge {
  font-size: 20rpx;
  color: #78716c;
  background: rgba(120, 113, 108, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 价格标签 */
.price-tag {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.price-tag.no-afford {
  opacity: 0.5;
}

.price-icon {
  font-size: 22rpx;
  margin-right: 4rpx;
}

.price-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #fbbf24;
}

.no-afford .price-num {
  color: #ef4444;
}

/* 购买按钮 */
.btn-buy {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border-radius: 12rpx;
  padding: 10rpx 28rpx;
  text-align: center;
}

.btn-buy text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.btn-buy.btn-disabled {
  background: rgba(120, 113, 108, 0.3);
}

.btn-buy.btn-disabled text {
  color: #78716c;
}

/* 装备按钮 */
.btn-equip {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  border-radius: 12rpx;
  padding: 10rpx 28rpx;
  text-align: center;
}

.btn-equip text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

/* 已装备标记 */
.equipped-badge {
  background: rgba(99, 102, 241, 0.2);
  border: 2rpx solid rgba(99, 102, 241, 0.5);
  border-radius: 12rpx;
  padding: 6rpx 20rpx;
  margin-bottom: 8rpx;
}

.equipped-badge text {
  font-size: 22rpx;
  font-weight: 700;
  color: #a5b4fc;
}

.btn-unequip {
  background: rgba(120, 113, 108, 0.3);
  border-radius: 10rpx;
  padding: 6rpx 20rpx;
  text-align: center;
}

.btn-unequip text {
  font-size: 20rpx;
  font-weight: 600;
  color: #a8a29e;
}
