/* ===== 全屏大地图 ===== */
.page {
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: #2d1b00;
}

.world-map {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
}

/* 区域背景 */
.world-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 100%;
  min-height: 900rpx;
}

.mc-bg-1 { background: linear-gradient(180deg, #87ceeb 0%, #87ceeb 12%, #5b8c3e 12%, #5b8c3e 20%, #4a7a30 20%, #4a7a30 100%); }
.mc-bg-2 { background: linear-gradient(180deg, #6b8e6b 0%, #6b8e6b 12%, #3d6b28 12%, #3d6b28 20%, #2d5a1a 20%, #2d5a1a 100%); }
.mc-bg-3 { background: linear-gradient(180deg, #b0c4de 0%, #b0c4de 12%, #8fa4b8 12%, #8fa4b8 20%, #7a90a4 20%, #7a90a4 100%); }
.mc-bg-4 { background: linear-gradient(180deg, #cd853f 0%, #cd853f 12%, #b8732e 12%, #b8732e 20%, #a0621e 20%, #a0621e 100%); }
.mc-bg-5 { background: linear-gradient(180deg, #9370db 0%, #9370db 12%, #7b5cb8 12%, #7b5cb8 20%, #6a4ca6 20%, #6a4ca6 100%); }

/* 装饰元素 */
.world-deco {
  position: absolute;
  z-index: 1;
  pointer-events: none;
}

.deco-cloud {
  font-size: 52rpx;
  opacity: 0.7;
  animation: cloud-float 18s linear infinite;
}

.deco-tree {
  font-size: 44rpx;
  filter: drop-shadow(2rpx 4rpx 0 rgba(0,0,0,0.3));
}

@keyframes cloud-float {
  0% { transform: translateX(0); }
  100% { transform: translateX(120rpx); }
}

/* 像素地面 */
.world-ground {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  min-height: 900rpx;
  display: flex;
  flex-direction: column;
  opacity: 0.04;
  pointer-events: none;
  z-index: 0;
}

.ground-row { display: flex; flex: 1; }
.ground-cell { flex: 1; border: 1rpx solid rgba(0,0,0,0.2); }
.gc-0 { background: #5b8c3e; }
.gc-1 { background: #4a7a30; }
.gc-2 { background: #6b9c4e; }

/* ===== 路径连线 ===== */
.path-line {
  position: absolute;
  z-index: 2;
  pointer-events: none;
}

.path-inner {
  width: 100%;
  height: 6rpx;
  background: rgba(255,255,255,0.12);
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  border: 2rpx solid rgba(0,0,0,0.1);
}

.path-on {
  background: #5b8c3e;
  border-color: #3d6b28;
  height: 8rpx;
  box-shadow: 0 0 10rpx rgba(91,140,62,0.4);
}

/* ===== 怪物节点 ===== */
.mob {
  position: absolute;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translate(-50%, -50%);
  transition: transform 0.15s;
}

.mob:active { transform: translate(-50%, -50%) scale(0.85); }

/* 怪物身体 */
.mob-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.mob-head {
  width: 72rpx;
  height: 72rpx;
  background: #8b6b4a;
  border: 4rpx solid #6b4a2a;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 3;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.25);
}

.mob-face { font-size: 36rpx; }

.mob-feet {
  display: flex;
  gap: 6rpx;
  margin-top: -2rpx;
  z-index: 2;
}

.mob-foot {
  width: 24rpx;
  height: 16rpx;
  background: #6b4a2a;
  border: 3rpx solid #4a2a0a;
  border-radius: 0 0 4rpx 4rpx;
}

/* 已完成 - 钻石色 */
.mob-dead .mob-head {
  background: #4ad8d8;
  border-color: #2a9898;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.2);
}
.mob-dead .mob-face {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.3);
}
.mob-dead .mob-foot { background: #2a9898; border-color: #1a7878; }

/* 锁定 - 灰色石头 */
.mob-locked .mob-head {
  background: #999;
  border-color: #777;
}
.mob-locked .mob-face { opacity: 0.5; font-size: 28rpx; }
.mob-locked .mob-foot { background: #777; border-color: #555; }
.mob-locked { pointer-events: none; }

/* Boss - TNT红 */
.mob-boss .mob-head {
  width: 88rpx;
  height: 88rpx;
  background: #ee3333;
  border-color: #aa1111;
  border-width: 5rpx;
}
.mob-boss .mob-face { font-size: 44rpx; }
.mob-boss .mob-foot { width: 28rpx; height: 18rpx; background: #aa1111; border-color: #881111; }

/* 精英 - 金色 */
.mob-elite .mob-head {
  width: 80rpx;
  height: 80rpx;
  background: #e8c200;
  border-color: #a08600;
}
.mob-elite .mob-face { font-size: 38rpx; }
.mob-elite .mob-foot { background: #a08600; border-color: #806800; }

/* 怪物光环 */
.mob-glow {
  position: absolute;
  top: 50%; left: 50%;
  width: 110rpx; height: 110rpx;
  margin-left: -55rpx; margin-top: -55rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(239,68,68,0.25) 0%, transparent 70%);
  animation: glow-pulse 2s ease-in-out infinite;
  z-index: 0;
  pointer-events: none;
}

.mob-boss .mob-glow {
  width: 140rpx; height: 140rpx;
  margin-left: -70rpx; margin-top: -70rpx;
  background: radial-gradient(circle, rgba(239,68,68,0.35) 0%, transparent 70%);
}

.mob-elite .mob-glow {
  background: radial-gradient(circle, rgba(255,215,0,0.25) 0%, transparent 70%);
}

@keyframes glow-pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* 怪物标签 */
.mob-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 4rpx;
}

.mob-name {
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(0,0,0,0.55);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  white-space: nowrap;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.5);
}

.mob-dead .mob-name { color: #4ad8d8; background: rgba(0,0,0,0.4); }
.mob-locked .mob-name { color: #999; background: rgba(0,0,0,0.3); }

.mob-type {
  font-size: 14rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  margin-top: 2rpx;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.5);
}

.mob-type-boss { color: #ff4444; }
.mob-type-elite { color: #ffd700; }

/* ===== 玩家角色 ===== */
.player {
  position: absolute;
  z-index: 20;
  transform: translate(-50%, -50%);
  animation: player-idle 1.5s ease-in-out infinite;
}

@keyframes player-idle {
  0%, 100% { transform: translate(-50%, -50%) translateY(0); }
  50% { transform: translate(-50%, -50%) translateY(-6rpx); }
}

.steve {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.steve-head-wrap { position: relative; z-index: 3; }

.steve-head {
  width: 40rpx;
  height: 40rpx;
  background: #c8a87a;
  border: 3rpx solid #8b6b4a;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.steve-face { font-size: 24rpx; }

.steve-body-wrap {
  display: flex;
  align-items: stretch;
  height: 32rpx;
  position: relative;
  z-index: 2;
}

.steve-arm {
  width: 12rpx;
  background: #5b8c3e;
  border: 2rpx solid #3d6b28;
}

.steve-arm-l { border-radius: 3rpx 0 0 3rpx; }
.steve-arm-r { border-radius: 0 3rpx 3rpx 0; }

.steve-torso {
  width: 28rpx;
  background: #3b82f6;
  border: 2rpx solid #2563eb;
}

.steve-legs-wrap {
  display: flex;
  height: 24rpx;
  position: relative;
  z-index: 1;
}

.steve-leg {
  width: 18rpx;
  background: #4a4a8a;
  border: 2rpx solid #333366;
  border-radius: 0 0 3rpx 3rpx;
}

/* 玩家脚下指示器 */
.player-indicator {
  width: 40rpx;
  height: 12rpx;
  background: rgba(91,140,62,0.4);
  border-radius: 50%;
  margin-top: 2rpx;
  animation: indicator-pulse 2s ease-in-out infinite;
}

@keyframes indicator-pulse {
  0%, 100% { opacity: 0.4; transform: scaleX(1); }
  50% { opacity: 0.8; transform: scaleX(1.3); }
}

/* ===== 区域标题浮层 ===== */
.region-pill {
  position: fixed;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0,0,0,0.6);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  border: 3rpx solid rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
}

.region-pill-icon { font-size: 28rpx; }

.region-pill-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.5);
}

.region-pill-arrow {
  font-size: 16rpx;
  color: rgba(255,255,255,0.6);
  margin-left: 4rpx;
}

.region-pill-progress {
  position: absolute;
  bottom: -2rpx;
  left: 20rpx;
  right: 20rpx;
  height: 4rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 2rpx;
  overflow: hidden;
}

.region-pill-fill {
  height: 100%;
  background: #5b8c3e;
  border-radius: 2rpx;
  transition: width 0.5s ease;
}

/* 区域下拉菜单 */
.region-dropdown {
  position: fixed;
  top: 76rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 101;
  background: rgba(0,0,0,0.8);
  border-radius: 12rpx;
  border: 3rpx solid rgba(255,255,255,0.1);
  padding: 8rpx;
  backdrop-filter: blur(12px);
  min-width: 300rpx;
  animation: dropdown-in 0.2s ease;
}

@keyframes dropdown-in {
  from { opacity: 0; transform: translateX(-50%) translateY(-10rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.dropdown-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  border-radius: 8rpx;
  transition: background 0.15s;
}

.dropdown-item:active { background: rgba(255,255,255,0.1); }
.dropdown-active { background: rgba(91,140,62,0.3); }
.dropdown-locked { opacity: 0.45; }

.dropdown-icon { font-size: 28rpx; }
.dropdown-name { font-size: 24rpx; color: #fff; font-weight: 600; flex: 1; }
.dropdown-lv { font-size: 18rpx; color: #999; }

/* ===== HUD 面板 ===== */
.hud {
  position: fixed;
  left: 20rpx;
  bottom: 40rpx;
  z-index: 100;
  transition: all 0.3s ease;
}

/* 收起态 */
.hud-mini {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0,0,0,0.6);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255,255,255,0.2);
  backdrop-filter: blur(8px);
  gap: 4rpx;
}

.hud-mini-lv {
  font-size: 28rpx;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.5);
  line-height: 1;
}

.hud-mini-hp {
  width: 48rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 4rpx;
  overflow: hidden;
}

.hud-mini-hp-fill {
  height: 100%;
  background: #4ade80;
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 展开态 */
.hud-full {
  width: 340rpx;
  background: rgba(0,0,0,0.7);
  border-radius: 16rpx;
  padding: 18rpx;
  border: 3rpx solid rgba(255,255,255,0.12);
  backdrop-filter: blur(12px);
  animation: hud-slide-in 0.3s ease;
}

@keyframes hud-slide-in {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.hud-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.hud-lv-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255,255,255,0.3);
}

.hud-lv-text {
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.4);
}

.hud-info { flex: 1; }

.hud-rank {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

.hud-bar-wrap {
  position: relative;
  margin-bottom: 8rpx;
}

.hud-bar {
  height: 18rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 4rpx;
  overflow: hidden;
  border: 2rpx solid rgba(0,0,0,0.3);
}

.hud-bar-fill {
  height: 100%;
  border-radius: 2rpx;
  transition: width 0.5s ease;
}

.hud-xp-fill { background: linear-gradient(180deg, #ffd700, #b8860b); }
.hud-hp-fill { background: linear-gradient(180deg, #ff4444, #cc0000); }

.hud-bar-label {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14rpx;
  color: #fff;
  font-weight: 700;
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.6);
}

.hud-stats {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.hud-stat {
  font-size: 18rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.08);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
}

/* ===== 每日宝箱 ===== */
.chest-btn {
  position: fixed;
  right: 24rpx;
  top: 50%;
  z-index: 100;
  background: linear-gradient(180deg, #c6a03e, #8b6914);
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 0 rgba(0,0,0,0.3);
  border: 4rpx solid #d4a017;
  animation: chest-bounce 2s ease-in-out infinite;
}

@keyframes chest-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.chest-icon { font-size: 44rpx; }

.chest-glow {
  position: absolute;
  top: -10rpx; left: -10rpx; right: -10rpx; bottom: -10rpx;
  border-radius: 12rpx;
  background: radial-gradient(circle, rgba(255,215,0,0.3) 0%, transparent 70%);
  animation: chest-glow-pulse 1.5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes chest-glow-pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}

/* ===== 武器掉落动画 ===== */
.drop-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drop-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  animation: fade-in 0.3s ease;
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.drop-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: drop-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes drop-in {
  from { transform: translateY(80rpx) scale(0.8); opacity: 0; }
  to { transform: translateY(0) scale(1); opacity: 1; }
}

.drop-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 4rpx 4rpx 0 rgba(0,0,0,0.5);
  letter-spacing: 4rpx;
}

.drop-region {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin: 8rpx 0 36rpx;
}

.drop-box {
  position: relative;
  width: 360rpx;
  padding: 36rpx;
  background: linear-gradient(180deg, #4a3728, #3a2a1a);
  border: 6rpx solid #8b6b4a;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 0 rgba(0,0,0,0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.drop-glow {
  position: absolute;
  top: -20rpx; left: -20rpx; right: -20rpx; bottom: -20rpx;
  border-radius: 12rpx;
  background: radial-gradient(circle, rgba(255,215,0,0.2) 0%, transparent 70%);
  animation: weapon-glow 2s ease-in-out infinite;
  pointer-events: none;
}

@keyframes weapon-glow {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
}

.drop-emoji {
  font-size: 90rpx;
  animation: weapon-bounce 1s ease-in-out infinite;
  filter: drop-shadow(0 4rpx 8rpx rgba(255,215,0,0.5));
}

@keyframes weapon-bounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-16rpx) rotate(5deg); }
}

.drop-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #ffd700;
  margin-top: 14rpx;
  letter-spacing: 4rpx;
  text-shadow: 3rpx 3rpx 0 rgba(0,0,0,0.5);
}

.drop-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 6rpx;
}

.drop-stat {
  font-size: 26rpx;
  font-weight: 800;
  color: #ff6b6b;
  margin-top: 10rpx;
  background: rgba(255,0,0,0.1);
  padding: 4rpx 18rpx;
  border-radius: 6rpx;
  border: 2rpx solid rgba(255,100,100,0.3);
}

.drop-btn {
  margin-top: 36rpx;
  padding: 18rpx 50rpx;
  background: linear-gradient(180deg, #5b8c3e, #3d6b28);
  border: 5rpx solid #7ab356;
  border-radius: 6rpx;
  box-shadow: 0 6rpx 0 rgba(0,0,0,0.3);
}

.drop-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 rgba(0,0,0,0.3);
}

.drop-btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.4);
}

/* ===== 战斗转场 ===== */
.battle-transition {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.bt-flash {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #fff;
  opacity: 0;
}

.bt-active .bt-flash {
  animation: bt-flash-anim 0.8s ease-out;
}

@keyframes bt-flash-anim {
  0% { opacity: 0; }
  15% { opacity: 0.9; }
  40% { opacity: 0.3; }
  100% { opacity: 0; }
}

.bt-text {
  position: relative;
  z-index: 2;
  font-size: 40rpx;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 4rpx 4rpx 0 rgba(0,0,0,0.6);
  letter-spacing: 6rpx;
  opacity: 0;
}

.bt-active .bt-text {
  animation: bt-text-anim 0.8s ease-out;
}

@keyframes bt-text-anim {
  0% { opacity: 0; transform: scale(0.5); }
  20% { opacity: 1; transform: scale(1.2); }
  50% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(1.5); }
}
