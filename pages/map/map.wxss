/* ===== Page ===== */
.page {
  min-height: 100vh;
  background: #f0f4f8;
  padding-bottom: 160rpx;
  position: relative;
  overflow-x: hidden;
}

/* ===== Hero Bar ===== */
.hero-bar {
  position: relative;
  padding: 30rpx 24rpx 24rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

/* Hero Left: Level & Rank */
.hero-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
}

.level-badge {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.25), inset 0 -4rpx 8rpx rgba(0,0,0,0.15);
  border: 4rpx solid rgba(255,255,255,0.5);
}

.level-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.rank-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10rpx;
}

.rank-emoji {
  font-size: 36rpx;
}

.rank-name {
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  margin-top: 2rpx;
}

/* Hero Center: XP & HP Bars */
.hero-center {
  flex: 1;
  margin: 10rpx 20rpx 0;
}

.xp-bar-wrap,
.hp-bar-wrap {
  height: 36rpx;
  background: rgba(0,0,0,0.25);
  border-radius: 18rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 12rpx;
  border: 2rpx solid rgba(255,255,255,0.15);
}

.xp-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd700, #ffaa00);
  border-radius: 18rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: inset 0 2rpx 4rpx rgba(255,255,255,0.4);
}

.hp-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4caf50, #81c784);
  border-radius: 18rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: inset 0 2rpx 4rpx rgba(255,255,255,0.4);
}

.xp-bar-text,
.hp-bar-text {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.4);
}

/* Hero Right: Stats */
.hero-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.18);
  border-radius: 30rpx;
  padding: 6rpx 16rpx;
  backdrop-filter: blur(4px);
}

.stat-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.stat-val {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.2);
}

/* ===== Daily Chest ===== */
.chest-btn {
  position: fixed;
  right: 24rpx;
  top: 260rpx;
  z-index: 100;
  background: linear-gradient(135deg, #ff9800, #f57c00);
  border-radius: 24rpx;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(255,152,0,0.45);
  border: 3rpx solid rgba(255,255,255,0.4);
  animation: chest-bounce 2s ease-in-out infinite;
}

.chest-hidden {
  display: none;
}

.chest-icon {
  font-size: 48rpx;
}

.chest-label {
  font-size: 18rpx;
  color: #fff;
  font-weight: bold;
  margin-top: 4rpx;
}

.chest-glow {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  border-radius: 30rpx;
  background: radial-gradient(circle, rgba(255,215,0,0.3) 0%, transparent 70%);
  animation: chest-glow-pulse 1.5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes chest-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes chest-glow-pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}

/* ===== Region Tabs ===== */
.region-tabs {
  white-space: nowrap;
  padding: 20rpx 0 10rpx;
  background: transparent;
}

.region-tabs-inner {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 16rpx;
}

.region-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 140rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.region-tab-active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: rgba(255,255,255,0.5);
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.4);
  transform: translateY(-4rpx);
}

.region-tab-locked {
  opacity: 0.55;
}

.region-tab-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.region-tab-active .region-tab-icon,
.region-tab-active .region-tab-name {
  filter: none;
}

.region-tab-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #333;
}

.region-tab-active .region-tab-name {
  color: #fff;
}

.region-tab-lock {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 4rpx;
}

.lock-icon {
  font-size: 20rpx;
}

.lock-level {
  font-size: 16rpx;
  color: #999;
}

.region-tab-indicator {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 8rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 4rpx;
}

/* ===== Map Area ===== */
.map-area {
  margin: 16rpx 20rpx;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
  min-height: 700rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  border: 3rpx solid rgba(255,255,255,0.8);
}

.map-bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.map-header {
  position: relative;
  z-index: 2;
  padding: 30rpx 30rpx 10rpx;
  text-align: center;
}

.map-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2d3436;
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(255,255,255,0.5);
}

.map-desc {
  font-size: 22rpx;
  color: #636e72;
  display: block;
  margin-top: 6rpx;
}

/* ===== Map Canvas ===== */
.map-canvas {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 600rpx;
  margin: 20rpx 0;
}

/* ===== Path Lines ===== */
.path-line {
  position: absolute;
  z-index: 1;
  pointer-events: none;
}

.path-line-inner {
  width: 100%;
  height: 4rpx;
  background: rgba(0,0,0,0.12);
  border-radius: 2rpx;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
}

.path-line-inner.path-active {
  background: linear-gradient(90deg, #4caf50, #81c784);
  height: 6rpx;
  box-shadow: 0 0 12rpx rgba(76,175,80,0.4);
}

/* ===== Map Nodes ===== */
.map-node {
  position: absolute;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translate(-50%, -50%);
  transition: transform 0.2s ease;
}

.map-node:active {
  transform: translate(-50%, -50%) scale(0.9);
}

/* Node sizes */
.node-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 3;
  transition: all 0.3s ease;
}

.node-elite .node-inner {
  width: 96rpx;
  height: 96rpx;
}

.node-boss .node-inner {
  width: 116rpx;
  height: 116rpx;
}

/* ===== Node States ===== */

/* Completed */
.node-completed .node-inner {
  background: linear-gradient(135deg, #43a047, #66bb6a);
  box-shadow: 0 6rpx 20rpx rgba(67,160,71,0.35), inset 0 2rpx 6rpx rgba(255,255,255,0.3);
  border: 4rpx solid rgba(255,255,255,0.5);
}

.node-completed .node-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
}

/* Available */
.node-available .node-inner {
  background: linear-gradient(135deg, #1e88e5, #42a5f5);
  box-shadow: 0 6rpx 20rpx rgba(30,136,229,0.4), inset 0 2rpx 6rpx rgba(255,255,255,0.3);
  border: 4rpx solid rgba(255,255,255,0.6);
}

.node-available .node-icon {
  font-size: 30rpx;
}

/* Locked */
.node-locked .node-inner {
  background: linear-gradient(135deg, #bdbdbd, #9e9e9e);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1), inset 0 2rpx 6rpx rgba(255,255,255,0.2);
  border: 4rpx solid rgba(255,255,255,0.3);
}

.node-locked .node-icon {
  font-size: 24rpx;
  opacity: 0.6;
}

.node-locked {
  pointer-events: none;
}

/* ===== Boss Ring ===== */
.node-boss-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 148rpx;
  height: 148rpx;
  margin-left: -74rpx;
  margin-top: -74rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(244,67,54,0.5);
  animation: boss-pulse 2s ease-in-out infinite;
  z-index: 1;
}

@keyframes boss-pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
    box-shadow: 0 0 0 0 rgba(244,67,54,0.3);
  }
  50% {
    transform: scale(1.18);
    opacity: 0;
    box-shadow: 0 0 30rpx 10rpx rgba(244,67,54,0);
  }
}

.node-boss.node-available .node-inner {
  background: linear-gradient(135deg, #e53935, #ff5252);
  box-shadow: 0 8rpx 28rpx rgba(229,57,53,0.5), inset 0 2rpx 8rpx rgba(255,255,255,0.3);
  border: 5rpx solid rgba(255,215,0,0.7);
}

.node-boss.node-completed .node-inner {
  background: linear-gradient(135deg, #43a047, #66bb6a);
  box-shadow: 0 6rpx 20rpx rgba(67,160,71,0.35), inset 0 2rpx 6rpx rgba(255,255,255,0.3);
  border: 5rpx solid rgba(255,215,0,0.5);
}

.node-boss .node-icon {
  font-size: 42rpx;
}

/* ===== Elite Ring ===== */
.node-elite-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120rpx;
  height: 120rpx;
  margin-left: -60rpx;
  margin-top: -60rpx;
  border-radius: 50%;
  border: 3rpx dashed rgba(255,152,0,0.6);
  z-index: 1;
}

.node-elite.node-available .node-inner {
  background: linear-gradient(135deg, #ef6c00, #ff9800);
  box-shadow: 0 6rpx 24rpx rgba(239,108,0,0.45), inset 0 2rpx 6rpx rgba(255,255,255,0.3);
  border: 4rpx solid rgba(255,255,255,0.6);
}

.node-elite .node-icon {
  font-size: 34rpx;
}

/* ===== Node Glow (available nodes) ===== */
.node-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120rpx;
  height: 120rpx;
  margin-left: -60rpx;
  margin-top: -60rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(30,136,229,0.25) 0%, transparent 70%);
  animation: node-glow-pulse 2s ease-in-out infinite;
  z-index: 0;
  pointer-events: none;
}

.node-boss .node-glow {
  width: 160rpx;
  height: 160rpx;
  margin-left: -80rpx;
  margin-top: -80rpx;
  background: radial-gradient(circle, rgba(229,57,53,0.25) 0%, transparent 70%);
}

.node-elite .node-glow {
  width: 140rpx;
  height: 140rpx;
  margin-left: -70rpx;
  margin-top: -70rpx;
  background: radial-gradient(circle, rgba(239,108,0,0.25) 0%, transparent 70%);
}

@keyframes node-glow-pulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* ===== Node Label ===== */
.node-label-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 8rpx;
}

.node-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #2d3436;
  background: rgba(255,255,255,0.85);
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  white-space: nowrap;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.node-locked .node-label {
  color: #aaa;
  background: rgba(255,255,255,0.5);
}

.node-type-label {
  font-size: 16rpx;
  font-weight: 800;
  color: #e53935;
  margin-top: 2rpx;
  letter-spacing: 2rpx;
}

.node-type-elite {
  color: #ef6c00;
}

/* ===== Bottom Bar ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 200;
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 40rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.bottom-btn:active {
  background: rgba(102,126,234,0.08);
  transform: scale(0.92);
}

.bottom-btn-icon {
  font-size: 44rpx;
}

.bottom-btn-label {
  font-size: 22rpx;
  color: #555;
  font-weight: 600;
  margin-top: 4rpx;
}

