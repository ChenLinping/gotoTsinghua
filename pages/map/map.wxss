/* ========================================== */
/* 走向清华 V5 - 修仙修行面板 */
/* ========================================== */

.page {
  width: 100vw; min-height: 100vh;
  background: #1a1a2e;
  display: flex; flex-direction: column;
  padding-bottom: 80px;
}

/* ===== Top Bar ===== */
.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px 8px;
}
.top-date { font-size: 14px; color: rgba(255,255,255,0.6); font-weight: 600; }
.top-countdown { display: flex; align-items: baseline; gap: 4px; }
.cd-num { font-size: 28px; font-weight: 900; color: #fbbf24; }
.cd-label { font-size: 12px; color: rgba(255,255,255,0.5); }

/* Cultivation Days */
.cult-days {
  display: flex; align-items: center; gap: 10px;
  padding: 0 20px 12px;
  font-size: 13px; color: rgba(255,255,255,0.5);
}
.cult-lv { font-weight: 800; color: #a78bfa; }

/* ===== Realm Panel ===== */
.realm-panel {
  position: relative; margin: 8px 20px 20px;
  background: rgba(0,0,0,0.3); border-radius: 20px;
  padding: 30px 20px 24px;
  display: flex; flex-direction: column; align-items: center;
  border: 1px solid rgba(255,255,255,0.08);
  overflow: hidden;
}
.realm-glow {
  position: absolute; top: -30px; left: 50%; transform: translateX(-50%);
  width: 200px; height: 200px; pointer-events: none;
}
.realm-icon { font-size: 64px; margin-bottom: 12px; position: relative; z-index: 2; }
.realm-name {
  font-size: 28px; font-weight: 900; color: #fff;
  letter-spacing: 4px; position: relative; z-index: 2;
}
.realm-stage {
  font-size: 16px; color: rgba(255,255,255,0.7); font-weight: 600;
  margin-top: 4px; position: relative; z-index: 2;
}
.realm-desc {
  font-size: 11px; color: rgba(255,255,255,0.35);
  margin-top: 10px; position: relative; z-index: 2;
}

/* ===== 呼吸光效 ===== */
.realm-breathe {
  animation: realmBreathe 3s ease-in-out infinite;
}
@keyframes realmBreathe {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 8px rgba(255,255,255,0.2)); }
  50% { transform: scale(1.08); filter: drop-shadow(0 0 20px rgba(255,255,255,0.5)); }
}

/* ===== 灵气光环 ===== */
.realm-ring {
  position: absolute;
  top: 20px; left: 50%; transform: translateX(-50%);
  width: 90px; height: 90px;
  border-radius: 50%;
  border: 2px solid;
  animation: ringPulse 3s ease-in-out infinite;
  z-index: 1; pointer-events: none;
}
@keyframes ringPulse {
  0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.3; }
  50% { transform: translateX(-50%) scale(1.2); opacity: 0.6; }
}

/* ===== 灵气粒子 ===== */
.sp-particle {
  position: absolute;
  width: 5px; height: 5px;
  border-radius: 50%;
  opacity: 0; z-index: 1; pointer-events: none;
  animation: spFloat 4s ease-in-out infinite;
}
.sp-particle.p1 { left: 15%; bottom: 20%; animation-delay: 0s; }
.sp-particle.p2 { left: 30%; bottom: 10%; animation-delay: 0.7s; }
.sp-particle.p3 { left: 50%; bottom: 5%; animation-delay: 1.4s; }
.sp-particle.p4 { left: 70%; bottom: 15%; animation-delay: 2.1s; }
.sp-particle.p5 { left: 85%; bottom: 8%; animation-delay: 2.8s; }
.sp-particle.p6 { left: 40%; bottom: 25%; animation-delay: 3.5s; }
@keyframes spFloat {
  0% { transform: translateY(0) scale(0); opacity: 0; }
  15% { transform: translateY(-10px) scale(1.2); opacity: 0.8; }
  50% { transform: translateY(-40px) scale(0.8); opacity: 0.5; }
  100% { transform: translateY(-80px) scale(0); opacity: 0; }
}

/* ===== 进度条灵气流动 ===== */
.progress-fill {
  position: relative; overflow: hidden;
}

/* ===== Progress Bar ===== */
.progress-section { padding: 0 20px 16px; }
.progress-bar {
  height: 10px; background: rgba(255,255,255,0.08);
  border-radius: 5px; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 5px;
  transition: width 0.5s ease;
  box-shadow: 0 0 8px rgba(255,255,255,0.2);
}
.progress-info {
  display: flex; justify-content: space-between;
  padding: 6px 0; font-size: 11px; color: rgba(255,255,255,0.45);
}
.prog-current { color: rgba(255,255,255,0.7); font-weight: 600; }

/* ===== Streak ===== */
.streak-row {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  padding: 8px 0 16px;
}
.streak-fire { font-size: 18px; }
.streak-text { font-size: 13px; color: #fbbf24; font-weight: 700; }

/* ===== Practice Section ===== */
.practice-section {
  margin: 0 20px; padding: 20px;
  background: rgba(0,0,0,0.25); border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.06);
}
.section-title {
  font-size: 16px; font-weight: 800; color: #fff;
  display: block; margin-bottom: 4px;
}
.section-sub {
  font-size: 11px; color: rgba(255,255,255,0.4);
  display: block; margin-bottom: 16px;
}

/* Subject Grid */
.subject-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 10px; margin-bottom: 16px;
}
.subject-btn {
  display: flex; flex-direction: column; align-items: center;
  padding: 14px 8px; border-radius: 12px;
  background: rgba(255,255,255,0.04);
  border: 2px solid rgba(255,255,255,0.08);
  transition: all 0.2s;
}
.subject-btn:active { transform: scale(0.95); }
.subject-active {
  background: rgba(255,255,255,0.1);
  border-width: 2px;
}
.subj-icon { font-size: 24px; margin-bottom: 4px; }
.subj-name { font-size: 12px; color: rgba(255,255,255,0.7); font-weight: 600; }
.subject-active .subj-name { color: #fff; }

/* Start Button */
.start-btn {
  width: 100%; padding: 14px;
  background: rgba(255,255,255,0.06); border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.3);
  transition: all 0.2s;
}
.start-ready {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  box-shadow: 0 4px 12px rgba(99,102,241,0.3);
}
.start-btn:active { transform: scale(0.97); }

/* ===== Done Section ===== */
.done-section { padding: 20px; }
.done-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 30px 20px; background: rgba(0,0,0,0.25);
  border-radius: 16px; border: 1px solid rgba(34,197,94,0.2);
}
.done-icon { font-size: 40px; margin-bottom: 10px; }
.done-title { font-size: 16px; font-weight: 800; color: #4ade80; }
.done-detail { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 6px; }

/* ===== Realm Timeline ===== */
.realm-timeline {
  position: relative; display: flex; align-items: center;
  justify-content: space-between;
  margin: 24px 30px 20px; padding: 0 4px;
}
.tl-dot {
  width: 14px; height: 14px; border-radius: 50%;
  z-index: 2; position: relative;
  border: 2px solid rgba(255,255,255,0.2);
}
.tl-done { background: #4ade80; border-color: #22c55e; }
.tl-cur { background: #a78bfa; border-color: #8b5cf6; box-shadow: 0 0 8px rgba(167,139,250,0.5); }
.tl-lock { background: rgba(255,255,255,0.1); }
.tl-line {
  position: absolute; top: 50%; left: 7px; right: 7px;
  height: 3px; background: rgba(255,255,255,0.08);
  transform: translateY(-50%); z-index: 1;
}
.tl-line-fill { height: 100%; background: #4ade80; border-radius: 2px; transition: width 0.5s; }

/* ============================================ */
/* ===== Practice View (答题) ===== */
/* ============================================ */
.practice-view {
  display: flex; flex-direction: column;
  min-height: 100vh; padding: 20px;
}
.practice-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px;
}
.prac-counter { font-size: 14px; color: rgba(255,255,255,0.7); font-weight: 700; }
.prac-dots { display: flex; gap: 5px; }
.prac-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.dot-ok { background: #22c55e; box-shadow: 0 0 4px rgba(34,197,94,0.5); }
.dot-no { background: #ef4444; box-shadow: 0 0 4px rgba(239,68,68,0.4); }
.dot-cur { background: #a78bfa; box-shadow: 0 0 4px rgba(167,139,250,0.5); }

/* Question */
.practice-body { flex: 1; display: flex; flex-direction: column; }
.prac-q {
  font-size: 16px; color: #e2e8f0; line-height: 1.7;
  padding: 20px; background: rgba(0,0,0,0.2);
  border-radius: 14px; margin-bottom: 16px;
  border: 1px solid rgba(255,255,255,0.06);
}

/* Options */
.prac-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 12px; }
.prac-opt {
  display: flex; align-items: center; padding: 14px 16px;
  border-radius: 12px; border: 2px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04); transition: all 0.15s;
}
.prac-opt:active { transform: scale(0.97); background: rgba(255,255,255,0.08); }
.opt-correct { border-color: #22c55e; background: rgba(34,197,94,0.1); }
.opt-wrong { border-color: #ef4444; background: rgba(239,68,68,0.1); }

.prac-opt-label {
  width: 28px; height: 28px; display: flex;
  align-items: center; justify-content: center;
  background: rgba(139,92,246,0.2); border-radius: 7px;
  font-size: 13px; font-weight: bold; color: #c4b5fd;
  margin-right: 12px; flex-shrink: 0;
}
.opt-correct .prac-opt-label { background: rgba(34,197,94,0.25); color: #4ade80; }
.opt-wrong .prac-opt-label { background: rgba(239,68,68,0.25); color: #f87171; }
.prac-opt-text { flex: 1; font-size: 14px; color: #cbd5e1; line-height: 1.4; }
.opt-correct .prac-opt-text { color: #bbf7d0; }
.opt-wrong .prac-opt-text { color: #fca5a5; }

/* Explain */
.prac-explain {
  background: rgba(0,0,0,0.2); border-radius: 10px; padding: 12px 14px;
}
.explain-ok { font-size: 14px; font-weight: bold; color: #4ade80; display: block; margin-bottom: 6px; }
.explain-fail { font-size: 14px; font-weight: bold; color: #f87171; display: block; margin-bottom: 6px; }
.explain-detail { font-size: 12px; color: #94a3b8; line-height: 1.5; }

/* ============================================ */
/* ===== Result View ===== */
/* ============================================ */
.result-view {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; padding: 20px;
}
.result-card {
  width: 100%; max-width: 360px;
  display: flex; flex-direction: column; align-items: center;
  background: rgba(0,0,0,0.4); border-radius: 20px;
  padding: 30px 24px; border: 1px solid rgba(255,255,255,0.08);
}
.result-icon { font-size: 56px; margin-bottom: 12px; }
.result-title { font-size: 22px; font-weight: 900; color: #fff; margin-bottom: 20px; }

.result-stats { width: 100%; margin-bottom: 20px; }
.stat-row {
  display: flex; justify-content: space-between;
  padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
}
.stat-label { font-size: 13px; color: rgba(255,255,255,0.5); }
.stat-value { font-size: 14px; font-weight: 700; color: #fff; }
.stat-xp { color: #a78bfa; }
.stat-perfect { color: #fbbf24; }

.result-realm {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 20px; background: rgba(255,255,255,0.05);
  border-radius: 10px; margin-bottom: 20px;
}
.rr-icon { font-size: 24px; }
.rr-name { font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.8); }

.result-btn {
  width: 100%; padding: 14px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 12px; display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 700; color: #fff;
  box-shadow: 0 4px 12px rgba(99,102,241,0.3);
}
.result-btn:active { transform: scale(0.97); }

/* ============================================ */
/* ===== Breakthrough Overlay (升级版) ===== */
/* ============================================ */
.bk-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9000; display: flex; align-items: center; justify-content: center;
}
.bk-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  animation: bkBgIn 0.6s ease-out;
}
@keyframes bkBgIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 大境界突破: 屏幕震动 */
.bk-realm-break {
  animation: bkShake 0.6s ease-out 1.2s;
}
@keyframes bkShake {
  0%, 100% { transform: translate(0, 0); }
  10% { transform: translate(-4px, -2px); }
  20% { transform: translate(4px, 2px); }
  30% { transform: translate(-3px, 3px); }
  40% { transform: translate(3px, -3px); }
  50% { transform: translate(-2px, 1px); }
  60% { transform: translate(2px, -1px); }
  70% { transform: translate(-1px, 2px); }
  80% { transform: translate(1px, -1px); }
  90% { transform: translate(-1px, 0); }
}

/* 灵气漩涡 */
.bk-vortex {
  position: absolute; top: 50%; left: 50%;
  width: 200px; height: 200px;
  margin: -100px 0 0 -100px;
  border-radius: 50%;
  border: 3px solid;
  opacity: 0;
  animation: vortexSpin 2s ease-out forwards;
  z-index: 1;
}
.bk-vortex2 {
  width: 140px; height: 140px;
  margin: -70px 0 0 -70px;
  animation: vortexSpin2 2s ease-out 0.2s forwards;
}
@keyframes vortexSpin {
  0% { transform: scale(0) rotate(0deg); opacity: 0; }
  30% { transform: scale(1.5) rotate(180deg); opacity: 0.8; }
  60% { transform: scale(2) rotate(360deg); opacity: 0.5; }
  100% { transform: scale(3) rotate(540deg); opacity: 0; }
}
@keyframes vortexSpin2 {
  0% { transform: scale(0) rotate(0deg); opacity: 0; }
  30% { transform: scale(1.2) rotate(-180deg); opacity: 0.6; }
  60% { transform: scale(1.8) rotate(-360deg); opacity: 0.3; }
  100% { transform: scale(2.5) rotate(-540deg); opacity: 0; }
}

/* 爆发粒子 (8个方向) */
.bk-burst {
  position: absolute; top: 50%; left: 50%;
  width: 8px; height: 8px;
  margin: -4px 0 0 -4px;
  border-radius: 50%;
  opacity: 0; z-index: 1;
  animation: bkBurst 0.8s ease-out 1.4s forwards;
}
.bk-burst.b1 { animation-name: bkBurst1; }
.bk-burst.b2 { animation-name: bkBurst2; }
.bk-burst.b3 { animation-name: bkBurst3; }
.bk-burst.b4 { animation-name: bkBurst4; }
.bk-burst.b5 { animation-name: bkBurst5; }
.bk-burst.b6 { animation-name: bkBurst6; }
.bk-burst.b7 { animation-name: bkBurst7; }
.bk-burst.b8 { animation-name: bkBurst8; }

@keyframes bkBurst1 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(80px,-60px) scale(0); opacity: 0; } }
@keyframes bkBurst2 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(90px,20px) scale(0); opacity: 0; } }
@keyframes bkBurst3 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(40px,80px) scale(0); opacity: 0; } }
@keyframes bkBurst4 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(-30px,75px) scale(0); opacity: 0; } }
@keyframes bkBurst5 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(-85px,30px) scale(0); opacity: 0; } }
@keyframes bkBurst6 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(-80px,-50px) scale(0); opacity: 0; } }
@keyframes bkBurst7 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(-20px,-85px) scale(0); opacity: 0; } }
@keyframes bkBurst8 { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(50px,-75px) scale(0); opacity: 0; } }

/* 面板 */
.bk-panel {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center;
  background: linear-gradient(180deg, #2a1f4e, #1a1340);
  border: 2px solid rgba(167,139,250,0.4);
  border-radius: 20px; padding: 30px 36px;
  animation: bkIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1s both;
}
@keyframes bkIn {
  from { transform: scale(0.3) translateY(60px); opacity: 0; }
  to { transform: scale(1) translateY(0); opacity: 1; }
}
.bk-title {
  font-size: 24px; font-weight: 900; color: #fbbf24;
  letter-spacing: 4px; margin-bottom: 16px;
  animation: bkTitleGlow 2s ease-in-out infinite;
}
@keyframes bkTitleGlow {
  0%, 100% { text-shadow: 0 0 8px rgba(251,191,36,0.3); }
  50% { text-shadow: 0 0 20px rgba(251,191,36,0.8), 0 0 40px rgba(251,191,36,0.4); }
}

/* 境界图标浮现 */
.bk-icon-emerge {
  font-size: 64px; margin-bottom: 12px;
  animation: bkIconEmerge 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1.2s both, bkPulse 2s ease-in-out 2s infinite;
}
@keyframes bkIconEmerge {
  from { transform: scale(0) rotate(-30deg); opacity: 0; }
  to { transform: scale(1) rotate(0deg); opacity: 1; }
}
@keyframes bkPulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px rgba(255,255,255,0.3)); }
  50% { transform: scale(1.12); filter: drop-shadow(0 0 25px rgba(255,255,255,0.6)); }
}

.bk-from { font-size: 16px; color: rgba(255,255,255,0.5); font-weight: 600; }
.bk-arrow { font-size: 24px; color: #a78bfa; margin: 8px 0; }
.bk-to {
  font-size: 22px; color: #fff; font-weight: 900; letter-spacing: 2px;
  animation: bkToReveal 0.5s ease-out 1.6s both;
}
@keyframes bkToReveal {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.bk-desc { font-size: 12px; color: rgba(255,255,255,0.4); margin: 12px 0 20px; }
.bk-btn {
  padding: 12px 40px;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border-radius: 10px; font-size: 15px; font-weight: 800; color: #fff;
  box-shadow: 0 4px 12px rgba(245,158,11,0.3);
  animation: bkBtnIn 0.4s ease-out 2s both;
}
@keyframes bkBtnIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.bk-btn:active { transform: scale(0.95); }
