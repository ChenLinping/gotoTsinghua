/* ========================================== */
/* 走向清华 V3.0 - 大地图 + 摇杆 + 炼宝 + 战斗 */
/* ========================================== */

/* ===== Page ===== */
.page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: #1a1a2e;
}

/* ===== World (camera) ===== */
.world {
  position: absolute;
  top: 0;
  left: 0;
  width: 3000px;
  height: 3000px;
  will-change: transform;
}

.world-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.mc-bg-1 { background: linear-gradient(180deg, #87ceeb 0%, #87ceeb 5%, #6aaa3e 5%, #5b9630 30%, #4a8528 60%, #3d7220 100%); }
.mc-bg-2 { background: linear-gradient(180deg, #6b8e6b 0%, #6b8e6b 5%, #3d6b28 5%, #2d5a1a 50%, #1d4a0a 100%); }
.mc-bg-3 { background: linear-gradient(180deg, #b0c4de 0%, #b0c4de 5%, #8fa4b8 5%, #7a90a4 50%, #6a8094 100%); }
.mc-bg-4 { background: linear-gradient(180deg, #cd853f 0%, #cd853f 5%, #b8732e 5%, #a0621e 50%, #885010 100%); }
.mc-bg-5 { background: linear-gradient(180deg, #9370db 0%, #9370db 5%, #7b5cb8 5%, #6a4ca6 50%, #593c96 100%); }

/* ===== Ground Grid ===== */
.world-grid {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  opacity: 0.06;
  pointer-events: none;
  z-index: 1;
}

.grid-row {
  display: flex;
  flex: 1;
}

.grid-cell {
  flex: 1;
  border: 1px solid rgba(0,0,0,0.15);
}

.gc-0 { background: #5b8c3e; }
.gc-1 { background: #4a7a30; }
.gc-2 { background: #6b9c4e; }

/* ===== Decorations ===== */
.deco {
  position: absolute;
  z-index: 2;
  pointer-events: none;
}

.deco-cloud {
  font-size: 52px;
  opacity: 0.6;
  animation: cloudFloat 25s linear infinite;
}

.deco-tree {
  font-size: 40px;
  filter: drop-shadow(2px 4px 0 rgba(0,0,0,0.3));
}

@keyframes cloudFloat {
  0% { transform: translateX(0); }
  100% { transform: translateX(120px); }
}

/* ===== Monsters ===== */
.mob {
  position: absolute;
  z-index: 10;
  transform: translate(-50%, -50%);
  transition: opacity 0.3s;
}

.mob-alive { opacity: 1; }
.mob-dead { opacity: 0.5; }
.mob-locked { opacity: 0.35; pointer-events: none; }

.mob-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.mob-head {
  width: 64px;
  height: 64px;
  background: #8b6b4a;
  border: 3px solid #6b4a2a;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 0 rgba(0,0,0,0.25);
  position: relative;
  z-index: 3;
}

.mob-face {
  font-size: 32px;
  line-height: 1;
}

.mob-dead .mob-head {
  background: #4ad8d8;
  border-color: #2a9898;
}

.mob-dead .mob-face {
  color: #fff;
  font-size: 28px;
  font-weight: 900;
}

.mob-locked .mob-head {
  background: #888;
  border-color: #666;
}

.mob-boss .mob-head {
  width: 80px;
  height: 80px;
  background: #ee3333;
  border-color: #aa1111;
  border-width: 4px;
  box-shadow: 0 0 20px rgba(238,51,51,0.4), 0 4px 0 rgba(0,0,0,0.25);
}

.mob-boss .mob-face { font-size: 40px; }

.mob-elite .mob-head {
  width: 72px;
  height: 72px;
  background: #e8c200;
  border-color: #a08600;
  box-shadow: 0 0 15px rgba(232,194,0,0.3), 0 4px 0 rgba(0,0,0,0.25);
}

.mob-elite .mob-face { font-size: 36px; }

/* Monster legs */
.mob-legs {
  display: flex;
  gap: 8px;
  margin-top: -2px;
  z-index: 2;
}

.mob-leg {
  width: 18px;
  height: 14px;
  background: #6b4a2a;
  border: 2px solid #4a2a0a;
  border-radius: 0 0 4px 4px;
}

.mob-dead .mob-leg { background: #2a9898; border-color: #1a7878; }
.mob-locked .mob-leg { background: #666; border-color: #444; }
.mob-boss .mob-leg { width: 22px; height: 16px; background: #aa1111; border-color: #881111; }
.mob-elite .mob-leg { background: #a08600; border-color: #806800; }

/* Monster info */
.mob-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 6px;
  gap: 3px;
}

.mob-name {
  font-size: 11px;
  font-weight: 700;
  color: #fff;
  background: rgba(0,0,0,0.6);
  padding: 2px 8px;
  border-radius: 4px;
  white-space: nowrap;
  text-shadow: 1px 1px 0 rgba(0,0,0,0.5);
}

.mob-hp-bar {
  width: 50px;
  height: 5px;
  background: rgba(0,0,0,0.4);
  border-radius: 3px;
  overflow: hidden;
}

.mob-hp-fill {
  height: 100%;
  background: linear-gradient(90deg, #ef4444, #f87171);
  border-radius: 3px;
  transition: width 0.3s;
}

/* ===== Player ===== */
.player {
  position: absolute;
  z-index: 20;
  transform: translate(-50%, -50%);
}

.player-shadow {
  width: 36px;
  height: 10px;
  background: rgba(0,0,0,0.25);
  border-radius: 50%;
  margin: 2px auto 0;
  animation: shadowPulse 1.5s ease-in-out infinite;
}

@keyframes shadowPulse {
  0%, 100% { opacity: 0.25; transform: scaleX(1); }
  50% { opacity: 0.4; transform: scaleX(1.2); }
}

/* ===== Steve Character ===== */
.steve {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: steveIdle 1.5s ease-in-out infinite;
}

.steve-walk {
  animation: steveWalk 0.4s ease-in-out infinite;
}

@keyframes steveIdle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3px); }
}

@keyframes steveWalk {
  0%, 100% { transform: translateY(0); }
  25% { transform: translateY(-4px) rotate(-2deg); }
  75% { transform: translateY(-4px) rotate(2deg); }
}

.steve-head-box {
  width: 28px;
  height: 28px;
  background: #c8a87a;
  border: 2px solid #8b6b4a;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 3;
}

.steve-face {
  font-size: 18px;
  line-height: 1;
}

.steve-body-box {
  display: flex;
  align-items: stretch;
  height: 22px;
  position: relative;
  z-index: 2;
  margin-top: -1px;
}

.steve-arm-l,
.steve-arm-r {
  width: 8px;
  background: #5b8c3e;
  border: 1px solid #3d6b28;
}

.steve-arm-l { border-radius: 3px 0 0 3px; }
.steve-arm-r { border-radius: 0 3px 3px 0; }

.steve-torso {
  width: 20px;
  background: #3b82f6;
  border: 1px solid #2563eb;
}

.steve-legs-box {
  display: flex;
  height: 18px;
  position: relative;
  z-index: 1;
  margin-top: -1px;
}

.steve-leg-l,
.steve-leg-r {
  width: 14px;
  background: #4a4a8a;
  border: 1px solid #333366;
  border-radius: 0 0 3px 3px;
}

.steve-walk .steve-leg-l {
  animation: legSwingL 0.4s ease-in-out infinite;
}
.steve-walk .steve-leg-r {
  animation: legSwingR 0.4s ease-in-out infinite;
}

@keyframes legSwingL {
  0%, 100% { transform: rotate(0); }
  50% { transform: rotate(-15deg); }
}
@keyframes legSwingR {
  0%, 100% { transform: rotate(0); }
  50% { transform: rotate(15deg); }
}

/* ===== Treasure Orbit ===== */
.treasure-orbit {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  z-index: 25;
  pointer-events: none;
}

.treasure-item {
  position: absolute;
  width: 28px;
  height: 28px;
  margin-left: -14px;
  margin-top: -14px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.3);
  box-shadow: 0 0 8px rgba(255,255,255,0.2);
}

.treasure-emoji {
  font-size: 16px;
  line-height: 1;
}

/* ===== HUD Bar ===== */
.hud-bar {
  position: fixed;
  top: 12px;
  left: 12px;
  right: 12px;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(0,0,0,0.6);
  padding: 8px 14px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
}

.hud-lv {
  font-size: 13px;
  font-weight: 800;
  color: #ffd700;
  text-shadow: 1px 1px 0 rgba(0,0,0,0.5);
  white-space: nowrap;
}

.hud-rank {
  font-size: 16px;
}

.hud-hp-wrap {
  flex: 1;
  height: 8px;
  background: rgba(255,255,255,0.1);
  border-radius: 4px;
  overflow: hidden;
}

.hud-hp-fill {
  height: 100%;
  background: linear-gradient(90deg, #22c55e, #4ade80);
  border-radius: 4px;
  transition: width 0.5s;
}

.hud-coin {
  font-size: 12px;
  color: #fbbf24;
  font-weight: 700;
  white-space: nowrap;
}

.hud-treasure-count {
  font-size: 12px;
  color: #c4b5fd;
  font-weight: 600;
  white-space: nowrap;
}

/* ===== Region Pill ===== */
.region-pill {
  position: fixed;
  top: 52px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 101;
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(0,0,0,0.55);
  padding: 6px 16px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.12);
  backdrop-filter: blur(6px);
  font-size: 12px;
  color: #fff;
  font-weight: 600;
}

.pill-arrow {
  font-size: 10px;
  color: rgba(255,255,255,0.5);
  margin-left: 4px;
}

/* Region Dropdown */
.region-dropdown {
  position: fixed;
  top: 82px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 102;
  background: rgba(0,0,0,0.85);
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  padding: 6px;
  backdrop-filter: blur(12px);
  min-width: 200px;
  animation: ddSlideIn 0.2s ease;
}

@keyframes ddSlideIn {
  from { opacity: 0; transform: translateX(-50%) translateY(-8px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.dd-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 13px;
  color: #fff;
  font-weight: 500;
  transition: background 0.15s;
}

.dd-item:active { background: rgba(255,255,255,0.1); }
.dd-active { background: rgba(91,140,62,0.3); }
.dd-locked { opacity: 0.4; }

.dd-lock {
  font-size: 10px;
  color: #999;
}

/* ===== Chest Float ===== */
.chest-float {
  position: fixed;
  right: 16px;
  top: 50%;
  z-index: 100;
  width: 48px;
  height: 48px;
  background: linear-gradient(180deg, #c6a03e, #8b6914);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 0 rgba(0,0,0,0.3);
  border: 2px solid #d4a017;
  animation: chestBounce 2s ease-in-out infinite;
}

@keyframes chestBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

.chest-emoji {
  font-size: 28px;
}

/* ===== Virtual Joystick ===== */
.joystick-zone {
  position: fixed;
  left: 20px;
  bottom: 80px;
  width: 120px;
  height: 120px;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.joystick-base {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 2px solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.joystick-knob {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.15) 100%);
  border: 2px solid rgba(255,255,255,0.35);
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  transition: none;
}

/* ===== Hint Bar ===== */
.hint-bar {
  position: fixed;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 90;
  background: rgba(0,0,0,0.55);
  color: rgba(255,255,255,0.8);
  font-size: 12px;
  padding: 8px 20px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.1);
  white-space: nowrap;
  animation: hintFade 3s ease-in-out infinite;
}

@keyframes hintFade {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

/* ============================================ */
/* ===== FORGE OVERLAY (炼宝界面) ===== */
/* ============================================ */
.forge-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.forge-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(6px);
  animation: fadeIn 0.3s ease;
}

.forge-panel {
  position: relative;
  z-index: 2;
  width: 88%;
  max-width: 380px;
  background: linear-gradient(180deg, #2a1f4e 0%, #1a1340 100%);
  border-radius: 20px;
  padding: 28px 24px;
  border: 2px solid rgba(167,139,250,0.3);
  box-shadow: 0 0 40px rgba(139,92,246,0.2);
  animation: panelSlideUp 0.35s ease;
}

@keyframes panelSlideUp {
  from { opacity: 0; transform: translateY(40px) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.forge-header {
  text-align: center;
  margin-bottom: 20px;
}

.forge-title {
  display: block;
  font-size: 24px;
  font-weight: 900;
  color: #c4b5fd;
  text-shadow: 0 0 12px rgba(167,139,250,0.4);
}

.forge-sub {
  display: block;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  margin-top: 4px;
}

/* Furnace */
.forge-furnace {
  width: 80px;
  height: 80px;
  margin: 0 auto 20px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139,92,246,0.3) 0%, rgba(30,20,60,0.8) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 2px solid rgba(167,139,250,0.3);
}

.furnace-glow {
  position: absolute;
  top: -10px; left: -10px; right: -10px; bottom: -10px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(167,139,250,0.25) 0%, transparent 70%);
  animation: furnacePulse 2s ease-in-out infinite;
  pointer-events: none;
}

@keyframes furnacePulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}

.furnace-emoji {
  font-size: 40px;
  animation: furnaceSpin 3s linear infinite;
}

@keyframes furnaceSpin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Question */
.forge-question {
  background: rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 16px 18px;
  margin-bottom: 16px;
  border: 1px solid rgba(255,255,255,0.08);
}

.forge-q-text {
  font-size: 14px;
  color: #e2e8f0;
  line-height: 1.7;
  word-break: break-all;
}

/* Options */
.forge-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 14px;
}

.forge-opt {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-radius: 12px;
  border: 2px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.05);
  transition: all 0.2s;
}

.forge-opt:active {
  transform: scale(0.97);
  background: rgba(255,255,255,0.1);
}

.opt-correct {
  border-color: #22c55e;
  background: rgba(34,197,94,0.15);
  box-shadow: 0 0 16px rgba(34,197,94,0.2);
}

.opt-wrong {
  border-color: #ef4444;
  background: rgba(239,68,68,0.15);
  box-shadow: 0 0 16px rgba(239,68,68,0.2);
}

.opt-label {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(139,92,246,0.25);
  border-radius: 8px;
  font-size: 13px;
  font-weight: bold;
  color: #c4b5fd;
  margin-right: 12px;
  flex-shrink: 0;
}

.opt-correct .opt-label {
  background: rgba(34,197,94,0.3);
  color: #4ade80;
}

.opt-wrong .opt-label {
  background: rgba(239,68,68,0.3);
  color: #f87171;
}

.opt-text {
  flex: 1;
  font-size: 13px;
  color: #cbd5e1;
  line-height: 1.5;
}

.opt-correct .opt-text { color: #bbf7d0; }
.opt-wrong .opt-text { color: #fca5a5; }

/* Explain */
.forge-explain {
  background: rgba(255,255,255,0.04);
  border-radius: 10px;
  padding: 12px 14px;
  border: 1px solid rgba(255,255,255,0.06);
}

.explain-ok {
  font-size: 14px;
  font-weight: bold;
  color: #4ade80;
  display: block;
  margin-bottom: 6px;
}

.explain-fail {
  font-size: 14px;
  font-weight: bold;
  color: #f87171;
  display: block;
  margin-bottom: 6px;
}

.explain-detail {
  font-size: 12px;
  color: #94a3b8;
  line-height: 1.6;
}

/* ============================================ */
/* ===== TREASURE GOT (获得法宝) ===== */
/* ============================================ */
.got-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.got-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.8);
  animation: fadeIn 0.3s ease;
}

.got-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: gotPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes gotPop {
  from { transform: scale(0.3); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.got-burst {
  position: absolute;
  width: 200px;
  height: 200px;
  top: 50%;
  left: 50%;
  margin-left: -100px;
  margin-top: -100px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(251,191,36,0.4) 0%, rgba(167,139,250,0.2) 40%, transparent 70%);
  animation: burstPulse 1.5s ease-out forwards;
  pointer-events: none;
}

@keyframes burstPulse {
  0% { transform: scale(0.3); opacity: 1; }
  60% { transform: scale(1.2); opacity: 0.8; }
  100% { transform: scale(1.5); opacity: 0; }
}

.got-emoji {
  font-size: 72px;
  margin-bottom: 12px;
  animation: gotBounce 0.8s ease-in-out infinite;
  filter: drop-shadow(0 4px 12px rgba(251,191,36,0.5));
}

@keyframes gotBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-10px) scale(1.05); }
}

.got-name {
  font-size: 22px;
  font-weight: 900;
  color: #fbbf24;
  text-shadow: 0 2px 8px rgba(251,191,36,0.4);
  margin-bottom: 6px;
}

.got-count {
  font-size: 14px;
  color: rgba(255,255,255,0.6);
  font-weight: 600;
}

/* ============================================ */
/* ===== COMBAT OVERLAY (地图战斗) ===== */
/* ============================================ */
.combat-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.combat-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(4px);
  animation: fadeIn 0.3s ease;
}

.combat-arena {
  position: relative;
  z-index: 2;
  width: 92%;
  max-width: 400px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  padding: 24px 20px;
  animation: arenaSlide 0.4s ease;
}

@keyframes arenaSlide {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Player Side */
.combat-player-side {
  display: flex;
  align-items: center;
  gap: 16px;
  align-self: flex-start;
}

.combat-steve {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: combatSteveReady 0.6s ease;
}

@keyframes combatSteveReady {
  0% { transform: translateX(-30px); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}

.combat-remaining {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.combat-treasure-mini {
  font-size: 18px;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.2);
}

/* Flying Treasure */
.combat-flying {
  position: absolute;
  left: 80px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  transition: none;
}

.fly-go {
  animation: flyToMonster 0.5s ease-in forwards;
}

.fly-hit {
  animation: flyHitFlash 0.3s ease-out forwards;
}

@keyframes flyToMonster {
  0% { left: 80px; opacity: 1; transform: translateY(-50%) scale(1); }
  70% { left: 280px; opacity: 1; transform: translateY(-50%) scale(1.3); }
  100% { left: 300px; opacity: 0.8; transform: translateY(-50%) scale(0.8); }
}

@keyframes flyHitFlash {
  0% { opacity: 1; transform: translateY(-50%) scale(1.5); }
  50% { opacity: 1; transform: translateY(-50%) scale(2); }
  100% { opacity: 0; transform: translateY(-50%) scale(0.5); }
}

.fly-emoji {
  font-size: 32px;
  filter: drop-shadow(0 0 8px rgba(255,200,0,0.6));
}

/* Damage Number */
.combat-dmg {
  position: absolute;
  right: 60px;
  top: 30%;
  z-index: 15;
  opacity: 0;
}

.dmg-show {
  animation: dmgFloat 0.6s ease-out forwards;
}

@keyframes dmgFloat {
  0% { opacity: 0; transform: translateY(0) scale(0.5); }
  30% { opacity: 1; transform: translateY(-10px) scale(1.2); }
  100% { opacity: 0; transform: translateY(-30px) scale(0.8); }
}

.combat-dmg text {
  font-size: 28px;
  font-weight: 900;
  color: #fbbf24;
  text-shadow: 0 2px 4px rgba(0,0,0,0.8), 0 0 12px rgba(251,191,36,0.5);
}

/* Monster Side */
.combat-monster-side {
  display: flex;
  flex-direction: column;
  align-items: center;
  align-self: flex-end;
  animation: monsterAppear 0.5s ease;
}

@keyframes monsterAppear {
  0% { transform: translateX(30px); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}

.monster-shake {
  animation: monsterHitShake 0.4s ease-in-out !important;
}

@keyframes monsterHitShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-12px); }
  40% { transform: translateX(12px); }
  60% { transform: translateX(-8px); }
  80% { transform: translateX(8px); }
}

.monster-attack {
  animation: monsterCounterAttack 0.5s ease-in-out !important;
}

@keyframes monsterCounterAttack {
  0% { transform: translateX(0); }
  30% { transform: translateX(-40px) scale(1.1); }
  60% { transform: translateX(10px); }
  100% { transform: translateX(0) scale(1); }
}

.combat-mob-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.combat-mob-head {
  width: 72px;
  height: 72px;
  background: #8b6b4a;
  border: 3px solid #6b4a2a;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 0 rgba(0,0,0,0.25);
}

.combat-mob-face {
  font-size: 36px;
  line-height: 1;
}

.combat-mob-legs {
  display: flex;
  gap: 10px;
  margin-top: -2px;
}

.combat-mob-name {
  font-size: 13px;
  font-weight: 700;
  color: #e2e8f0;
  margin-top: 8px;
  text-shadow: 0 1px 2px rgba(0,0,0,0.5);
}

.combat-mob-hp {
  width: 100px;
  height: 8px;
  background: rgba(255,255,255,0.1);
  border-radius: 4px;
  overflow: hidden;
  margin-top: 6px;
  position: relative;
}

.combat-mob-hp-fill {
  height: 100%;
  background: linear-gradient(90deg, #ef4444, #f87171);
  border-radius: 4px;
  transition: width 0.4s ease;
}

.combat-mob-hp-text {
  position: absolute;
  top: -16px;
  right: 0;
  font-size: 10px;
  color: #94a3b8;
  white-space: nowrap;
}

/* Combat Log */
.combat-log {
  width: 100%;
  text-align: center;
  padding: 10px;
  background: rgba(0,0,0,0.3);
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.06);
}

.combat-log text {
  font-size: 13px;
  color: #a78bfa;
  font-weight: 500;
}

/* ===== Combat Result ===== */
.combat-result {
  position: relative;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0,0,0,0.6);
  border-radius: 20px;
  padding: 28px 32px;
  border: 1px solid rgba(255,255,255,0.1);
  animation: resultPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  margin-top: 12px;
}

@keyframes resultPop {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.result-emoji {
  font-size: 48px;
  margin-bottom: 8px;
}

.result-title {
  font-size: 20px;
  font-weight: 900;
  color: #fbbf24;
  text-shadow: 0 2px 6px rgba(251,191,36,0.3);
  margin-bottom: 12px;
}

.result-hint {
  font-size: 13px;
  color: #94a3b8;
  margin-bottom: 16px;
}

.result-rewards {
  display: flex;
  gap: 20px;
  margin-bottom: 16px;
  font-size: 14px;
  color: #e2e8f0;
  font-weight: 600;
}

.result-btn {
  padding: 14px 40px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  border-radius: 14px;
  box-shadow: 0 4px 12px rgba(99,102,241,0.3);
  text-align: center;
}

.result-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}

/* ============================================ */
/* ===== WEAPON DROP ===== */
/* ============================================ */
.drop-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drop-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  animation: fadeIn 0.3s ease;
}

.drop-panel {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, #4a3728, #3a2a1a);
  border: 4px solid #8b6b4a;
  border-radius: 16px;
  padding: 32px 40px;
  box-shadow: 0 8px 0 rgba(0,0,0,0.4);
  animation: dropIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes dropIn {
  from { transform: translateY(60px) scale(0.8); opacity: 0; }
  to { transform: translateY(0) scale(1); opacity: 1; }
}

.drop-title {
  font-size: 24px;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 2px 2px 0 rgba(0,0,0,0.5);
  margin-bottom: 20px;
}

.drop-weapon-emoji {
  font-size: 64px;
  margin-bottom: 12px;
  animation: weaponBounce 1s ease-in-out infinite;
  filter: drop-shadow(0 4px 8px rgba(255,215,0,0.5));
}

@keyframes weaponBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-12px) rotate(5deg); }
}

.drop-weapon-name {
  font-size: 20px;
  font-weight: 900;
  color: #ffd700;
  letter-spacing: 2px;
  text-shadow: 2px 2px 0 rgba(0,0,0,0.5);
  margin-bottom: 6px;
}

.drop-weapon-desc {
  font-size: 12px;
  color: rgba(255,255,255,0.6);
  margin-bottom: 20px;
}

.drop-btn {
  padding: 14px 40px;
  background: linear-gradient(180deg, #5b8c3e, #3d6b28);
  border: 3px solid #7ab356;
  border-radius: 8px;
  box-shadow: 0 4px 0 rgba(0,0,0,0.3);
  font-size: 16px;
  font-weight: 800;
  color: #fff;
  text-shadow: 1px 1px 0 rgba(0,0,0,0.4);
}

.drop-btn:active {
  transform: translateY(3px);
  box-shadow: 0 1px 0 rgba(0,0,0,0.3);
}

/* ===== Shared Keyframes ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
