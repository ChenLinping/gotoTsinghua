/* ========================================== */
/* 走向清华 V4.1 - 双层体系: 消耗飞刀 + 永久Buff */
/* ========================================== */

/* ===== Page ===== */
.page {
  width: 100vw; height: 100vh;
  overflow: hidden; position: relative;
  background: #1a1a2e;
}

/* ===== World ===== */
.world {
  position: absolute; top: 0; left: 0;
  width: 3000px; height: 3000px;
  will-change: transform;
}

.world-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }
.mc-bg-1 { background: linear-gradient(180deg, #87ceeb 0%, #87ceeb 5%, #6aaa3e 5%, #5b9630 30%, #4a8528 60%, #3d7220 100%); }
.mc-bg-2 { background: linear-gradient(180deg, #6b8e6b 0%, #6b8e6b 5%, #3d6b28 5%, #2d5a1a 50%, #1d4a0a 100%); }
.mc-bg-3 { background: linear-gradient(180deg, #b0c4de 0%, #b0c4de 5%, #8fa4b8 5%, #7a90a4 50%, #6a8094 100%); }
.mc-bg-4 { background: linear-gradient(180deg, #cd853f 0%, #cd853f 5%, #b8732e 5%, #a0621e 50%, #885010 100%); }
.mc-bg-5 { background: linear-gradient(180deg, #9370db 0%, #9370db 5%, #7b5cb8 5%, #6a4ca6 50%, #593c96 100%); }

/* Grid */
.world-grid { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; flex-direction: column; opacity: 0.05; pointer-events: none; z-index: 1; }
.grid-row { display: flex; flex: 1; }
.grid-cell { flex: 1; border: 1px solid rgba(0,0,0,0.12); }
.gc-0 { background: #5b8c3e; } .gc-1 { background: #4a7a30; } .gc-2 { background: #6b9c4e; }

/* Decorations */
.deco { position: absolute; z-index: 2; pointer-events: none; }
.deco-cloud { font-size: 40px; opacity: 0.4; animation: cloudDrift 30s linear infinite; }
.deco-tree { font-size: 32px; opacity: 0.5; color: #2d6b1a; }
@keyframes cloudDrift { 0% { transform: translateX(0); } 100% { transform: translateX(100px); } }

/* ===== Damage Numbers ===== */
.dmg-float {
  position: absolute; z-index: 30;
  animation: dmgUp 0.8s ease-out forwards;
  pointer-events: none;
}
.dmg-float text {
  font-size: 18px; font-weight: 900;
  text-shadow: 0 1px 3px rgba(0,0,0,0.8);
}
.dmg-monster text { color: #fbbf24; }
.dmg-player text { color: #ef4444; }

@keyframes dmgUp {
  0% { opacity: 1; transform: translateY(0); }
  60% { opacity: 1; transform: translateY(-25px); }
  100% { opacity: 0; transform: translateY(-45px); }
}

/* ===== Hit Flash ===== */
.hit-flash {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(239, 68, 68, 0.15);
  z-index: 400; pointer-events: none;
  animation: flashOut 0.2s ease-out forwards;
}
@keyframes flashOut { from { opacity: 1; } to { opacity: 0; } }

/* ===== Monsters ===== */
.mob {
  position: absolute; z-index: 10;
  transform: translate(-50%, -50%);
}
.mob-alive { opacity: 1; }
.mob-dead { opacity: 0.3; }
.mob-locked { opacity: 0.25; pointer-events: none; }

.mob-body { display: flex; flex-direction: column; align-items: center; }

.mob-head {
  width: 50px; height: 50px;
  background: #8b6b4a; border: 3px solid #6b4a2a;
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 3px 0 rgba(0,0,0,0.25);
  position: relative; z-index: 3;
}
.mob-face { font-size: 22px; line-height: 1; color: #fff; font-weight: 900; }

.mob-dead .mob-head { background: #5a9a9a; border-color: #3a7a7a; }
.mob-locked .mob-head { background: #777; border-color: #555; }

.mob-boss .mob-head {
  width: 66px; height: 66px;
  background: #cc2222; border-color: #991111; border-width: 4px;
  box-shadow: 0 0 16px rgba(204,34,34,0.4), 0 3px 0 rgba(0,0,0,0.25);
}
.mob-boss .mob-face { font-size: 28px; }

.mob-elite .mob-head {
  width: 58px; height: 58px;
  background: #c8a200; border-color: #8a7000;
  box-shadow: 0 0 12px rgba(200,162,0,0.3), 0 3px 0 rgba(0,0,0,0.25);
}
.mob-elite .mob-face { font-size: 24px; }

/* Chase glow */
.mob-chase .mob-head {
  animation: chasePulse 0.6s ease-in-out infinite;
}
@keyframes chasePulse {
  0%, 100% { box-shadow: 0 0 8px rgba(239,68,68,0.3), 0 3px 0 rgba(0,0,0,0.25); }
  50% { box-shadow: 0 0 20px rgba(239,68,68,0.6), 0 3px 0 rgba(0,0,0,0.25); }
}

/* Legs */
.mob-legs { display: flex; gap: 6px; margin-top: -2px; z-index: 2; }
.mob-leg { width: 16px; height: 12px; background: #6b4a2a; border: 2px solid #4a2a0a; border-radius: 0 0 3px 3px; }
.mob-dead .mob-leg { background: #3a7a7a; border-color: #2a5a5a; }
.mob-boss .mob-leg { width: 20px; height: 14px; background: #991111; border-color: #771111; }
.mob-elite .mob-leg { background: #8a7000; border-color: #6a5000; }

/* Chase leg animation */
.mob-chase .mob-leg:nth-child(1) { animation: legRun 0.3s ease-in-out infinite; }
.mob-chase .mob-leg:nth-child(2) { animation: legRun 0.3s ease-in-out infinite 0.15s; }
@keyframes legRun {
  0%, 100% { transform: rotate(0); }
  50% { transform: rotate(-20deg); }
}

/* Info */
.mob-info { display: flex; flex-direction: column; align-items: center; margin-top: 4px; gap: 2px; }
.mob-name {
  font-size: 10px; font-weight: 700; color: #fff;
  background: rgba(0,0,0,0.55); padding: 1px 6px;
  border-radius: 3px; white-space: nowrap;
}
.mob-hp-bar { width: 44px; height: 4px; background: rgba(0,0,0,0.4); border-radius: 2px; overflow: hidden; }
.mob-hp-fill { height: 100%; background: linear-gradient(90deg, #ef4444, #f87171); border-radius: 2px; transition: width 0.3s; }

/* Monster Knife Orbit */
.mob-knife-orbit { position: absolute; top: 50%; left: 50%; width: 0; height: 0; z-index: 12; pointer-events: none; }
.mob-knife-item {
  position: absolute; width: 16px; height: 16px;
  margin-left: -8px; margin-top: -8px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(139,68,68,0.2); border-radius: 50%;
  border: 1px solid rgba(239,68,68,0.35);
}
.mob-knife-emoji { font-size: 10px; color: #fca5a5; line-height: 1; }
.mob-boss .mob-knife-item { width: 20px; height: 20px; margin-left: -10px; margin-top: -10px; border-color: rgba(239,68,68,0.5); }
.mob-boss .mob-knife-emoji { font-size: 12px; }
.mob-elite .mob-knife-item { width: 18px; height: 18px; margin-left: -9px; margin-top: -9px; border-color: rgba(251,191,36,0.4); background: rgba(168,130,20,0.2); }
.mob-elite .mob-knife-emoji { font-size: 11px; color: #fbbf24; }

/* Monster Knife Bar (replaces HP bar) */
.mob-knife-bar { width: 44px; height: 4px; background: rgba(0,0,0,0.4); border-radius: 2px; overflow: hidden; }
.mob-knife-fill { height: 100%; background: linear-gradient(90deg, #c084fc, #a855f7); border-radius: 2px; transition: width 0.3s; }
.mob-knife-count { font-size: 9px; font-weight: 700; color: #c4b5fd; }

/* ===== Player ===== */
.player { position: absolute; z-index: 20; transform: translate(-50%, -50%); }

.player-shadow {
  width: 30px; height: 8px;
  background: rgba(0,0,0,0.2); border-radius: 50%;
  margin: 2px auto 0;
}

/* Shield Aura */
.shield-aura {
  position: absolute; top: 50%; left: 50%;
  width: 90px; height: 90px;
  margin-left: -45px; margin-top: -45px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(99,102,241,0.25) 0%, rgba(139,92,246,0.15) 50%, transparent 70%);
  border: 2px solid rgba(139,92,246,0.4);
  animation: shieldPulse 1s ease-in-out infinite;
  z-index: 21; pointer-events: none;
}
@keyframes shieldPulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.15); opacity: 0.5; }
}

/* ===== Buff Aura Effects ===== */
.buff-aura {
  position: absolute; top: 50%; left: 50%;
  width: 80px; height: 80px;
  margin-left: -40px; margin-top: -40px;
  border-radius: 50%;
  pointer-events: none; z-index: 19;
}

/* 火焰附魔 - 橙红脉冲 */
.buff-aura-fire {
  background: radial-gradient(circle, rgba(239,68,68,0.15) 0%, rgba(251,146,60,0.1) 50%, transparent 70%);
  border: 1px solid rgba(239,68,68,0.25);
  animation: fireAura 1.5s ease-in-out infinite;
}
@keyframes fireAura {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.2); opacity: 0.4; }
}

/* 护体金甲 - 金色光盾 */
.buff-aura-armor {
  background: radial-gradient(circle, rgba(234,179,8,0.12) 0%, rgba(234,179,8,0.06) 50%, transparent 70%);
  border: 1px solid rgba(234,179,8,0.3);
  animation: armorAura 2s ease-in-out infinite;
}
@keyframes armorAura {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.1); opacity: 0.3; }
}

/* 吸血光环 - 绿色脉动 */
.buff-aura-lifesteal {
  background: radial-gradient(circle, rgba(34,197,94,0.12) 0%, rgba(34,197,94,0.06) 50%, transparent 70%);
  border: 1px solid rgba(34,197,94,0.25);
  animation: lifeAura 1.8s ease-in-out infinite;
}
@keyframes lifeAura {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.15); opacity: 0.35; }
}

/* 暴击之心 - 红色闪烁 */
.buff-aura-crit {
  background: radial-gradient(circle, rgba(239,68,68,0.1) 0%, rgba(236,72,153,0.08) 50%, transparent 70%);
  border: 1px solid rgba(236,72,153,0.2);
  animation: critAura 1s ease-in-out infinite;
}
@keyframes critAura {
  0%, 100% { transform: scale(0.95); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

/* 荆棘之盾 - 绿色刺 */
.buff-aura-thorns {
  background: radial-gradient(circle, rgba(16,185,129,0.12) 0%, rgba(16,185,129,0.06) 50%, transparent 70%);
  border: 1px dashed rgba(16,185,129,0.35);
  animation: thornsAura 2s linear infinite;
}
@keyframes thornsAura {
  0% { transform: scale(1) rotate(0deg); opacity: 0.5; }
  50% { transform: scale(1.1) rotate(180deg); opacity: 0.7; }
  100% { transform: scale(1) rotate(360deg); opacity: 0.5; }
}

/* Fire treasure glow */
.treasure-fire {
  box-shadow: 0 0 8px rgba(239,68,68,0.6);
  border-color: rgba(239,68,68,0.5);
}

/* Steve */
.steve { display: flex; flex-direction: column; align-items: center; animation: steveIdle 1.5s ease-in-out infinite; }
.steve-walk { animation: steveWalk 0.4s ease-in-out infinite; }
@keyframes steveIdle { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-2px); } }
@keyframes steveWalk { 0%, 100% { transform: translateY(0); } 25% { transform: translateY(-3px) rotate(-2deg); } 75% { transform: translateY(-3px) rotate(2deg); } }

.steve-head-box { width: 24px; height: 24px; background: #c8a87a; border: 2px solid #8b6b4a; border-radius: 3px; display: flex; align-items: center; justify-content: center; z-index: 3; }
.steve-face { font-size: 14px; line-height: 1; color: #333; font-weight: 900; }
.steve-body-box { display: flex; align-items: stretch; height: 18px; z-index: 2; margin-top: -1px; }
.steve-arm-l, .steve-arm-r { width: 7px; background: #5b8c3e; border: 1px solid #3d6b28; }
.steve-arm-l { border-radius: 2px 0 0 2px; } .steve-arm-r { border-radius: 0 2px 2px 0; }
.steve-torso { width: 16px; background: #3b82f6; border: 1px solid #2563eb; }
.steve-legs-box { display: flex; height: 14px; z-index: 1; margin-top: -1px; }
.steve-leg-l, .steve-leg-r { width: 11px; background: #4a4a8a; border: 1px solid #333366; border-radius: 0 0 2px 2px; }
.steve-walk .steve-leg-l { animation: legL 0.4s ease-in-out infinite; }
.steve-walk .steve-leg-r { animation: legR 0.4s ease-in-out infinite; }
@keyframes legL { 0%, 100% { transform: rotate(0); } 50% { transform: rotate(-12deg); } }
@keyframes legR { 0%, 100% { transform: rotate(0); } 50% { transform: rotate(12deg); } }

/* Treasure Orbit */
.treasure-orbit { position: absolute; top: 50%; left: 50%; width: 0; height: 0; z-index: 25; pointer-events: none; }
.treasure-item {
  position: absolute; width: 24px; height: 24px;
  margin-left: -12px; margin-top: -12px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.12); border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.25);
  transition: opacity 0.3s;
}
.treasure-emoji { font-size: 14px; line-height: 1; }

/* ===== HUD ===== */
.hud-bar {
  position: fixed; top: 6px; left: 6px; right: 6px; z-index: 100;
  display: flex; align-items: center; gap: 8px;
  background: rgba(0,0,0,0.5); padding: 5px 10px;
  border-radius: 14px; border: 1px solid rgba(255,255,255,0.08);
}
.hud-lv { font-size: 12px; font-weight: 800; color: #ffd700; white-space: nowrap; }
.hud-rank { font-size: 14px; }
.hud-hp-wrap { flex: 1; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; }
.hud-hp-fill { height: 100%; background: linear-gradient(90deg, #22c55e, #4ade80); border-radius: 4px; transition: width 0.3s; }
.hud-hp-fill.hp-low { background: linear-gradient(90deg, #ef4444, #f87171); animation: hpBlink 0.5s ease-in-out infinite; }
@keyframes hpBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
.hud-hp-text { font-size: 10px; color: #94a3b8; white-space: nowrap; min-width: 50px; }
.hud-coin { font-size: 11px; color: #fbbf24; font-weight: 700; white-space: nowrap; }

/* Knife Ammo HUD */
.knife-hud {
  position: fixed; top: 36px; right: 10px; z-index: 101;
  display: flex; align-items: center; gap: 4px;
  background: rgba(0,0,0,0.55); padding: 4px 10px;
  border-radius: 10px; border: 1px solid rgba(196,181,253,0.3);
}
.knife-icon {
  font-size: 14px; color: #c4b5fd;
}
.knife-count {
  font-size: 16px; font-weight: 900; color: #e9d5ff;
  min-width: 16px; text-align: center;
}

/* Buff HUD Icons */
.buff-hud {
  position: fixed; top: 36px; left: 10px; z-index: 101;
  display: flex; align-items: center; gap: 4px;
}
.buff-icon {
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,0.2);
}
.buff-emoji { font-size: 16px; line-height: 1; }

.buff-icon-fire { background: rgba(239,68,68,0.25); border-color: rgba(239,68,68,0.4); }
.buff-icon-armor { background: rgba(234,179,8,0.25); border-color: rgba(234,179,8,0.4); }
.buff-icon-lifesteal { background: rgba(34,197,94,0.25); border-color: rgba(34,197,94,0.4); }
.buff-icon-crit { background: rgba(236,72,153,0.25); border-color: rgba(236,72,153,0.4); }
.buff-icon-thorns { background: rgba(16,185,129,0.25); border-color: rgba(16,185,129,0.4); }

/* Region Pill */
.region-pill {
  position: fixed; top: 6px; right: 160px; z-index: 101;
  display: flex; align-items: center; gap: 4px;
  background: rgba(0,0,0,0.45); padding: 5px 12px;
  border-radius: 12px; font-size: 11px; color: #fff; font-weight: 600;
}
.pill-arrow { font-size: 9px; color: rgba(255,255,255,0.4); margin-left: 4px; }

.region-dropdown {
  position: fixed; top: 34px; right: 160px; z-index: 102;
  background: rgba(0,0,0,0.8); border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.1); padding: 4px;
  min-width: 180px; animation: ddIn 0.2s ease;
}
@keyframes ddIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
.dd-item { display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border-radius: 6px; font-size: 12px; color: #fff; }
.dd-item:active { background: rgba(255,255,255,0.1); }
.dd-active { background: rgba(91,140,62,0.3); } .dd-locked { opacity: 0.35; }
.dd-lock { font-size: 9px; color: #888; }

/* Chest */
.chest-float {
  position: fixed; right: 110px; top: 6px; z-index: 100;
  width: 32px; height: 32px;
  background: linear-gradient(180deg, #c6a03e, #8b6914);
  border-radius: 6px; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 0 rgba(0,0,0,0.3); border: 2px solid #d4a017;
  animation: chestBob 2s ease-in-out infinite;
}
@keyframes chestBob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
.chest-emoji { font-size: 18px; color: #fff; font-weight: 900; }

/* Joystick */
.joystick-zone {
  position: fixed; left: 16px; bottom: 50px;
  width: 100px; height: 100px; z-index: 200;
  display: flex; align-items: center; justify-content: center;
}
.joystick-base {
  width: 90px; height: 90px; border-radius: 50%;
  background: rgba(255,255,255,0.06); border: 2px solid rgba(255,255,255,0.15);
  display: flex; align-items: center; justify-content: center;
}
.joystick-knob {
  width: 36px; height: 36px; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0.1) 100%);
  border: 2px solid rgba(255,255,255,0.3);
}

/* Hint */
.hint-bar {
  position: fixed; bottom: 50px; left: 50%; transform: translateX(-50%);
  z-index: 90; background: rgba(0,0,0,0.5); color: rgba(255,255,255,0.7);
  font-size: 11px; padding: 5px 14px; border-radius: 14px;
}

/* ============================================ */
/* ===== FORGE PANEL ===== */
/* ============================================ */
.forge-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 500; display: flex; align-items: center; justify-content: center;
}
.forge-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); animation: fadeIn 0.3s ease;
}

.forge-panel {
  position: relative; z-index: 2;
  width: 55%; max-width: 440px; max-height: 92vh; overflow-y: auto;
  background: linear-gradient(180deg, #2a1f4e 0%, #1a1340 100%);
  border-radius: 14px; padding: 16px 18px;
  border: 2px solid rgba(167,139,250,0.3);
  animation: panelIn 0.3s ease;
}
@keyframes panelIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

.forge-header { text-align: center; margin-bottom: 12px; }
.forge-title { display: block; font-size: 18px; font-weight: 900; color: #c4b5fd; }
.forge-sub { display: block; font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }

/* Progress */
.forge-progress { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.forge-counter { font-size: 11px; color: #a78bfa; font-weight: 600; }
.forge-dots { display: flex; gap: 6px; }
.forge-dot { width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.1); }
.dot-ok { background: #22c55e; box-shadow: 0 0 6px rgba(34,197,94,0.5); }
.dot-no { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.4); }
.dot-cur { background: rgba(167,139,250,0.5); box-shadow: 0 0 6px rgba(167,139,250,0.4); }

/* Question */
.forge-question {
  background: rgba(255,255,255,0.05); border-radius: 10px;
  padding: 12px 14px; margin-bottom: 10px;
  border: 1px solid rgba(255,255,255,0.06);
}
.forge-q-text { font-size: 13px; color: #e2e8f0; line-height: 1.6; }

/* Options */
.forge-options { display: flex; flex-direction: column; gap: 6px; margin-bottom: 8px; }
.forge-opt {
  display: flex; align-items: center; padding: 10px 12px;
  border-radius: 10px; border: 2px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04); transition: all 0.15s;
}
.forge-opt:active { transform: scale(0.97); background: rgba(255,255,255,0.08); }
.opt-correct { border-color: #22c55e; background: rgba(34,197,94,0.12); }
.opt-wrong { border-color: #ef4444; background: rgba(239,68,68,0.12); }

.opt-label {
  width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;
  background: rgba(139,92,246,0.2); border-radius: 6px;
  font-size: 12px; font-weight: bold; color: #c4b5fd;
  margin-right: 10px; flex-shrink: 0;
}
.opt-correct .opt-label { background: rgba(34,197,94,0.25); color: #4ade80; }
.opt-wrong .opt-label { background: rgba(239,68,68,0.25); color: #f87171; }
.opt-text { flex: 1; font-size: 12px; color: #cbd5e1; line-height: 1.4; }
.opt-correct .opt-text { color: #bbf7d0; } .opt-wrong .opt-text { color: #fca5a5; }

/* Explain */
.forge-explain { background: rgba(255,255,255,0.03); border-radius: 8px; padding: 8px 10px; margin-bottom: 6px; }
.explain-ok { font-size: 12px; font-weight: bold; color: #4ade80; display: block; margin-bottom: 4px; }
.explain-fail { font-size: 12px; font-weight: bold; color: #f87171; display: block; margin-bottom: 4px; }
.explain-detail { font-size: 11px; color: #94a3b8; line-height: 1.5; }

/* Shield Bar */
.forge-shield-bar {
  width: 100%; height: 4px; background: rgba(255,255,255,0.08);
  border-radius: 2px; overflow: hidden; margin-top: 4px;
}
.forge-shield-fill {
  height: 100%; background: linear-gradient(90deg, #6366f1, #a78bfa);
  border-radius: 2px; transition: width 0.5s;
}

/* ===== Weapon Drop ===== */
.drop-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999; display: flex; align-items: center; justify-content: center;
}
.drop-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); }
.drop-panel {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center;
  background: linear-gradient(180deg, #4a3728, #3a2a1a);
  border: 3px solid #8b6b4a; border-radius: 14px;
  padding: 24px 32px; animation: dropIn 0.4s ease;
}
@keyframes dropIn { from { transform: translateY(40px) scale(0.9); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
.drop-title { font-size: 20px; font-weight: 900; color: #ffd700; margin-bottom: 16px; }
.drop-weapon-emoji { font-size: 48px; margin-bottom: 10px; animation: weaponBob 1s ease-in-out infinite; }
@keyframes weaponBob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
.drop-weapon-name { font-size: 18px; font-weight: 900; color: #ffd700; margin-bottom: 4px; }
.drop-weapon-desc { font-size: 11px; color: rgba(255,255,255,0.5); margin-bottom: 16px; }
.drop-btn {
  padding: 10px 32px; background: linear-gradient(180deg, #5b8c3e, #3d6b28);
  border: 2px solid #7ab356; border-radius: 6px;
  font-size: 14px; font-weight: 800; color: #fff;
}
.drop-btn:active { transform: translateY(2px); }

/* ===== Slow Motion Transition ===== */
.world-slowmo {
  filter: grayscale(0.6) brightness(0.5);
  transition: filter 0.6s ease-in;
}

.slowmo-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 450; pointer-events: none;
  display: flex; align-items: center; justify-content: center;
}
.slowmo-vignette {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.7) 100%);
  animation: vignetteIn 0.6s ease-out forwards;
}
@keyframes vignetteIn {
  from { opacity: 0; } to { opacity: 1; }
}

.slowmo-text {
  position: relative; z-index: 2;
  opacity: 0; transform: scale(0.3);
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.slowmo-text-show {
  opacity: 1; transform: scale(1);
}
.slowmo-text text {
  font-size: 32px; font-weight: 900; color: #ef4444;
  text-shadow: 0 0 20px rgba(239,68,68,0.8), 0 0 40px rgba(239,68,68,0.4), 0 2px 4px rgba(0,0,0,0.8);
  letter-spacing: 4px;
}

/* Shared */
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
