/* ========================================== */
/* 走向清华 V5 - 修仙修行面板 */
/* ========================================== */

.page {
  width: 100vw; min-height: 100vh;
  background: #1a1a2e;
  display: flex; flex-direction: column;
  padding-bottom: 80px;
}

/* ===== Top Bar ===== */
.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px 8px;
}
.top-date { font-size: 14px; color: rgba(255,255,255,0.6); font-weight: 600; }
.top-countdown { display: flex; align-items: baseline; gap: 4px; }
.cd-num { font-size: 28px; font-weight: 900; color: #fbbf24; }
.cd-label { font-size: 12px; color: rgba(255,255,255,0.5); }

/* Cultivation Days */
.cult-days {
  display: flex; align-items: center; gap: 10px;
  padding: 0 20px 12px;
  font-size: 13px; color: rgba(255,255,255,0.5);
}
.cult-lv { font-weight: 800; color: #a78bfa; }

/* ===== Realm Panel ===== */
.realm-panel {
  position: relative; margin: 8px 20px 20px;
  background: rgba(0,0,0,0.3); border-radius: 20px;
  padding: 30px 20px 24px;
  display: flex; flex-direction: column; align-items: center;
  border: 1px solid rgba(255,255,255,0.08);
  overflow: hidden;
}
.realm-glow {
  position: absolute; top: -30px; left: 50%; transform: translateX(-50%);
  width: 200px; height: 200px; pointer-events: none;
}
.realm-icon { font-size: 64px; margin-bottom: 12px; position: relative; z-index: 2; }
.realm-name {
  font-size: 28px; font-weight: 900; color: #fff;
  letter-spacing: 4px; position: relative; z-index: 2;
}
.realm-stage {
  font-size: 16px; color: rgba(255,255,255,0.7); font-weight: 600;
  margin-top: 4px; position: relative; z-index: 2;
}
.realm-desc {
  font-size: 11px; color: rgba(255,255,255,0.35);
  margin-top: 10px; position: relative; z-index: 2;
}

/* ===== Progress Bar ===== */
.progress-section { padding: 0 20px 16px; }
.progress-bar {
  height: 10px; background: rgba(255,255,255,0.08);
  border-radius: 5px; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 5px;
  transition: width 0.5s ease;
  box-shadow: 0 0 8px rgba(255,255,255,0.2);
}
.progress-info {
  display: flex; justify-content: space-between;
  padding: 6px 0; font-size: 11px; color: rgba(255,255,255,0.45);
}
.prog-current { color: rgba(255,255,255,0.7); font-weight: 600; }

/* ===== Streak ===== */
.streak-row {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  padding: 8px 0 16px;
}
.streak-fire { font-size: 18px; }
.streak-text { font-size: 13px; color: #fbbf24; font-weight: 700; }

/* ===== Practice Section ===== */
.practice-section {
  margin: 0 20px; padding: 20px;
  background: rgba(0,0,0,0.25); border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.06);
}
.section-title {
  font-size: 16px; font-weight: 800; color: #fff;
  display: block; margin-bottom: 4px;
}
.section-sub {
  font-size: 11px; color: rgba(255,255,255,0.4);
  display: block; margin-bottom: 16px;
}

/* Subject Grid */
.subject-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 10px; margin-bottom: 16px;
}
.subject-btn {
  display: flex; flex-direction: column; align-items: center;
  padding: 14px 8px; border-radius: 12px;
  background: rgba(255,255,255,0.04);
  border: 2px solid rgba(255,255,255,0.08);
  transition: all 0.2s;
}
.subject-btn:active { transform: scale(0.95); }
.subject-active {
  background: rgba(255,255,255,0.1);
  border-width: 2px;
}
.subj-icon { font-size: 24px; margin-bottom: 4px; }
.subj-name { font-size: 12px; color: rgba(255,255,255,0.7); font-weight: 600; }
.subject-active .subj-name { color: #fff; }

/* Start Button */
.start-btn {
  width: 100%; padding: 14px;
  background: rgba(255,255,255,0.06); border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.3);
  transition: all 0.2s;
}
.start-ready {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  box-shadow: 0 4px 12px rgba(99,102,241,0.3);
}
.start-btn:active { transform: scale(0.97); }

/* ===== Done Section ===== */
.done-section { padding: 20px; }
.done-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 30px 20px; background: rgba(0,0,0,0.25);
  border-radius: 16px; border: 1px solid rgba(34,197,94,0.2);
}
.done-icon { font-size: 40px; margin-bottom: 10px; }
.done-title { font-size: 16px; font-weight: 800; color: #4ade80; }
.done-detail { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 6px; }

/* ===== Realm Timeline ===== */
.realm-timeline {
  position: relative; display: flex; align-items: center;
  justify-content: space-between;
  margin: 24px 30px 20px; padding: 0 4px;
}
.tl-dot {
  width: 14px; height: 14px; border-radius: 50%;
  z-index: 2; position: relative;
  border: 2px solid rgba(255,255,255,0.2);
}
.tl-done { background: #4ade80; border-color: #22c55e; }
.tl-cur { background: #a78bfa; border-color: #8b5cf6; box-shadow: 0 0 8px rgba(167,139,250,0.5); }
.tl-lock { background: rgba(255,255,255,0.1); }
.tl-line {
  position: absolute; top: 50%; left: 7px; right: 7px;
  height: 3px; background: rgba(255,255,255,0.08);
  transform: translateY(-50%); z-index: 1;
}
.tl-line-fill { height: 100%; background: #4ade80; border-radius: 2px; transition: width 0.5s; }

/* ============================================ */
/* ===== Practice View (答题) ===== */
/* ============================================ */
.practice-view {
  display: flex; flex-direction: column;
  min-height: 100vh; padding: 20px;
}
.practice-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px;
}
.prac-counter { font-size: 14px; color: rgba(255,255,255,0.7); font-weight: 700; }
.prac-dots { display: flex; gap: 5px; }
.prac-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.dot-ok { background: #22c55e; box-shadow: 0 0 4px rgba(34,197,94,0.5); }
.dot-no { background: #ef4444; box-shadow: 0 0 4px rgba(239,68,68,0.4); }
.dot-cur { background: #a78bfa; box-shadow: 0 0 4px rgba(167,139,250,0.5); }

/* Question */
.practice-body { flex: 1; display: flex; flex-direction: column; }
.prac-q {
  font-size: 16px; color: #e2e8f0; line-height: 1.7;
  padding: 20px; background: rgba(0,0,0,0.2);
  border-radius: 14px; margin-bottom: 16px;
  border: 1px solid rgba(255,255,255,0.06);
}

/* Options */
.prac-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 12px; }
.prac-opt {
  display: flex; align-items: center; padding: 14px 16px;
  border-radius: 12px; border: 2px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04); transition: all 0.15s;
}
.prac-opt:active { transform: scale(0.97); background: rgba(255,255,255,0.08); }
.opt-correct { border-color: #22c55e; background: rgba(34,197,94,0.1); }
.opt-wrong { border-color: #ef4444; background: rgba(239,68,68,0.1); }

.prac-opt-label {
  width: 28px; height: 28px; display: flex;
  align-items: center; justify-content: center;
  background: rgba(139,92,246,0.2); border-radius: 7px;
  font-size: 13px; font-weight: bold; color: #c4b5fd;
  margin-right: 12px; flex-shrink: 0;
}
.opt-correct .prac-opt-label { background: rgba(34,197,94,0.25); color: #4ade80; }
.opt-wrong .prac-opt-label { background: rgba(239,68,68,0.25); color: #f87171; }
.prac-opt-text { flex: 1; font-size: 14px; color: #cbd5e1; line-height: 1.4; }
.opt-correct .prac-opt-text { color: #bbf7d0; }
.opt-wrong .prac-opt-text { color: #fca5a5; }

/* Explain */
.prac-explain {
  background: rgba(0,0,0,0.2); border-radius: 10px; padding: 12px 14px;
}
.explain-ok { font-size: 14px; font-weight: bold; color: #4ade80; display: block; margin-bottom: 6px; }
.explain-fail { font-size: 14px; font-weight: bold; color: #f87171; display: block; margin-bottom: 6px; }
.explain-detail { font-size: 12px; color: #94a3b8; line-height: 1.5; }

/* ============================================ */
/* ===== Result View ===== */
/* ============================================ */
.result-view {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; padding: 20px;
}
.result-card {
  width: 100%; max-width: 360px;
  display: flex; flex-direction: column; align-items: center;
  background: rgba(0,0,0,0.4); border-radius: 20px;
  padding: 30px 24px; border: 1px solid rgba(255,255,255,0.08);
}
.result-icon { font-size: 56px; margin-bottom: 12px; }
.result-title { font-size: 22px; font-weight: 900; color: #fff; margin-bottom: 20px; }

.result-stats { width: 100%; margin-bottom: 20px; }
.stat-row {
  display: flex; justify-content: space-between;
  padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
}
.stat-label { font-size: 13px; color: rgba(255,255,255,0.5); }
.stat-value { font-size: 14px; font-weight: 700; color: #fff; }
.stat-xp { color: #a78bfa; }
.stat-perfect { color: #fbbf24; }

.result-realm {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 20px; background: rgba(255,255,255,0.05);
  border-radius: 10px; margin-bottom: 20px;
}
.rr-icon { font-size: 24px; }
.rr-name { font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.8); }

.result-btn {
  width: 100%; padding: 14px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 12px; display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 700; color: #fff;
  box-shadow: 0 4px 12px rgba(99,102,241,0.3);
}
.result-btn:active { transform: scale(0.97); }

/* ============================================ */
/* ===== Breakthrough Overlay ===== */
/* ============================================ */
.bk-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9000; display: flex; align-items: center; justify-content: center;
}
.bk-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); }
.bk-panel {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center;
  background: linear-gradient(180deg, #2a1f4e, #1a1340);
  border: 2px solid rgba(167,139,250,0.4);
  border-radius: 20px; padding: 30px 36px;
  animation: bkIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes bkIn {
  from { transform: scale(0.5) translateY(40px); opacity: 0; }
  to { transform: scale(1) translateY(0); opacity: 1; }
}
.bk-title {
  font-size: 24px; font-weight: 900; color: #fbbf24;
  letter-spacing: 4px; margin-bottom: 16px;
}
.bk-icon { font-size: 56px; margin-bottom: 12px; animation: bkPulse 1s ease-in-out infinite; }
@keyframes bkPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}
.bk-from { font-size: 16px; color: rgba(255,255,255,0.5); font-weight: 600; }
.bk-arrow { font-size: 24px; color: #a78bfa; margin: 8px 0; }
.bk-to { font-size: 22px; color: #fff; font-weight: 900; letter-spacing: 2px; }
.bk-desc { font-size: 12px; color: rgba(255,255,255,0.4); margin: 12px 0 20px; }
.bk-btn {
  padding: 12px 40px;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border-radius: 10px; font-size: 15px; font-weight: 800; color: #fff;
  box-shadow: 0 4px 12px rgba(245,158,11,0.3);
}
.bk-btn:active { transform: scale(0.95); }
