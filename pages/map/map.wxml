<view class="page" style="background:{{realmInfo.realm.bg}};">

  <!-- ===== 境界主页 (idle) ===== -->
  <view class="main-view" wx:if="{{state === 'idle'}}">

    <!-- 顶栏 -->
    <view class="top-bar">
      <text class="top-date">{{dateStr}}</text>
      <view class="top-countdown">
        <text class="cd-num">{{daysLeft}}</text>
        <text class="cd-label">天后高考</text>
      </view>
    </view>

    <!-- 修行天数 -->
    <view class="cult-days">
      <text>修行第 {{cultDays}} 天</text>
      <text class="cult-lv">Lv.{{level}}</text>
    </view>

    <!-- 境界面板 -->
    <view class="realm-panel">
      <view class="realm-glow" style="background:radial-gradient(circle, {{realmInfo.realm.color}}33 0%, transparent 70%);"></view>
      <!-- 灵气粒子 -->
      <view class="sp-particle p1" style="background:{{realmInfo.realm.color}};"></view>
      <view class="sp-particle p2" style="background:{{realmInfo.realm.color}};"></view>
      <view class="sp-particle p3" style="background:{{realmInfo.realm.color}};"></view>
      <view class="sp-particle p4" style="background:{{realmInfo.realm.color}};"></view>
      <view class="sp-particle p5" style="background:{{realmInfo.realm.color}};"></view>
      <view class="sp-particle p6" style="background:{{realmInfo.realm.color}};"></view>
      <text class="realm-icon realm-breathe">{{realmInfo.realm.icon}}</text>
      <view class="realm-ring" style="border-color:{{realmInfo.realm.color}}44;"></view>
      <text class="realm-name">{{realmInfo.realm.name}}</text>
      <text class="realm-stage">{{realmInfo.stage.name}}</text>
    </view>

    <!-- 进度条 -->
    <view class="progress-section">
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{realmInfo.progress * 100}}%; background:{{realmInfo.realm.color}};"></view>
      </view>
      <view class="progress-info">
        <text class="prog-current">{{totalCultivation}} 修为</text>
        <text class="prog-next">{{realmInfo.isMax ? '大圆满' : realmInfo.nextThreshold + ' 突破'}}</text>
      </view>
    </view>

    <!-- 连续打卡 -->
    <view class="streak-row" wx:if="{{char.streakDays > 0}}">
      <text class="streak-fire">{{emFire}}</text>
      <text class="streak-text">连续修行 {{char.streakDays}} 天</text>
    </view>

    <!-- 每日修行入口 -->
    <view class="practice-section" wx:if="{{!todayDone}}">
      <text class="section-title">每日修行</text>
      <text class="section-sub">选择科目，答题获得修为</text>

      <!-- 科目选择 -->
      <view class="subject-grid">
        <view wx:for="{{subjects}}" wx:key="id"
          class="subject-btn {{selectedSubject === item.id ? 'subject-active' : ''}}"
          data-id="{{item.id}}" bindtap="selectSubject"
          style="{{selectedSubject === item.id ? 'border-color:' + realmInfo.realm.color : ''}}">
          <text class="subj-icon">{{item.icon}}</text>
          <text class="subj-name">{{item.name}}</text>
        </view>
      </view>

      <view class="start-btn {{selectedSubject ? 'start-ready' : ''}}" bindtap="startPractice">
        <text>开始修行</text>
      </view>
    </view>

    <!-- 今日已完成 -->
    <view class="done-section" wx:if="{{todayDone}}">
      <view class="done-card">
        <text class="done-icon">{{emCheck}}</text>
        <text class="done-title">今日修行完成</text>
        <text class="done-detail">明天继续，道心坚定</text>
      </view>
    </view>

    <!-- 境界总览(底部) -->
    <view class="realm-timeline">
      <view wx:for="{{9}}" wx:for-item="r" wx:for-index="ri" wx:key="ri"
        class="tl-dot {{ri < realmInfo.realmIdx ? 'tl-done' : ri === realmInfo.realmIdx ? 'tl-cur' : 'tl-lock'}}">
      </view>
      <view class="tl-line">
        <view class="tl-line-fill" style="width:{{(realmInfo.realmIdx / 8) * 100}}%;"></view>
      </view>
    </view>

  </view>

  <!-- ===== 答题界面 (practice) ===== -->
  <view class="practice-view" wx:if="{{state === 'practice'}}">
    <view class="practice-header">
      <text class="prac-counter">第 {{qIdx + 1}} / {{questions.length}} 题</text>
      <view class="prac-dots">
        <view wx:for="{{results}}" wx:key="index"
          class="prac-dot {{item === 'correct' ? 'dot-ok' : item === 'wrong' ? 'dot-no' : qIdx === index ? 'dot-cur' : ''}}"></view>
      </view>
    </view>

    <view class="practice-body" wx:if="{{questions[qIdx]}}">
      <text class="prac-q">{{questions[qIdx].q}}</text>

      <view class="prac-options">
        <view wx:for="{{questions[qIdx].options}}" wx:key="index"
          class="prac-opt {{showResult && results[qIdx] === 'correct' && index === questions[qIdx].answer ? 'opt-correct' : ''}} {{showResult && selectedOption === index && results[qIdx] === 'wrong' ? 'opt-wrong' : ''}}"
          data-index="{{index}}" bindtap="selectOption">
          <text class="prac-opt-label">{{index === 0 ? 'A' : index === 1 ? 'B' : index === 2 ? 'C' : 'D'}}</text>
          <text class="prac-opt-text">{{item}}</text>
        </view>
      </view>

      <view class="prac-explain" wx:if="{{showResult}}">
        <text class="{{results[qIdx] === 'correct' ? 'explain-ok' : 'explain-fail'}}">
          {{results[qIdx] === 'correct' ? '正确! +3修为' : '答错了，继续加油'}}
        </text>
        <text class="explain-detail">{{questions[qIdx].explain}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 结果界面 (result) ===== -->
  <view class="result-view" wx:if="{{state === 'result'}}">
    <view class="result-card">
      <text class="result-icon">{{resultIcon}}</text>
      <text class="result-title">修行完成</text>

      <view class="result-stats">
        <view class="stat-row">
          <text class="stat-label">答对</text>
          <text class="stat-value">{{todayCorrect}} / {{todayTotal}}</text>
        </view>
        <view class="stat-row">
          <text class="stat-label">获得修为</text>
          <text class="stat-value stat-xp">+{{todayXP}}</text>
        </view>
        <view class="stat-row" wx:if="{{todayCorrect === todayTotal}}">
          <text class="stat-label">全对奖励</text>
          <text class="stat-value stat-perfect">+10 修为</text>
        </view>
      </view>

      <!-- 更新后境界 -->
      <view class="result-realm">
        <text class="rr-icon">{{realmInfo.realm.icon}}</text>
        <text class="rr-name">{{realmInfo.realm.name}} {{realmInfo.stage.name}}</text>
      </view>

      <view class="result-btn" bindtap="backToIdle">
        <text>继续修行</text>
      </view>
    </view>
  </view>

  <!-- ===== 突破弹窗 (升级版) ===== -->
  <view class="bk-overlay {{breakthroughInfo.type === 'realm' ? 'bk-realm-break' : ''}}" wx:if="{{showBreakthrough}}">
    <view class="bk-bg" bindtap="closeBreakthrough"></view>
    <!-- 灵气漩涡 -->
    <view class="bk-vortex" style="border-color:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-vortex bk-vortex2" style="border-color:{{breakthroughInfo.newRealm.color}}88;"></view>
    <!-- 爆发粒子 -->
    <view class="bk-burst b1" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-burst b2" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-burst b3" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-burst b4" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-burst b5" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-burst b6" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-burst b7" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <view class="bk-burst b8" style="background:{{breakthroughInfo.newRealm.color}};"></view>
    <!-- 内容 -->
    <view class="bk-panel">
      <text class="bk-title">境界突破!</text>
      <text class="bk-icon bk-icon-emerge">{{breakthroughInfo.newRealm.icon}}</text>
      <text class="bk-from">{{breakthroughInfo.from}}</text>
      <text class="bk-arrow">{{emArrow}}</text>
      <text class="bk-to">{{breakthroughInfo.to}}</text>
      <text class="bk-desc">{{breakthroughInfo.newRealm.desc}}</text>
      <view class="bk-btn" bindtap="closeBreakthrough">
        <text>太好了!</text>
      </view>
    </view>
  </view>

</view>
