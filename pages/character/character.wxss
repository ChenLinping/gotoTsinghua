/* ========================================== */
/* 清北修仙传 - 储物袋 */
/* ========================================== */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #1a1340 50%, #0f0c29 100%);
  padding: 16px;
  box-sizing: border-box;
}

/* ===== Header ===== */
.bag-header {
  position: relative;
  display: flex; align-items: center; gap: 14px;
  padding: 18px 16px;
  background: rgba(0,0,0,0.3); border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.08);
  margin-bottom: 16px; overflow: hidden;
}
.bag-glow {
  position: absolute; top: -30px; right: -20px;
  width: 120px; height: 120px; pointer-events: none;
}
.bag-avatar {
  width: 52px; height: 52px; border-radius: 50%;
  background: rgba(255,255,255,0.06);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; position: relative; z-index: 1;
  border: 2px solid rgba(255,255,255,0.1);
}
.bag-icon { font-size: 28px; }
.bag-info { display: flex; flex-direction: column; gap: 2px; position: relative; z-index: 1; }
.bag-name { font-size: 18px; font-weight: 900; color: #fff; letter-spacing: 1px; }
.bag-realm { font-size: 13px; font-weight: 700; }
.bag-xp { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }

/* ===== Section ===== */
.bag-section {
  background: rgba(0,0,0,0.25); border-radius: 14px;
  padding: 14px; margin-bottom: 12px;
  border: 1px solid rgba(255,255,255,0.06);
}
.sec-title {
  display: flex; align-items: center; gap: 6px;
  margin-bottom: 12px;
  font-size: 14px; font-weight: 800; color: #fff;
}
.sec-icon { font-size: 16px; }
.sec-count {
  margin-left: auto;
  font-size: 11px; font-weight: 600;
  color: rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.06);
  padding: 2px 8px; border-radius: 10px;
}

/* ===== Reward Grid ===== */
.reward-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}
.reward-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 12px 8px; border-radius: 12px;
  border: 1.5px solid rgba(255,255,255,0.06);
  transition: all 0.2s; position: relative;
}
.reward-earned {
  background: rgba(255,255,255,0.05);
  border-color: rgba(255,255,255,0.12);
}
.reward-locked {
  background: rgba(0,0,0,0.2);
  opacity: 0.45;
}

/* Rarity borders */
.rarity-common.reward-earned { border-color: rgba(148,163,184,0.3); }
.rarity-rare.reward-earned { border-color: rgba(96,165,250,0.4); box-shadow: 0 0 8px rgba(96,165,250,0.1); }
.rarity-epic.reward-earned { border-color: rgba(167,139,250,0.4); box-shadow: 0 0 8px rgba(167,139,250,0.15); }
.rarity-legendary.reward-earned { border-color: rgba(251,191,36,0.4); box-shadow: 0 0 12px rgba(251,191,36,0.15); }

/* Reward content */
.rw-icon { font-size: 24px; margin-bottom: 4px; }
.rw-name {
  font-size: 12px; font-weight: 700; color: #e2e8f0;
  text-align: center; line-height: 1.3;
}
.rw-desc {
  font-size: 10px; color: rgba(255,255,255,0.35);
  text-align: center; margin-top: 3px; line-height: 1.3;
}

/* Rarity tag */
.rw-rarity {
  font-size: 9px; font-weight: 700;
  padding: 1px 6px; border-radius: 6px;
  margin-top: 5px;
}
.rarity-tag-common { background: rgba(148,163,184,0.15); color: #94a3b8; }
.rarity-tag-rare { background: rgba(96,165,250,0.15); color: #60a5fa; }
.rarity-tag-epic { background: rgba(167,139,250,0.15); color: #a78bfa; }
.rarity-tag-legendary { background: rgba(251,191,36,0.15); color: #fbbf24; }

/* Progress bar (for subject medals) */
.rw-progress {
  width: 80%; height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 2px; margin-top: 6px;
  overflow: hidden;
}
.rw-progress-fill {
  height: 100%; border-radius: 2px;
  background: #6366f1;
  transition: width 0.3s;
}
