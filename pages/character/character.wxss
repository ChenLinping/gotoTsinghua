/* ========================================== */
/* 清北修仙传 - 修行统计页 */
/* ========================================== */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #1a1340 40%, #0f0c29 100%);
  padding: 16px 16px 0;
}

/* ===== 角色卡片 ===== */
.hero-card {
  position: relative;
  background: rgba(0,0,0,0.3);
  border-radius: 18px;
  padding: 24px 20px;
  margin-bottom: 14px;
  border: 1px solid rgba(255,255,255,0.08);
  overflow: hidden;
}
.hero-glow {
  position: absolute; top: -40px; right: -30px;
  width: 140px; height: 140px; border-radius: 50%;
  pointer-events: none;
}
.hero-content {
  display: flex; align-items: center;
  position: relative; z-index: 1;
}
.hero-icon {
  font-size: 52px; margin-right: 16px;
  width: 70px; height: 70px; line-height: 70px;
  text-align: center;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.1);
}
.hero-info { flex: 1; }
.hero-name {
  font-size: 20px; font-weight: 900; color: #fff;
  display: block; margin-bottom: 4px;
}
.hero-realm {
  font-size: 14px; font-weight: 700;
  display: block; margin-bottom: 2px;
}
.hero-lv {
  font-size: 11px; color: rgba(255,255,255,0.4);
}

/* ===== 通用面板 ===== */
.panel {
  background: rgba(0,0,0,0.25);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid rgba(255,255,255,0.06);
}
.panel-title {
  display: flex; align-items: center;
  font-size: 14px; font-weight: 800; color: rgba(255,255,255,0.8);
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.panel-icon {
  font-size: 16px; margin-right: 6px;
}

/* ===== 修行概览 ===== */
.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
.overview-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 12px 4px;
  background: rgba(255,255,255,0.03);
  border-radius: 12px;
}
.overview-item.highlight {
  background: rgba(251,191,36,0.08);
  border: 1px solid rgba(251,191,36,0.15);
}
.ov-num {
  font-size: 22px; font-weight: 900; color: #fff;
  margin-bottom: 2px;
}
.fire-color { color: #fbbf24; }
.ov-label {
  font-size: 10px; color: rgba(255,255,255,0.4);
}

/* ===== 答题统计 ===== */
.answer-summary {
  display: flex; align-items: center;
}
.answer-big {
  display: flex; flex-direction: column; align-items: center;
  width: 110px; flex-shrink: 0;
  padding-right: 16px;
  border-right: 1px solid rgba(255,255,255,0.06);
}
.answer-rate {
  font-size: 36px; font-weight: 900; color: #4ade80;
}
.answer-rate-label {
  font-size: 11px; color: rgba(255,255,255,0.4);
}
.answer-detail {
  flex: 1; padding-left: 16px;
  display: flex; flex-direction: column; gap: 8px;
}
.ad-row {
  display: flex; align-items: center;
}
.ad-dot {
  width: 8px; height: 8px; border-radius: 50%;
  margin-right: 8px; flex-shrink: 0;
}
.correct-dot { background: #4ade80; }
.wrong-dot { background: #f87171; }
.total-dot { background: #a78bfa; }
.ad-text {
  font-size: 12px; color: rgba(255,255,255,0.5);
  width: 36px;
}
.ad-num {
  font-size: 16px; font-weight: 800; color: #fff;
  margin-left: auto;
}

/* ===== 科目分布 ===== */
.subject-list {
  display: flex; flex-direction: column; gap: 8px;
}
.subject-row {
  display: flex; align-items: center;
}
.subj-name {
  font-size: 12px; color: rgba(255,255,255,0.6);
  width: 36px; flex-shrink: 0;
}
.subj-bar-wrap {
  flex: 1; height: 8px;
  background: rgba(255,255,255,0.05);
  border-radius: 4px; overflow: hidden;
  margin: 0 8px;
}
.subj-bar {
  height: 100%; border-radius: 4px;
  background: linear-gradient(90deg, #6366f1, #a78bfa);
  transition: width 0.5s ease;
}
.subj-count {
  font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.8);
  width: 28px; text-align: right; flex-shrink: 0;
}

/* ===== 境界时间线 ===== */
.realm-timeline { padding: 4px 0; }
.tl-track {
  position: relative;
  display: flex; justify-content: space-between;
  align-items: center;
  padding: 0 4px;
  margin-bottom: 10px;
}
.tl-line-bg {
  position: absolute; top: 50%; left: 16px; right: 16px;
  height: 3px; background: rgba(255,255,255,0.08);
  transform: translateY(-50%); z-index: 0;
  border-radius: 2px;
}
.tl-line-fill {
  height: 100%; border-radius: 2px;
  background: #4ade80;
  transition: width 0.5s ease;
}
.tl-node {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  z-index: 1; position: relative;
  border: 2px solid rgba(255,255,255,0.15);
  background: rgba(0,0,0,0.4);
}
.tl-done {
  background: #4ade80;
  border-color: #22c55e;
}
.tl-cur {
  border-width: 3px;
  box-shadow: 0 0 10px rgba(167,139,250,0.4);
}
.tl-icon { font-size: 14px; }
.tl-labels {
  display: flex; justify-content: space-between;
  padding: 0 0;
}
.tl-label {
  font-size: 9px; color: rgba(255,255,255,0.25);
  width: 36px; text-align: center;
}
.tl-label-done { color: #4ade80; }
.tl-label-cur { color: #a78bfa; font-weight: 700; }
