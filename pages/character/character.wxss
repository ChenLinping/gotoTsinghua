/* ========== 页面背景 ========== */
.page-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #1e1b4b 0%, #312e81 30%, #1e1b4b 100%);
  padding: 24rpx 24rpx 0;
}

/* ========== 顶部角色卡片 ========== */
.hero-card {
  position: relative;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.4) 0%, rgba(139, 92, 246, 0.3) 100%);
  border-radius: 28rpx;
  padding: 48rpx 32rpx 40rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  border: 2rpx solid rgba(139, 92, 246, 0.4);
}

.hero-glow {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(168, 85, 247, 0.4) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-content {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar-wrap {
  position: relative;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar-emoji {
  font-size: 100rpx;
  display: block;
  width: 130rpx;
  height: 130rpx;
  line-height: 130rpx;
  text-align: center;
  background: rgba(30, 27, 75, 0.5);
  border-radius: 50%;
  border: 3rpx solid rgba(168, 85, 247, 0.6);
}

.rank-badge {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(30, 27, 75, 0.8);
}

.rank-emoji {
  font-size: 22rpx;
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.hero-name {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.rank-title {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.next-rank {
  font-size: 20rpx;
  opacity: 0.6;
  margin-left: 4rpx;
}

.level-row {
  display: flex;
  align-items: center;
}

.level-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #c4b5fd;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.xp-bar-wrap {
  flex: 1;
  height: 14rpx;
  background: rgba(30, 27, 75, 0.6);
  border-radius: 7rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.xp-bar {
  height: 100%;
  background: linear-gradient(90deg, #a78bfa, #c084fc);
  border-radius: 7rpx;
  transition: width 0.5s ease;
  box-shadow: 0 0 8rpx rgba(167, 139, 250, 0.5);
}

.xp-text {
  font-size: 20rpx;
  color: #a5b4fc;
  flex-shrink: 0;
}

/* ========== 通用面板 ========== */
.panel {
  background: rgba(30, 27, 75, 0.6);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.25);
  backdrop-filter: blur(10px);
}

.panel-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #e0e7ff;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid rgba(99, 102, 241, 0.2);
}

.panel-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

/* ========== 属性面板 ========== */
.stat-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #c4b5fd;
  width: 90rpx;
  flex-shrink: 0;
}

.hp-bar-outer {
  flex: 1;
  height: 20rpx;
  background: rgba(15, 12, 50, 0.6);
  border-radius: 10rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.hp-bar-inner {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.hp-high {
  background: linear-gradient(90deg, #22c55e, #4ade80);
  box-shadow: 0 0 10rpx rgba(34, 197, 94, 0.4);
}

.hp-mid {
  background: linear-gradient(90deg, #f59e0b, #fbbf24);
  box-shadow: 0 0 10rpx rgba(245, 158, 11, 0.4);
}

.hp-low {
  background: linear-gradient(90deg, #ef4444, #f87171);
  box-shadow: 0 0 10rpx rgba(239, 68, 68, 0.4);
}

.stat-value {
  font-size: 22rpx;
  color: #a5b4fc;
  flex-shrink: 0;
  min-width: 100rpx;
  text-align: right;
}

.stat-grid {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 16rpx 0;
  background: rgba(15, 12, 50, 0.4);
  border-radius: 16rpx;
  margin: 0 6rpx;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 2rpx;
}

.stat-name {
  font-size: 20rpx;
  color: #94a3b8;
}

.bonus-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  padding: 10rpx;
  background: rgba(168, 85, 247, 0.15);
  border-radius: 12rpx;
}

.bonus-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.bonus-text {
  font-size: 24rpx;
  color: #c084fc;
  font-weight: 600;
}

/* ========== 装备面板 ========== */
.equip-slots {
  display: flex;
  justify-content: space-between;
}

.equip-slot {
  flex: 1;
  margin: 0 8rpx;
  background: rgba(15, 12, 50, 0.5);
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 3rpx solid #475569;
  min-height: 200rpx;
  position: relative;
}

.slot-type {
  font-size: 20rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.slot-emoji {
  font-size: 52rpx;
  margin-bottom: 10rpx;
}

.slot-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #e2e8f0;
  text-align: center;
  margin-bottom: 6rpx;
}

.slot-stat {
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.slot-rarity {
  font-size: 18rpx;
  color: #fff;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.slot-empty {
  font-size: 28rpx;
  color: #475569;
  margin-top: 30rpx;
}

/* ========== 成就面板 ========== */
.achieve-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -6rpx;
}

.achieve-item {
  width: calc(33.33% - 12rpx);
  margin: 6rpx;
  background: rgba(15, 12, 50, 0.4);
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.achieve-item.unlocked {
  background: rgba(99, 102, 241, 0.2);
  border: 2rpx solid rgba(139, 92, 246, 0.4);
}

.achieve-item.locked {
  opacity: 0.45;
}

.achieve-emoji {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.achieve-item.locked .achieve-emoji {
  filter: grayscale(100%);
}

.achieve-name {
  font-size: 22rpx;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 4rpx;
}

.achieve-desc {
  font-size: 18rpx;
  color: #94a3b8;
  line-height: 1.3;
}

.achieve-lock {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 20rpx;
  opacity: 0.6;
}

/* ========== 战绩面板 ========== */
.record-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-box {
  flex: 1;
  margin: 0 6rpx;
  background: rgba(15, 12, 50, 0.4);
  border-radius: 16rpx;
  padding: 18rpx 8rpx;
  text-align: center;
}

.record-box.boss {
  background: rgba(239, 68, 68, 0.15);
  border: 2rpx solid rgba(239, 68, 68, 0.3);
}

.record-num {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 4rpx;
}

.record-box.boss .record-num {
  color: #f87171;
}

.record-label {
  font-size: 20rpx;
  color: #94a3b8;
}

/* 答题详情 */
.answer-row {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 12, 50, 0.3);
  border-radius: 16rpx;
  padding: 18rpx;
  margin-bottom: 24rpx;
}

.answer-correct,
.answer-wrong {
  flex: 1;
  text-align: center;
}

.answer-num {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
}

.answer-correct .answer-num {
  color: #4ade80;
}

.answer-wrong .answer-num {
  color: #f87171;
}

.answer-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.answer-divider {
  width: 2rpx;
  height: 50rpx;
  background: rgba(99, 102, 241, 0.3);
  margin: 0 20rpx;
}

/* 各科目击杀 */
.subject-kills {
  margin-top: 8rpx;
}

.subject-title {
  font-size: 24rpx;
  color: #a5b4fc;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.subject-list {
  display: flex;
  flex-direction: column;
}

.subject-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.subject-name {
  font-size: 24rpx;
  color: #c4b5fd;
  width: 70rpx;
  flex-shrink: 0;
}

.subject-bar-wrap {
  flex: 1;
  height: 14rpx;
  background: rgba(15, 12, 50, 0.5);
  border-radius: 7rpx;
  overflow: hidden;
  margin: 0 14rpx;
}

.subject-bar {
  height: 100%;
  background: linear-gradient(90deg, #6366f1, #a78bfa);
  border-radius: 7rpx;
  transition: width 0.5s ease;
}

.subject-count {
  font-size: 24rpx;
  color: #e2e8f0;
  font-weight: 700;
  width: 50rpx;
  text-align: right;
  flex-shrink: 0;
}
