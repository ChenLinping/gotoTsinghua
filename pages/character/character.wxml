<view class="page">

  <!-- 角色卡片 -->
  <view class="hero-card">
    <view class="hero-glow" style="background:radial-gradient(circle, {{realmInfo.realm.color}}44 0%, transparent 70%);"></view>
    <view class="hero-content">
      <text class="hero-icon">{{realmInfo.realm.icon}}</text>
      <view class="hero-info">
        <text class="hero-name">{{char.name || '修仙者'}}</text>
        <text class="hero-realm" style="color:{{realmInfo.realm.color}};">{{realmInfo.realm.name}} {{realmInfo.stage.name}}</text>
        <text class="hero-lv">Lv.{{realmInfo.realmIdx * 4 + realmInfo.stageIdx + 1}}</text>
      </view>
    </view>
  </view>

  <!-- 修行概览 -->
  <view class="panel">
    <view class="panel-title">
      <text class="panel-icon">&#9968;</text>
      <text>修行概览</text>
    </view>
    <view class="overview-grid">
      <view class="overview-item">
        <text class="ov-num">{{totalCultivation}}</text>
        <text class="ov-label">总修为</text>
      </view>
      <view class="overview-item">
        <text class="ov-num">{{cultDays}}</text>
        <text class="ov-label">修行天数</text>
      </view>
      <view class="overview-item">
        <text class="ov-num">{{daysLeft}}</text>
        <text class="ov-label">距高考(天)</text>
      </view>
      <view class="overview-item highlight">
        <text class="ov-num fire-color">{{streakDays}}</text>
        <text class="ov-label">连续打卡</text>
      </view>
    </view>
  </view>

  <!-- 答题统计 -->
  <view class="panel">
    <view class="panel-title">
      <text class="panel-icon">&#128202;</text>
      <text>答题统计</text>
    </view>

    <view class="answer-summary">
      <view class="answer-big">
        <text class="answer-rate">{{correctRate}}%</text>
        <text class="answer-rate-label">正确率</text>
      </view>
      <view class="answer-detail">
        <view class="ad-row">
          <text class="ad-dot correct-dot"></text>
          <text class="ad-text">答对</text>
          <text class="ad-num">{{correctCount}}</text>
        </view>
        <view class="ad-row">
          <text class="ad-dot wrong-dot"></text>
          <text class="ad-text">答错</text>
          <text class="ad-num">{{wrongCount}}</text>
        </view>
        <view class="ad-row">
          <text class="ad-dot total-dot"></text>
          <text class="ad-text">总计</text>
          <text class="ad-num">{{totalAnswers}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 科目分布 -->
  <view class="panel">
    <view class="panel-title">
      <text class="panel-icon">&#128218;</text>
      <text>科目分布</text>
    </view>
    <view class="subject-list">
      <view class="subject-row" wx:for="{{subjectStats}}" wx:key="key">
        <text class="subj-name">{{item.name}}</text>
        <view class="subj-bar-wrap">
          <view class="subj-bar" style="width:{{item.count > 0 ? (item.count / maxSubjectCount * 100) : 0}}%; min-width:{{item.count > 0 ? '6px' : '0'}};"></view>
        </view>
        <text class="subj-count">{{item.count}}</text>
      </view>
    </view>
  </view>

  <!-- 境界历程 -->
  <view class="panel">
    <view class="panel-title">
      <text class="panel-icon">&#127793;</text>
      <text>境界历程</text>
    </view>
    <view class="realm-timeline">
      <view class="tl-track">
        <view class="tl-line-bg">
          <view class="tl-line-fill" style="width:{{realmIdx / 4 * 100}}%;"></view>
        </view>
        <view wx:for="{{realms}}" wx:key="name"
          class="tl-node {{index < realmIdx ? 'tl-done' : index === realmIdx ? 'tl-cur' : 'tl-lock'}}"
          style="{{index === realmIdx ? 'border-color:' + item.color : index < realmIdx ? 'border-color:#4ade80; background:#4ade80;' : ''}}">
          <text class="tl-icon">{{item.icon}}</text>
        </view>
      </view>
      <view class="tl-labels">
        <text wx:for="{{realms}}" wx:key="name" class="tl-label {{index === realmIdx ? 'tl-label-cur' : index < realmIdx ? 'tl-label-done' : ''}}">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view style="height:80px;"></view>

</view>
