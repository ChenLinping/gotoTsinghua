<view class="page">

  <!-- 角色信息卡 -->
  <view class="bag-header">
    <view class="bag-glow" style="background:radial-gradient(circle, {{realmColor}}33 0%, transparent 70%);"></view>
    <view class="bag-avatar">
      <image class="char-portrait" src="{{charImg}}" mode="aspectFit" />
    </view>
    <view class="bag-info">
      <text class="bag-name">{{char.name || '修仙者'}}</text>
      <text class="bag-realm" style="color:{{realmColor}};">{{realmName}} {{stageName}}</text>
      <text class="bag-xp">{{totalCultivation}} 修为 · 答对 {{totalCorrect}} 题</text>
    </view>
  </view>

  <!-- 装备展示 -->
  <view class="bag-section">
    <view class="section-header">
      <text class="section-title">{{'\u6CD5\u5B9D\u88C5\u5907'}}</text>
      <text class="section-count">{{equipOwnedCount}} / {{equipList.length}}</text>
    </view>
    <view class="equip-grid">
      <view wx:for="{{equipList}}" wx:key="id" class="equip-card rarity-{{item.rarity}} {{item.owned ? 'card-owned' : 'card-locked'}}">
        <image wx:if="{{item.owned}}" class="equip-card-img" src="{{item.img}}" mode="aspectFit" />
        <view wx:if="{{!item.owned}}" class="equip-card-lock">
          <text>{{'\uD83D\uDD12'}}</text>
        </view>
        <text class="equip-card-name">{{item.name}}</text>
        <text class="equip-card-realm">{{item.realmName}}</text>
        <text class="equip-card-rarity">{{item.rarity === 'common' ? '\u666E\u901A' : item.rarity === 'rare' ? '\u7A00\u6709' : item.rarity === 'epic' ? '\u53F2\u8BD7' : '\u4F20\u8BF4'}}</text>
      </view>
    </view>
  </view>

  <!-- 境界突破奖状 -->
  <view class="bag-section">
    <view class="sec-title">
      <text class="sec-icon">📜</text>
      <text>境界突破奖状</text>
      <text class="sec-count">{{earnedRealm}}/{{realmCerts.length}}</text>
    </view>
    <view class="reward-grid">
      <view wx:for="{{realmCerts}}" wx:key="id"
        class="reward-card {{item.earned ? 'reward-earned' : 'reward-locked'}} rarity-{{item.rarity}}">
        <text class="rw-icon">{{item.earned ? item.icon : '🔒'}}</text>
        <text class="rw-name">{{item.name}}</text>
        <text class="rw-desc">{{item.desc}}</text>
        <text wx:if="{{item.earned}}" class="rw-rarity rarity-tag-{{item.rarity}}">{{item.rarity === 'common' ? '普通' : item.rarity === 'rare' ? '稀有' : item.rarity === 'epic' ? '史诗' : '传说'}}</text>
      </view>
    </view>
  </view>

  <!-- 修行成就 -->
  <view class="bag-section">
    <view class="sec-title">
      <text class="sec-icon">🏆</text>
      <text>修行成就</text>
      <text class="sec-count">{{earnedCult}}/{{cultAchievements.length}}</text>
    </view>
    <view class="reward-grid">
      <view wx:for="{{cultAchievements}}" wx:key="id"
        class="reward-card {{item.earned ? 'reward-earned' : 'reward-locked'}} rarity-{{item.rarity}}">
        <text class="rw-icon">{{item.earned ? item.icon : '🔒'}}</text>
        <text class="rw-name">{{item.name}}</text>
        <text class="rw-desc">{{item.desc}}</text>
        <text wx:if="{{item.earned}}" class="rw-rarity rarity-tag-{{item.rarity}}">{{item.rarity === 'common' ? '普通' : item.rarity === 'rare' ? '稀有' : item.rarity === 'epic' ? '史诗' : '传说'}}</text>
      </view>
    </view>
  </view>

  <!-- 答题勋章 -->
  <view class="bag-section">
    <view class="sec-title">
      <text class="sec-icon">🎖️</text>
      <text>答题勋章</text>
      <text class="sec-count">{{earnedAnswer}}/{{answerRecords.length}}</text>
    </view>
    <view class="reward-grid">
      <view wx:for="{{answerRecords}}" wx:key="id"
        class="reward-card {{item.earned ? 'reward-earned' : 'reward-locked'}} rarity-{{item.rarity}}">
        <text class="rw-icon">{{item.earned ? item.icon : '🔒'}}</text>
        <text class="rw-name">{{item.name}}</text>
        <text class="rw-desc">{{item.desc}}</text>
        <text wx:if="{{item.earned}}" class="rw-rarity rarity-tag-{{item.rarity}}">{{item.rarity === 'common' ? '普通' : item.rarity === 'rare' ? '稀有' : item.rarity === 'epic' ? '史诗' : '传说'}}</text>
      </view>
    </view>
  </view>

  <!-- 科目奖牌 -->
  <view class="bag-section">
    <view class="sec-title">
      <text class="sec-icon">🥇</text>
      <text>科目奖牌</text>
      <text class="sec-count">{{earnedSubject}}/{{subjectMedals.length}}</text>
    </view>
    <view class="reward-grid">
      <view wx:for="{{subjectMedals}}" wx:key="id"
        class="reward-card {{item.earned ? 'reward-earned' : 'reward-locked'}} rarity-{{item.rarity}}">
        <text class="rw-icon">{{item.earned ? item.icon : '🔒'}}</text>
        <text class="rw-name">{{item.name}}</text>
        <text class="rw-desc">{{item.desc}}</text>
        <view wx:if="{{!item.earned}}" class="rw-progress">
          <view class="rw-progress-fill" style="width:{{item.progress * 100}}%;"></view>
        </view>
        <text wx:if="{{item.earned}}" class="rw-rarity rarity-tag-{{item.rarity}}">稀有</text>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view style="height:80px;"></view>

</view>
