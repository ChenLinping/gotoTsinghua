/* ========================================== */
/* 走向清华 V2 - 战斗页面 (Minecraft风格) */
/* ========================================== */

/* ===== Page ===== */
.mc-battle {
  min-height: 100vh;
  background: #87ceeb;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 39rpx, rgba(0,0,0,0.02) 39rpx, rgba(0,0,0,0.02) 40rpx),
    repeating-linear-gradient(90deg, transparent, transparent 39rpx, rgba(0,0,0,0.02) 39rpx, rgba(0,0,0,0.02) 40rpx);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.mc-text {
  letter-spacing: 4rpx;
  text-shadow: 3rpx 3rpx 0 rgba(0,0,0,0.5);
}

/* ===== Sky ===== */
.mc-sky {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  pointer-events: none;
  z-index: 0;
}

.mc-cloud {
  position: absolute;
  font-size: 48rpx;
  opacity: 0.6;
}

.mc-cloud-1 {
  left: 10%;
  top: 20rpx;
  animation: mc-cloud-drift 20s linear infinite;
}

.mc-cloud-2 {
  left: 60%;
  top: 40rpx;
  animation: mc-cloud-drift 25s linear infinite;
  animation-delay: -8s;
}

@keyframes mc-cloud-drift {
  0% { transform: translateX(-100rpx); }
  100% { transform: translateX(800rpx); }
}

/* ===== Battle Field ===== */
.mc-field {
  padding: 24rpx 24rpx 16rpx;
  position: relative;
  background: linear-gradient(180deg, transparent 0%, transparent 60%, #5b8c3e 60%, #4a7a30 100%);
}

/* --- Monster --- */
.mc-monster-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 12rpx 0;
}

.monster-info-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.monster-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #2d3436;
  text-shadow: 2rpx 2rpx 0 rgba(255,255,255,0.5);
}

.mc-badge {
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 4rpx;
  font-weight: 600;
  border: 2rpx solid rgba(0,0,0,0.3);
  box-shadow: 0 2rpx 0 rgba(0,0,0,0.2);
}

/* MC Mob block display */
.mc-mob-display {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
}

.mc-mob-block {
  width: 120rpx;
  height: 120rpx;
  position: relative;
  transform-style: preserve-3d;
}

.mc-mob-top {
  position: absolute;
  top: 0;
  left: 12rpx;
  right: 12rpx;
  height: 20rpx;
  background: #6b4423;
  border-radius: 4rpx 4rpx 0 0;
  border: 3rpx solid #4a2f18;
  z-index: 3;
}

.mc-mob-front {
  position: absolute;
  top: 18rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 0;
  background: #8b6b4a;
  border: 3rpx solid #6b4423;
  border-radius: 0 0 4rpx 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.mc-mob-left {
  position: absolute;
  top: 18rpx;
  left: 0;
  width: 16rpx;
  bottom: 0;
  background: #7a5a3a;
  border: 2rpx solid #5a3a1a;
  border-radius: 4rpx 0 0 4rpx;
  z-index: 1;
}

.mc-mob-right {
  position: absolute;
  top: 18rpx;
  right: 0;
  width: 16rpx;
  bottom: 0;
  background: #6b4a2a;
  border: 2rpx solid #4a2a0a;
  border-radius: 0 4rpx 4rpx 0;
  z-index: 1;
}

.monster-emoji {
  font-size: 72rpx;
  line-height: 1;
}

/* --- HP Bars (像素风) --- */
.mc-hp-bar-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 100%;
  padding: 0 20rpx;
}

.mc-hp-bar {
  flex: 1;
  height: 20rpx;
  background: rgba(0,0,0,0.2);
  border-radius: 4rpx;
  overflow: hidden;
  border: 3rpx solid rgba(0,0,0,0.3);
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.mc-hp-fill {
  height: 100%;
  border-radius: 2rpx;
  transition: width 0.5s ease-out;
  background: linear-gradient(180deg, #ff6b6b 0%, #cc3333 100%);
  box-shadow: inset 0 -2rpx 0 rgba(0,0,0,0.2);
}

.mc-hp-fill-green {
  background: linear-gradient(180deg, #4ade80 0%, #22c55e 100%);
}

.mc-hp-text {
  font-size: 20rpx;
  color: #2d3436;
  white-space: nowrap;
  min-width: 110rpx;
  text-align: right;
  font-weight: 700;
  text-shadow: 1rpx 1rpx 0 rgba(255,255,255,0.5);
}

/* --- VS --- */
.mc-vs-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.mc-vs-block {
  background: #ffd700;
  padding: 8rpx 24rpx;
  border: 4rpx solid #b8960a;
  border-radius: 4rpx;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.3);
}

.mc-vs-text {
  font-size: 40rpx;
  font-weight: 900;
  color: #2d3436;
  text-shadow: 2rpx 2rpx 0 rgba(255,255,255,0.3);
  letter-spacing: 6rpx;
}

.mc-node-label {
  font-size: 22rpx;
  color: #fff;
  background: rgba(0,0,0,0.4);
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  border: 2rpx solid rgba(255,255,255,0.1);
  text-shadow: 1rpx 1rpx 0 rgba(0,0,0,0.4);
}

/* --- Player Section --- */
.mc-player-section {
  padding: 16rpx 20rpx;
  background: rgba(0,0,0,0.15);
  border-radius: 6rpx;
  border: 4rpx solid rgba(0,0,0,0.2);
  position: relative;
}

.mc-player-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

/* Minecraft Steve-style character */
.mc-player-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 72rpx;
}

.mc-steve-head {
  width: 48rpx;
  height: 48rpx;
  background: #c8a87a;
  border: 3rpx solid #8b6b4a;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.mc-steve-face {
  font-size: 28rpx;
}

.mc-steve-body {
  display: flex;
  align-items: stretch;
  height: 40rpx;
  position: relative;
}

.mc-steve-arm {
  width: 14rpx;
  background: #5b8c3e;
  border: 2rpx solid #3d6b28;
}

.mc-steve-arm-l {
  border-radius: 3rpx 0 0 3rpx;
}

.mc-steve-arm-r {
  border-radius: 0 3rpx 3rpx 0;
}

.mc-steve-torso {
  width: 32rpx;
  background: #3b82f6;
  border: 2rpx solid #2563eb;
}

.mc-steve-legs {
  display: flex;
  height: 32rpx;
}

.mc-steve-leg {
  width: 20rpx;
  background: #4a4a8a;
  border: 2rpx solid #333366;
}

.mc-steve-leg-l {
  border-radius: 0 0 3rpx 3rpx;
}

.mc-steve-leg-r {
  border-radius: 0 0 3rpx 3rpx;
}

.mc-player-info {
  flex: 1;
}

.mc-player-lv {
  font-size: 28rpx;
  font-weight: 800;
  color: #2d3436;
  text-shadow: 1rpx 1rpx 0 rgba(255,255,255,0.5);
  margin-bottom: 4rpx;
}

.mc-stats-inline {
  display: flex;
  gap: 20rpx;
}

.mc-stat-atk {
  font-size: 22rpx;
  color: #cc3333;
  font-weight: 700;
  text-shadow: 1rpx 1rpx 0 rgba(255,255,255,0.3);
}

.mc-stat-def {
  font-size: 22rpx;
  color: #3366cc;
  font-weight: 700;
  text-shadow: 1rpx 1rpx 0 rgba(255,255,255,0.3);
}

/* ===== Damage Float ===== */
.mc-damage-float {
  position: absolute;
  left: 50%;
  top: 20rpx;
  transform: translateX(-50%);
  z-index: 20;
  animation: mc-float-up 0.8s ease-out forwards;
}

.mc-damage-num {
  font-size: 40rpx;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 3rpx 3rpx 0 rgba(0,0,0,0.6);
}

.mc-damage-crit .mc-damage-num {
  font-size: 52rpx;
  color: #ff4444;
}

.mc-crit-tag {
  font-size: 22rpx;
  color: #ff4444;
  background: rgba(255,0,0,0.15);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  border: 2rpx solid rgba(255,0,0,0.3);
  margin-right: 8rpx;
}

.mc-damage-player {
  top: -10rpx;
}

.mc-damage-red {
  color: #ff4444 !important;
}

@keyframes mc-float-up {
  0% { opacity: 1; transform: translateX(-50%) translateY(0); }
  60% { opacity: 1; transform: translateX(-50%) translateY(-40rpx); }
  100% { opacity: 0; transform: translateX(-50%) translateY(-80rpx); }
}

/* ===== Animations ===== */
.monster-hit {
  animation: mc-mob-hit 0.4s ease-in-out;
}

@keyframes mc-mob-hit {
  0% { transform: scale(1); }
  30% { transform: scale(0.85); filter: brightness(2); }
  60% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.monster-shake {
  animation: mc-shake 0.4s ease-in-out;
}

@keyframes mc-shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-14rpx); }
  40% { transform: translateX(14rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(8rpx); }
}

.player-shake {
  animation: mc-player-shake 0.5s ease-in-out;
}

@keyframes mc-player-shake {
  0%, 100% { transform: translateX(0); }
  15% { transform: translateX(-10rpx); background: rgba(255,0,0,0.1); }
  30% { transform: translateX(10rpx); }
  45% { transform: translateX(-6rpx); }
  60% { transform: translateX(6rpx); }
}

/* ===== Question Area ===== */
.mc-question-area {
  flex: 1;
  padding: 0 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  background: #4a3728;
  border-top: 6rpx solid #3a2a1a;
}

/* --- Progress --- */
.mc-progress {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 8rpx;
}

.mc-counter {
  font-size: 22rpx;
  color: #d4c4a8;
  font-weight: 600;
}

.mc-progress-dots {
  display: flex;
  gap: 8rpx;
}

.mc-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 2rpx;
  border: 2rpx solid rgba(255,255,255,0.2);
}

.mc-dot-correct { background: #22c55e; border-color: #16a34a; }
.mc-dot-wrong { background: #ef4444; border-color: #dc2626; }
.mc-dot-empty { background: rgba(255,255,255,0.08); }

/* --- Question Card --- */
.mc-question-card {
  background: rgba(0,0,0,0.25);
  border-radius: 6rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 4rpx solid #5a4738;
  min-height: 100rpx;
}

.mc-question-text {
  font-size: 26rpx;
  color: #e8dcc8;
  line-height: 1.7;
  word-break: break-all;
}

/* --- Options --- */
.mc-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.mc-option {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 4rpx;
  border: 4rpx solid #5a4738;
  background: #3a2a1a;
  transition: all 0.15s;
  position: relative;
}

.mc-option:active {
  transform: scale(0.97);
  background: #4a3a2a;
}

.mc-option-correct {
  border-color: #22c55e;
  background: rgba(34, 197, 94, 0.2);
  box-shadow: 0 0 16rpx rgba(34, 197, 94, 0.15);
}

.mc-option-wrong {
  border-color: #ef4444;
  background: rgba(239, 68, 68, 0.2);
  box-shadow: 0 0 16rpx rgba(239, 68, 68, 0.15);
}

.mc-option-normal {
  border-color: #4a3a2a;
  opacity: 0.5;
}

.mc-option-selected {
  transform: scale(0.98);
}

.mc-option-label {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #5a4738;
  border-radius: 4rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #d4c4a8;
  margin-right: 14rpx;
  flex-shrink: 0;
  border: 2rpx solid #6b5848;
}

.mc-option-correct .mc-option-label { background: #22c55e; color: #fff; }
.mc-option-wrong .mc-option-label { background: #ef4444; color: #fff; }

.mc-option-text {
  flex: 1;
  font-size: 24rpx;
  color: #e8dcc8;
  line-height: 1.5;
}

.mc-option-correct .mc-option-text { color: #bbf7d0; }
.mc-option-wrong .mc-option-text { color: #fca5a5; }

.mc-result-icon {
  font-size: 28rpx;
  font-weight: 800;
  margin-left: 10rpx;
  flex-shrink: 0;
}

.mc-result-correct { color: #22c55e; }
.mc-result-wrong { color: #ef4444; }

/* --- Explanation --- */
.mc-explanation {
  background: rgba(0,0,0,0.2);
  border-radius: 6rpx;
  padding: 16rpx 20rpx;
  border: 3rpx solid #5a4738;
}

.mc-exp-header {
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid rgba(255,255,255,0.08);
}

.mc-exp-ok { color: #4ade80; }
.mc-exp-fail { color: #f87171; }

.mc-exp-text {
  font-size: 22rpx;
  color: #a89880;
  line-height: 1.7;
  word-break: break-all;
}

/* ===== Battle Log ===== */
.mc-log-section {
  padding: 0 20rpx 20rpx;
  background: #4a3728;
}

.mc-log-scroll {
  height: 100rpx;
  background: rgba(0,0,0,0.3);
  border-radius: 4rpx;
  padding: 10rpx 14rpx;
  border: 3rpx solid #3a2a1a;
}

.mc-log-entry {
  font-size: 20rpx;
  color: #8b7a68;
  line-height: 1.8;
}

.mc-log-entry:last-child {
  color: #d4c4a8;
}

/* ===== Result Overlay ===== */
.mc-result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.mc-result-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.8);
}

.mc-result-card {
  position: relative;
  width: 620rpx;
  border-radius: 8rpx;
  padding: 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slideUp 0.4s ease;
  border: 6rpx solid;
}

.mc-victory-card {
  background: linear-gradient(180deg, #4a3728 0%, #3a2a1a 100%);
  border-color: #ffd700;
  box-shadow: 0 8rpx 0 rgba(0,0,0,0.3), 0 0 40rpx rgba(255,215,0,0.2);
}

.mc-defeat-card {
  background: linear-gradient(180deg, #3a2a1a 0%, #2a1a0a 100%);
  border-color: #ef4444;
  box-shadow: 0 8rpx 0 rgba(0,0,0,0.3), 0 0 40rpx rgba(239,68,68,0.15);
}

.mc-result-emoji {
  font-size: 72rpx;
  margin-bottom: 8rpx;
}

.mc-result-title {
  font-size: 40rpx;
  font-weight: 900;
  margin-bottom: 24rpx;
}

.mc-victory-title {
  color: #ffd700;
  text-shadow: 3rpx 3rpx 0 rgba(0,0,0,0.5);
}

.mc-defeat-title {
  color: #ef4444;
  text-shadow: 3rpx 3rpx 0 rgba(0,0,0,0.5);
}

.mc-defeat-desc {
  font-size: 24rpx;
  color: #a89880;
  margin-bottom: 24rpx;
}

/* --- Rewards --- */
.mc-rewards {
  width: 100%;
  background: rgba(0,0,0,0.2);
  border-radius: 6rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  border: 3rpx solid #5a4738;
}

.mc-reward-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  gap: 10rpx;
}

.mc-reward-icon { font-size: 28rpx; }
.mc-reward-label { font-size: 24rpx; color: #a89880; flex: 1; }
.mc-reward-value { font-size: 28rpx; font-weight: 800; color: #ffd700; }

/* --- Battle Stats --- */
.mc-battle-stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 20rpx;
}

.mc-stat-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mc-stat-num {
  font-size: 32rpx;
  font-weight: 800;
  color: #e8dcc8;
}

.mc-stat-lbl {
  font-size: 20rpx;
  color: #8b7a68;
  margin-top: 4rpx;
}

.mc-green { color: #4ade80; }
.mc-red { color: #f87171; }

/* --- Level Up --- */
.mc-levelup {
  width: 100%;
  text-align: center;
  padding: 14rpx;
  background: rgba(255,215,0,0.1);
  border-radius: 4rpx;
  border: 3rpx solid rgba(255,215,0,0.3);
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #ffd700;
}

/* --- Achievements --- */
.mc-achievements {
  width: 100%;
  margin-bottom: 16rpx;
}

.mc-ach-title {
  font-size: 24rpx;
  color: #d4c4a8;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.mc-ach-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 14rpx;
  background: rgba(255,215,0,0.08);
  border-radius: 4rpx;
  margin-bottom: 6rpx;
  border: 2rpx solid rgba(255,215,0,0.15);
}

.mc-ach-emoji { font-size: 28rpx; }
.mc-ach-name { font-size: 24rpx; color: #ffd700; font-weight: 600; }

/* --- Bonus --- */
.mc-bonus {
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: #a78bfa;
  padding: 8rpx;
  background: rgba(167,139,250,0.08);
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

/* ===== MC Buttons ===== */
.mc-btn {
  width: 100%;
  text-align: center;
  padding: 20rpx;
  border-radius: 4rpx;
  margin-top: 10rpx;
  border: 4rpx solid;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.3);
}

.mc-btn:active {
  transform: translateY(3rpx);
  box-shadow: 0 1rpx 0 rgba(0,0,0,0.3);
}

.mc-btn-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.4);
}

.mc-btn-green {
  background: linear-gradient(180deg, #5b8c3e 0%, #3d6b28 100%);
  border-color: #7ab356;
}

.mc-btn-red {
  background: linear-gradient(180deg, #cc3333 0%, #aa1111 100%);
  border-color: #ee5555;
}

.mc-btn-gray {
  background: linear-gradient(180deg, #5a4738 0%, #3a2a1a 100%);
  border-color: #6b5848;
}

/* ===== Keyframes ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(60rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
