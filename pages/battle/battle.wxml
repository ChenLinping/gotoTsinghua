<!-- ========================================== -->
<!-- 走向清华 V2 - 战斗页面 (Minecraft风格) -->
<!-- ========================================== -->
<view class="battle-page mc-battle">

  <!-- ====== Battle Field (Top Half) ====== -->
  <view class="battle-field mc-field">

    <!-- 天空/背景装饰 -->
    <view class="mc-sky">
      <view class="mc-cloud mc-cloud-1">☁️</view>
      <view class="mc-cloud mc-cloud-2">☁️</view>
    </view>

    <!-- Monster Section -->
    <view class="monster-section mc-monster-section">
      <view class="monster-info-row">
        <view class="monster-name mc-text">{{monster.name}}</view>
        <view class="type-badge mc-badge" style="background:{{monster.color}}">{{monster.typeName}}</view>
      </view>

      <!-- 怪物像素方块 -->
      <view class="mc-mob-display {{isAttacking ? 'monster-hit' : ''}} {{isMonsterDamaged ? 'monster-shake' : ''}}">
        <view class="mc-mob-block">
          <view class="mc-mob-top"></view>
          <view class="mc-mob-front">
            <text class="monster-emoji">{{monster.emoji}}</text>
          </view>
          <view class="mc-mob-left"></view>
          <view class="mc-mob-right"></view>
        </view>
      </view>

      <!-- Floating damage on monster -->
      <view wx:if="{{showPlayerDamage}}" class="mc-damage-float {{showCrit ? 'mc-damage-crit' : ''}}">
        <text wx:if="{{showCrit}}" class="mc-crit-tag">暴击!</text>
        <text class="mc-damage-num">-{{playerDamageAmount}}</text>
      </view>

      <!-- 怪物HP条 -->
      <view class="mc-hp-bar-wrap">
        <view class="mc-hp-bar mc-hp-enemy">
          <view class="mc-hp-fill" style="width:{{monsterHpPercent}}%"></view>
        </view>
        <text class="mc-hp-text">{{monster.hp}}/{{monster.maxHP}}</text>
      </view>
    </view>

    <!-- VS Indicator -->
    <view class="mc-vs-section">
      <view class="mc-vs-block">
        <text class="mc-vs-text">VS</text>
      </view>
      <text class="mc-node-label">{{nodeLabel}}</text>
    </view>

    <!-- Player Section -->
    <view class="mc-player-section {{isPlayerDamaged ? 'player-shake' : ''}}">
      <!-- Floating damage on player -->
      <view wx:if="{{showMonsterDamage}}" class="mc-damage-float mc-damage-player">
        <text class="mc-damage-num mc-damage-red">-{{monsterDamageAmount}}</text>
      </view>

      <view class="mc-player-row">
        <!-- 玩家像素角色 -->
        <view class="mc-player-block">
          <view class="mc-steve-head">
            <text class="mc-steve-face">🧑‍🎓</text>
          </view>
          <view class="mc-steve-body">
            <view class="mc-steve-arm mc-steve-arm-l"></view>
            <view class="mc-steve-torso"></view>
            <view class="mc-steve-arm mc-steve-arm-r"></view>
          </view>
          <view class="mc-steve-legs">
            <view class="mc-steve-leg mc-steve-leg-l"></view>
            <view class="mc-steve-leg mc-steve-leg-r"></view>
          </view>
        </view>

        <view class="mc-player-info">
          <view class="mc-player-lv">Lv.{{char.level}}</view>
          <view class="mc-stats-inline">
            <text class="mc-stat-atk">⚔{{charStats.atk}}</text>
            <text class="mc-stat-def">🛡{{charStats.def}}</text>
          </view>
        </view>
      </view>

      <!-- 玩家HP条 -->
      <view class="mc-hp-bar-wrap">
        <view class="mc-hp-bar mc-hp-player">
          <view class="mc-hp-fill mc-hp-fill-green" style="width:{{playerHpPercent}}%"></view>
        </view>
        <text class="mc-hp-text">{{playerHp}}/{{playerMaxHp}}</text>
      </view>
    </view>

  </view>

  <!-- ====== Question Area (Bottom Half) ====== -->
  <view class="mc-question-area" wx:if="{{!battleOver}}">

    <!-- Question Progress -->
    <view class="mc-progress">
      <text class="mc-counter">第 {{questionIndex + 1}} 题</text>
      <view class="mc-progress-dots">
        <view wx:for="{{progressDots}}" wx:key="index" class="mc-dot mc-dot-{{item}}"></view>
      </view>
    </view>

    <!-- Question Card -->
    <view class="mc-question-card" wx:if="{{currentQuestion}}">
      <text class="mc-question-text">{{currentQuestion.q}}</text>
    </view>

    <!-- Options -->
    <view class="mc-options">
      <view
        wx:for="{{currentQuestion.options}}"
        wx:key="index"
        class="mc-option mc-option-{{answeredOptions[index] || 'default'}} {{selectedOption === index ? 'mc-option-selected' : ''}}"
        data-index="{{index}}"
        bindtap="selectAnswer"
      >
        <view class="mc-option-label">
          <text>{{index === 0 ? 'A' : index === 1 ? 'B' : index === 2 ? 'C' : 'D'}}</text>
        </view>
        <text class="mc-option-text">{{item}}</text>
        <text wx:if="{{showResult && index === currentQuestion.answer}}" class="mc-result-icon mc-result-correct">✓</text>
        <text wx:if="{{showResult && selectedOption === index && index !== currentQuestion.answer}}" class="mc-result-icon mc-result-wrong">✗</text>
      </view>
    </view>

    <!-- Explanation -->
    <view class="mc-explanation" wx:if="{{showResult}}">
      <view class="mc-exp-header {{isCorrect ? 'mc-exp-ok' : 'mc-exp-fail'}}">
        <text>{{isCorrect ? '✅ 回答正确！攻击成功！' : '❌ 回答错误！怪物反击！'}}</text>
      </view>
      <text class="mc-exp-text">{{explanation}}</text>
    </view>

  </view>

  <!-- ====== Battle Log ====== -->
  <view class="mc-log-section">
    <scroll-view
      scroll-y
      class="mc-log-scroll"
      scroll-into-view="log-{{battleLog.length - 1}}"
      scroll-with-animation
    >
      <view wx:for="{{battleLog}}" wx:key="index" id="log-{{index}}" class="mc-log-entry">
        <text>{{item}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- ====== Victory Overlay ====== -->
  <view class="mc-result-overlay" wx:if="{{victory}}">
    <view class="mc-result-bg"></view>
    <view class="mc-result-card mc-victory-card">
      <text class="mc-result-emoji">🎉</text>
      <text class="mc-result-title mc-victory-title mc-text">战斗胜利！</text>

      <view class="mc-rewards">
        <view class="mc-reward-row">
          <text class="mc-reward-icon">✨</text>
          <text class="mc-reward-label">经验值</text>
          <text class="mc-reward-value">+{{rewards.xp}}</text>
        </view>
        <view class="mc-reward-row">
          <text class="mc-reward-icon">🪙</text>
          <text class="mc-reward-label">金币</text>
          <text class="mc-reward-value">+{{rewards.coins}}</text>
        </view>
      </view>

      <view class="mc-battle-stats">
        <view class="mc-stat-col">
          <text class="mc-stat-num mc-green">{{monster.correctCount}}</text>
          <text class="mc-stat-lbl">答对</text>
        </view>
        <view class="mc-stat-col">
          <text class="mc-stat-num mc-red">{{monster.wrongCount}}</text>
          <text class="mc-stat-lbl">答错</text>
        </view>
        <view class="mc-stat-col">
          <text class="mc-stat-num">{{monster.questionsAnswered}}</text>
          <text class="mc-stat-lbl">总题数</text>
        </view>
      </view>

      <view class="mc-levelup" wx:if="{{leveledUp}}">
        <text>⬆️ 升级！Lv.{{char.level}}</text>
      </view>

      <view class="mc-achievements" wx:if="{{newAchievements.length > 0}}">
        <text class="mc-ach-title">成就解锁！</text>
        <view wx:for="{{newAchievements}}" wx:key="id" class="mc-ach-item">
          <text class="mc-ach-emoji">{{item.emoji}}</text>
          <text class="mc-ach-name">{{item.name}}</text>
        </view>
      </view>

      <view class="mc-bonus" wx:if="{{rewards.bonus}}">
        <text>🎁 额外掉落：{{rewards.bonus}}</text>
      </view>

      <view class="mc-btn mc-btn-green" bindtap="goBack">
        <text class="mc-btn-text">返回地图</text>
      </view>
    </view>
  </view>

  <!-- ====== Defeat Overlay ====== -->
  <view class="mc-result-overlay" wx:if="{{defeat}}">
    <view class="mc-result-bg"></view>
    <view class="mc-result-card mc-defeat-card">
      <text class="mc-result-emoji">💀</text>
      <text class="mc-result-title mc-defeat-title mc-text">战斗失败</text>
      <text class="mc-defeat-desc">HP归零了...回去恢复吧！</text>

      <view class="mc-battle-stats">
        <view class="mc-stat-col">
          <text class="mc-stat-num mc-green">{{monster.correctCount}}</text>
          <text class="mc-stat-lbl">答对</text>
        </view>
        <view class="mc-stat-col">
          <text class="mc-stat-num mc-red">{{monster.wrongCount}}</text>
          <text class="mc-stat-lbl">答错</text>
        </view>
      </view>

      <view class="mc-btn mc-btn-red" bindtap="retry">
        <text class="mc-btn-text">重新挑战</text>
      </view>
      <view class="mc-btn mc-btn-gray" bindtap="goBack">
        <text class="mc-btn-text">返回地图</text>
      </view>
    </view>
  </view>

</view>
