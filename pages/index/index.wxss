.header {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #a855f7 100%);
  color: #fff;
  padding: 40rpx 36rpx 32rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin: -24rpx -28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.header-sub { font-size: 24rpx; opacity: 0.85; display: block; margin-bottom: 8rpx; }
.header-main { font-size: 44rpx; font-weight: 800; display: block; letter-spacing: 2rpx; }
.header-date { font-size: 24rpx; opacity: 0.7; display: block; margin-top: 10rpx; }

.day-type-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.day-type-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  white-space: nowrap;
}
.day-type-tag.weekday {
  background: #eff6ff;
  color: #2563eb;
}
.day-type-tag.weekend {
  background: #fef3c7;
  color: #92400e;
}
.day-type-tag.holiday {
  background: #fce7f3;
  color: #be185d;
}
.day-type-hint {
  font-size: 24rpx;
  color: #64748b;
  flex: 1;
}

.header-right { text-align: right; }
.progress-badge {
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 14rpx 24rpx;
}
.progress-label { font-size: 22rpx; opacity: 0.8; display: block; }
.progress-num { font-size: 40rpx; font-weight: 800; display: block; text-align: center; }

.phase-bar {
  display: flex;
  gap: 6rpx;
  height: 12rpx;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.phase-legend { margin-bottom: 24rpx; }
.phase-item {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 12rpx 0;
  gap: 12rpx;
}
.phase-dot { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; }
.phase-name { font-size: 26rpx; font-weight: 600; }
.phase-period { font-size: 22rpx; color: #94a3b8; }
.phase-desc { font-size: 22rpx; color: #64748b; width: 100%; padding-left: 28rpx; }
.expand-arrow { font-size: 24rpx; color: #94a3b8; }

.task-highlight {
  border-radius: 20rpx;
  padding: 28rpx;
}
.task-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.task-sub { display: flex; align-items: center; gap: 12rpx; }
.task-emoji { font-size: 36rpx; }
.task-sub-name { font-weight: 700; font-size: 32rpx; }
.active-tag { font-size: 22rpx; color: #fff; padding: 4rpx 16rpx; border-radius: 10rpx; }
.task-time { font-size: 26rpx; color: #64748b; font-weight: 500; }
.task-detail { font-size: 28rpx; color: #334155; line-height: 1.7; display: block; margin-bottom: 12rpx; }
.type-tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 10rpx; font-weight: 500; }
.done-msg { color: #94a3b8; text-align: center; padding: 20rpx; display: block; }

.task-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  gap: 16rpx;
}
.task-item:last-child { border-bottom: none; }
.check-btn {
  width: 44rpx; height: 44rpx; border-radius: 12rpx;
  border: 4rpx solid; flex-shrink: 0; margin-top: 4rpx;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.check-mark { color: #fff; font-size: 24rpx; font-weight: 700; }
.task-info { flex: 1; }
.task-info-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.task-info-name { font-weight: 600; font-size: 28rpx; }
.task-info-time { font-size: 24rpx; color: #94a3b8; }
.weak-tag {
  font-size: 20rpx;
  color: #fff;
  background: #ef4444;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.task-info-desc { font-size: 26rpx; color: #475569; line-height: 1.6; display: block; }
.go-btn {
  font-size: 24rpx; padding: 10rpx 20rpx;
  border-radius: 14rpx; font-weight: 500; white-space: nowrap;
  flex-shrink: 0;
}

.empty-tip { text-align: center; color: #94a3b8; padding: 32rpx; font-size: 28rpx; }

.subject-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.subject-btn {
  background: #fff;
  border: 2rpx solid;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.subject-btn-icon { font-size: 48rpx; display: block; margin-bottom: 8rpx; }
.subject-btn-name { font-size: 26rpx; font-weight: 600; display: block; }

.routine-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.routine-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 20rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  width: calc(50% - 6rpx);
  box-sizing: border-box;
}
.routine-icon { font-size: 32rpx; }
.routine-info { flex: 1; }
.routine-time { font-size: 24rpx; font-weight: 600; color: #475569; display: block; }
.routine-task { font-size: 22rpx; color: #64748b; display: block; }

.title-icon { font-size: 32rpx; margin-right: 12rpx; }

.rank-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.rank-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.rank-badge-emoji { font-size: 28rpx; }
.rank-badge-name { font-size: 24rpx; font-weight: 700; }
.streak-badge {
  padding: 10rpx 20rpx;
  background: #fffbeb;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #92400e;
  font-weight: 500;
}
.xp-badge {
  padding: 10rpx 20rpx;
  background: #f0fdf4;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #166534;
  font-weight: 600;
}
