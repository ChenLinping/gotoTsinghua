<view class="container">

  <!-- 倒计时头部 -->
  <view class="header">
    <view class="header-left">
      <text class="header-sub" wx:if="{{userName}}">{{userName}}，加油！</text>
      <text class="header-sub" wx:else>走向清华 · 物化生理科生</text>
      <text class="header-main">距高考还有 {{daysLeft}} 天</text>
      <text class="header-date">{{dateStr}} {{dayName}} · {{phaseName}}</text>
    </view>
    <view class="header-right">
      <view class="progress-badge">
        <text class="progress-label">今日进度</text>
        <text class="progress-num">{{completedCount}}/{{totalTasks}}</text>
      </view>
    </view>
  </view>

  <!-- 日期类型标签 -->
  <view class="day-type-bar">
    <view class="day-type-tag {{dayType === 'holiday' ? 'holiday' : dayType === 'weekend' ? 'weekend' : 'weekday'}}">
      {{dayTypeLabel}}
    </view>
    <text class="day-type-hint" wx:if="{{dayType === 'weekday'}}">在校上课，晚上安排1节自学</text>
    <text class="day-type-hint" wx:elif="{{dayType === 'weekend' && holidayName === ''}}">周末自主学习，合理安排作息</text>
    <text class="day-type-hint" wx:else>{{holidayName}}期间，高效利用整块时间</text>
  </view>

  <!-- 段位和连胜 -->
  <view class="rank-bar">
    <view class="rank-badge" style="border-color:{{rank.color}}">
      <text class="rank-badge-emoji">{{rank.emoji}}</text>
      <text class="rank-badge-name" style="color:{{rank.color}}">{{rank.name}}</text>
    </view>
    <view class="streak-badge" wx:if="{{streak >= 1}}">
      <text>{{streak >= 7 ? '🔥' : streak >= 3 ? '💫' : '✨'}} {{streak}}天连胜</text>
    </view>
    <view class="xp-badge">
      <text>{{totalXP}} XP</text>
    </view>
  </view>

  <!-- 阶段进度条 -->
  <view class="phase-bar">
    <view wx:for="{{phases}}" wx:key="name" class="phase-seg" style="background:{{item.isActive ? '#fff' : 'rgba(255,255,255,0.35)'}};flex:1" data-phase="{{item}}" bindtap="onPhaseTap">
    </view>
  </view>
  <view class="phase-legend" wx:if="{{showSchedule}}">
    <view wx:for="{{phases}}" wx:key="name" class="phase-item">
      <view class="phase-dot" style="background:{{item.color}};box-shadow:{{item.isActive ? '0 0 0 6rpx ' + item.color + '33' : 'none'}}"></view>
      <text class="phase-name" style="color:{{item.isActive ? item.color : '#64748b'}}">{{item.name}} {{item.isActive ? '（当前）' : ''}}</text>
      <text class="phase-period">{{item.period}}</text>
      <text class="phase-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 当前/下一个学习时段 -->
  <view class="card" wx:if="{{currentTask}}">
    <view class="card-title">
      <text class="title-icon" style="color:#f59e0b">⚡</text>
      <text>正在学习</text>
    </view>
    <view class="task-highlight" style="background:{{currentTask.bg}};border-left:8rpx solid {{currentTask.color}}">
      <view class="task-top">
        <view class="task-sub">
          <text class="task-emoji">{{currentTask.subjectIcon}}</text>
          <text class="task-sub-name" style="color:{{currentTask.text}}">{{currentTask.subjectName}}</text>
          <text class="active-tag" style="background:{{currentTask.color}}">进行中</text>
        </view>
        <text class="task-time">{{currentTask.time}}</text>
      </view>
      <text class="task-detail">{{currentTask.task}}</text>
      <text class="type-tag" style="background:{{currentTask.color}}22;color:{{currentTask.color}}">{{currentTask.type}}</text>
    </view>
  </view>

  <view class="card" wx:elif="{{nextTask}}">
    <view class="card-title">
      <text class="title-icon" style="color:#f59e0b">⏰</text>
      <text>下一个学习时段{{nextTask.isNextDay ? '（' + nextTask.dayLabel + '）' : ''}}</text>
    </view>
    <view class="task-highlight" style="background:{{nextTask.bg}};border-left:8rpx solid {{nextTask.color}}">
      <view class="task-top">
        <view class="task-sub">
          <text class="task-emoji">{{nextTask.subjectIcon}}</text>
          <text class="task-sub-name" style="color:{{nextTask.text}}">{{nextTask.subjectName}}</text>
        </view>
        <text class="task-time">{{nextTask.time}}</text>
      </view>
      <text class="task-detail">{{nextTask.task}}</text>
    </view>
  </view>

  <view class="card" wx:else>
    <view class="card-title">
      <text class="title-icon">🌙</text>
      <text>今日学习已结束</text>
    </view>
    <text class="done-msg">好好休息，明天继续加油！</text>
  </view>

  <!-- 今日任务清单 -->
  <view class="card">
    <view class="card-title">
      <text class="title-icon" style="color:#4f46e5">🎯</text>
      <text>今日任务（{{dayName}}）</text>
    </view>

    <view wx:if="{{tasks.length === 0}}" class="empty-tip">
      今天没有安排学习任务，好好休息~
    </view>

    <view wx:for="{{tasks}}" wx:key="key" class="task-item" style="opacity:{{item.done ? '0.5' : '1'}}">
      <view class="check-btn {{item.done ? 'checked' : ''}}" bindtap="toggleTask" data-index="{{item.index}}" style="border-color:{{item.done ? '#10b981' : '#cbd5e1'}};background:{{item.done ? '#10b981' : 'transparent'}}">
        <text wx:if="{{item.done}}" class="check-mark">✓</text>
      </view>
      <view class="task-info">
        <view class="task-info-top">
          <text>{{item.subjectIcon}}</text>
          <text class="task-info-name" style="color:{{item.text}}">{{item.subjectName}}</text>
          <text wx:if="{{item.isWeak}}" class="weak-tag">重点</text>
          <text class="task-info-time">{{item.time}}</text>
        </view>
        <text class="task-info-desc" style="text-decoration:{{item.done ? 'line-through' : 'none'}}">{{item.task}}</text>
      </view>
      <view wx:if="{{!item.done}}" class="go-btn" style="background:{{item.bg}};color:{{item.color}}" bindtap="goToSubject" data-subject="{{item.subject}}">
        去复习
      </view>
    </view>
  </view>

  <!-- 展开/收起阶段规划 -->
  <view class="card" bindtap="toggleSchedule">
    <view class="card-title" style="justify-content:space-between">
      <view style="display:flex;align-items:center">
        <text class="title-icon" style="color:#f59e0b">✨</text>
        <text>全年阶段规划</text>
      </view>
      <text class="expand-arrow">{{showSchedule ? '收起' : '展开'}}</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="subject-grid">
    <view wx:for="{{subjects}}" wx:key="name" class="subject-btn" style="border-color:{{item.color}}22" bindtap="goToSubject" data-subject="{{item.subject || ''}}">
      <text class="subject-btn-icon">{{item.icon}}</text>
      <text class="subject-btn-name" style="color:{{item.color}}">{{item.name}}</text>
    </view>
  </view>

  <!-- 每日作息 -->
  <view class="card" style="margin-top:24rpx">
    <view class="card-title">
      <text class="title-icon" style="color:#10b981">⏰</text>
      <text>每日作息建议</text>
    </view>
    <view class="routine-grid">
      <view wx:for="{{routine}}" wx:key="time" class="routine-item">
        <text class="routine-icon">{{item.icon}}</text>
        <view class="routine-info">
          <text class="routine-time">{{item.time}}</text>
          <text class="routine-task">{{item.task}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
